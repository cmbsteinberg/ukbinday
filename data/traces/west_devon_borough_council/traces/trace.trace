uide-nav__list-item"},["A",{"href":"/waste-and-recycling/guide-waste-and-recycling","hreflang":"en"},"Introduction"]],"\n                                  ",["LI",{"class":"lgd-guide-nav__list-item"},["A",{"href":"/waste-and-recycling/guide-waste-and-recycling/assisted-collection","hreflang":"en"},"Assisted collection"]],"\n                                  ",["LI",{"class":"lgd-guide-nav__list-item"},["A",{"href":"/waste-and-recycling/guide-waste-and-recycling/household-refuse","hreflang":"en"},"Household refuse"]],"\n                                ",["LI",{"class":"lgd-guide-nav__list-item lgd-guide-nav__list-item--active","aria-current":"page"},"Recycling"],"\n                                    ",["LI",{"class":"lgd-guide-nav__list-item"},["A",{"href":"/waste-and-recycling/guide-waste-and-recycling/food-waste","hreflang":"en"},"Food waste"]],"\n                                  ",["LI",{"class":"lgd-guide-nav__list-item"},["A",{"href":"/waste-and-recycling/guide-waste-and-recycling/garden-waste-service","hreflang":"en"},"Garden waste service"]],"\n                                  ",["LI",{"class":"lgd-guide-nav__list-item"},["A",{"href":"/waste-and-recycling/guide-waste-and-recycling/healthcare-waste-collections","hreflang":"en"},"Healthcare waste"]],"\n                                  ",["LI",{"class":"lgd-guide-nav__list-item"},["A",{"href":"/waste-and-recycling/guide-waste-and-recycling/bulky-waste-collections","hreflang":"en"},"Bulky waste"]],"\n                                  ",["LI",{"class":"lgd-guide-nav__list-item"},["A",{"href":"/waste-and-recycling/guide-waste-and-recycling/recycling-banks","hreflang":"en"},"Recycling centres and banks"]],"\n                                  ",["LI",{"class":"lgd-guide-nav__list-item"},["A",{"href":"/waste-and-recycling/guide-waste-and-recycling/where-does-my-recycling-and-waste-go","hreflang":"en"},"Where does my recycling and waste go?"]],"\n                                  ",["LI",{"class":"lgd-guide-nav__list-item"},["A",{"href":"/waste-and-recycling/guide-waste-and-recycling/how-can-i-recycle-more","hreflang":"en"},"How can I recycle more?"]],"\n                                  ",["LI",{"class":"lgd-guide-nav__list-item"},["A",{"href":"/waste-and-recycling/guide-waste-and-recycling/waste-and-recycling-faqs","hreflang":"en"},"Frequently asked questions"]],"\n                                  ",["LI",{"class":"lgd-guide-nav__list-item"},["A",{"href":"/waste-and-recycling/guide-waste-and-recycling/order-new-stickers","hreflang":"en"},"Order new stickers"]],"\n                                  ",["LI",{"class":"lgd-guide-nav__list-item"},["A",{"href":"/metalmatters","hreflang":"en"},"MetalMatters"]],"\n                  "],"\n  "],"\n\n\n  "],"\n\n    "],"\n\n          "],"\n    \n  "],"\n\n  \n                        \n  \n  \n  \n\n  ",["DIV",{"class":"lgd-region lgd-region--content region region-content"},"\n\n    \n    ",["DIV",{"class":"lgd-region__inner lgd-region__inner--content"},"\n      ",["DIV",{"id":"block-localgov-westdevon-localgov-mainpagecontent-base--2","class":"block block-system block-system-main-block"},"\n  \n    \n      \n\n\n",["ARTICLE",{"class":"lgd-guides lgd-guides--page node node--type-localgov-guides-page node--view-mode-full"},"\n  ",["DIV",{"class":"lgd-container padding-horizontal"},"\n    \n            ",["H2",{"class":"lgd-guides__title","id":"lgd-guides__title"},"\n        Recycling - Boxes and Sack\n      "],"\n          \n\n          ",["DIV",{"class":"lgd-guides__content node__content"},"\n        \n            ",["DIV",{"class":"field field--name-body field--type-text-with-summary field--label-hidden field__item"},["P",{},"Your recycling boxes and reusable white sack are collected weekly."],"\n",["P",{},["STRONG",{},"Please put your recycling boxes and sacks out at your collection point by 7.30 a.m. on your collection day."]],"\n",["HR"],"\n",["H2",{},"Reusable white sack"],"\n",["P",{},"Your white sack is for household plastics and metal packaging."],"\n",["H3",{},"Plastic packaging"],"\n",["UL",{},"\n",["LI",{},"Detergent and soap bottles (no pumps)"],"\n",["LI",{},"Cleaning product bottles"],"\n",["LI",{},"Skin care product bottles"],"\n",["LI",{},"Pop and water bottles"],"\n",["LI",{},"Milk bottles"],"\n",["LI",{},"Pots (e.g. yoghurt, soup)"],"\n",["LI",{},"Tubs (e.g. margarine, ice cream)"],"\n",["LI",{},"Trays and punnets (meat trays, takeaway trays, fruit and veg trays)"],"\n",["LI",{},"Plant pots (not black ones)"],"\n"],"\n",["H3",{},"Metal packaging"],"\n",["UL",{},"\n",["LI",{},"Drink cans"],"\n",["LI",{},"Food tins"],"\n",["LI",{},"Biscuit or chocolate tins"],"\n",["LI",{},"Aerosols (empty)"],"\n",["LI",{},"Aluminium Foil"],"\n",["LI",{},"Foil Trays (takeaway trays)"],"\n",["LI",{},"Aluminium tubes ( e.g. tomato purée)"],"\n",["LI",{},"Metal lids from jars and bottles"],"\n"],"\n",["P",{},"Empty all packaging and rinse clean. Replace bottle lids and tops, and flatten bottles where possible. You can leave labels on all packaging, but place film lids, absorbent pads etc. in your black sack."],"\n",["HR"],"\n",["H2",{},"Recycling Box 1"],"\n",["P",{},"Recycling box 1 is for paper, glass bottles and jars, and cartons."],"\n",["H3",{},"Paper"],"\n",["UL",{},"\n",["LI",{},"Paper"],"\n",["LI",{},"Magazine, brochures and catalogues"],"\n",["LI",{},"White paper (e.g. computer paper, letters etc.)"],"\n",["LI",{},"Telephone directories"],"\n",["LI",{},"Envelopes (including those with windows)"],"\n",["LI",{},"Book"],"\n",["LI",{},"Shredded paper (loosely tied in a bag)"],"\n"],"\n",["H3",{},"Glass bottles and jars"],"\n",["UL",{},"\n",["LI",{},"Bottles of any colour (e.g. wine, beer, sauce, oil etc.)"],"\n",["LI",{},"Jars of any colour (e.g. jam, sauce, baby food etc.)"],"\n",["LI",{},"Non-food bottles and jars (e.g. perfume, aftershave, face creams)"],"\n"],"\n",["H3",{},"Cartons"],"\n",["UL",{},"\n",["LI",{},"Drinks cartons (e.g. juices, milk, plant-based milk"],"\n",["LI",{},"Food cartons (e.g. soup, custard, flour)"],"\n"],"\n",["P",{},["STRONG",{},"Items must be sorted by material type within the box; so for example, place glass at one end of the box, cartons at the other and paper in the middle."]],"\n",["P",{},"Paper must be free of dirt, food or paint. Dirty or greasy paper (such as chip shop wrappers) should go in your black sacks."],"\n",["P",{},"Metal lids and caps should go in the reusable sack. Empty and rinse all containers, and where possible, squash or fold containers to save space."],"\n",["HR"],"\n",["H2",{},"Recycling Box 2"],"\n",["P",{},"Recycling Box 2 is for cardboard, batteries and printer cartridges, and clothes."],"\n",["H3",{},"Cardboard"],"\n",["UL",{},"\n",["LI",{},"Cardboard boxes (e.g. cereal boxes, dishwasher tablet boxes)"],"\n",["LI",{},"Corrugated cardboard"],"\n",["LI",{},"Online delivery boxes and cardboard envelopes"],"\n",["LI",{},"Greeting cards - no glitter"],"\n",["LI",{},"Egg boxes"],"\n",["LI",{},"Brown paper"],"\n"],"\n",["H3",{},"Batteries and Printer Cartridges"],"\n",["UL",{},"\n",["LI",{},"AAA, AA, C, D, and 9V"],"\n",["LI",{},"Common household batteries used in remote controls, small torches, clocks, etc."],"\n",["LI",{},"All household printer cartridges"],"\n"],"\n",["H3",{},"Clothes"],"\n",["UL",{},"\n",["LI",{},"Trousers and skirts"],"\n",["LI",{},"Jumpers and cardigans"],"\n",["LI",{},"Coats and jackets"],"\n",["LI",{},"Shirts and t-shirts"],"\n"],"\n",["P",{},["STRONG",{},"Items must be sorted by material type within the box; so for example, place glass at one end of the box, cartons at the other and paper in the middle."]],"\n",["P",{},"Cardboard must be free of dirt, food or paint. Dirty or greasy cardboard (such as takeaway pizza boxes) should go in your black sacks."],"\n",["P",{},"Pieces of cardboard can be placed alongside Box 2 if your box is full, as long as they are under 70 cm long."],"\n",["P",{},"Clothes must be clean and dry."],"\n",["P",{},"Batteries should be placed in a small clear tied bag, such as a sandwich bag or empty bread bag. Cover the contacts on lithium and button batteries with sticky tape to reduce fire risk.",["BR"],["BR"],["STRONG",{},"Please note the following batteries are cannot be placed in recycling boxes and should be taken to an appropriate recycling centre."]],"\n",["UL",{},"\n",["LI",{},"Rechargeable lithium-ion cells (e.g., vape batteries, power tool packs)"],"\n",["LI",{},"Industrial or high-capacity batteries"],"\n",["LI",{},"Damaged, leaking or corroded batteries of any kind"],"\n"],"\n"],"\n      \n      "],"\n      "],"\n"],"\n\n  "],"\n",["DIV",{"id":"block-chatbotcall","class":"block block-block-content block-block-content5553edba-0dd0-4e56-88c8-f66701b62ded"},"\n  \n    \n      \n            ",["DIV",{"class":"field field--name-body field--type-text-with-summary field--label-hidden field__item"}],"\n      \n  "],"\n\n    "],"\n\n    \n  "],"\n\n        \n      \n  \n  \n  \n\n  ",["DIV",{"class":"lgd-region lgd-region--content-bottom region region-content-bottom"},"\n\n          ",["DIV",{"class":"lgd-container padding-horizontal"},"\n    \n    ",["DIV",{"class":"lgd-region__inner lgd-region__inner--content-bottom"},"\n      ",["DIV",{"id":"block-localgov-westdevon-localgov-guides-prev-next-block-base","class":"block block-localgov-guides block-localgov-guides-prev-next-block"},"\n  \n    \n      \n\n\n\n\n\n",["NAV",{},"\n  ",["UL",{"class":"lgd-prev-next__list"},"\n          ",["LI",{"class":"lgd-prev-next__list-item lgd-prev-next__list-item--prev"},"\n        ",["A",{"href":"/waste-and-recycling/guide-waste-and-recycling/household-refuse#lgd-guides__title","class":"lgd-prev-next__link lgd-prev-next__link--prev","aria-label":"Previous: Household refuse"},"\n          \n\n\n",["DIV",{"aria-hidden":"true","class":"lgd-icon lgd-prev-next__icon lgd-prev-next__icon--prev"},["svg",{"xmlns":"http://www.w3.org/2000/svg","focusable":"false","viewBox":"0 0 320 512"},"\n  ","\n  ",["path",{"d":"M34.52 239.03L228.87 44.69