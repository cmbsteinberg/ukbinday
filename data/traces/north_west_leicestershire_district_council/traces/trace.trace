\t"],"\n"],"\n\n\t\t\t\t\t\t",["SECTION",{"class":"page-body"},"\n\t\t\t\t\t\t\t\n\t\t\t\t\t\t\t",["SECTION",{"id":"content","class":"page-content"},"\n\t\t\t\t\t\t\t\t",["ARTICLE",{"class":"module article with-attachments with-related-links","id":"article-recycling_and_waste"},"\n",["HEADER",{"class":"header empty"}],"\n",["DIV",{"class":"body"},["H2",{},"Top tasks:"],["UL",{"class":"section-links article-section-links"},["LI",{"class":"icon-wheelie-bin first"},["A",{"href":"/pages/paygardenwaste"},["SPAN",{},"Additional garden waste service"]]],["LI",{"class":"icon-fridge"},["A",{"href":"/pages/bulky_waste"},["SPAN",{},"Bulky waste collections"]]],["LI",{"class":"icon-wheelie-bin"},["A",{"href":"/pages/missed_collection"},["SPAN",{},"Missed waste collection"]]],["LI",{"class":"icon-recycle"},["A",{"href":"/pages/recyclemore"},["SPAN",{},"Recycle more"]]],["LI",{"class":"icon-default"},["A",{"href":"/pages/recycling_a_z_list"},["SPAN",{},"Recycling A to Z"]]],["LI",{"class":"icon-recycle"},["A",{"href":"/pages/recycling_centres_and_sites"},["SPAN",{},"Recycling and household waste sites"]]],["LI",{"class":"icon-recycle"},["A",{"href":"/pages/recycling_news"},["SPAN",{},"Recycling news and updates"]]],["LI",{"class":"icon-wheelie-bin"},["A",{"href":"/pages/container_request"},["SPAN",{},"Request recycling containers, bins and repairs"]]],["LI",{"class":"icon-roadsweeper"},["A",{"href":"/pages/street_cleansing"},["SPAN",{},"Street Cleansing"]]],["LI",{"class":"icon-recycle"},["A",{"href":"/pages/trade_waste_and_recycling"},["SPAN",{},"Trade waste and recycling"]]],["LI",{"class":"icon-tick"},["A",{"href":"/pages/waste_charter"},["SPAN",{},"Waste Charter"]]],["LI",{"class":"icon-recycle"},["A",{"href":"/pages/recycling_containers"},["SPAN",{},"What can I recycle and where?"]]],["LI",{"class":"icon-calendar"},["A",{"href":"/pages/collection_information"},["SPAN",{},"When is my next bin collection?"]]],["LI",{"class":"icon-default last"},["A",{"href":"/pages/recycling_information"},["SPAN",{},"Why recycle? And what happens to it?"]]]],["DIV",{"class":"pagecontent"},"\n",["H2",{"class":"normal"},"From this page you'll find lots of information and fun facts about reducing, reusing and recycling in North West Leicestershire."],"\n",["P",{},"From ",["A",{"data-cms-link-uri":"","href":"https://www.nwleics.gov.uk/pages/container_request","title":""},"ordering new or replacement recycling and waste containers and bins"],", to discovering our commercial waste services, have a look around and feel free to contact us with any questions or queries."],"\n",["P",{},["SPAN",{"class":"text"},"We have ",["A",{"data-cms-link-uri":"articles/581","href":"/pages/recycling_containers"},"different containers for different materials"]]," to help us collect a high quality of recycling."],"\n",["P",{},"Thank you for taking the time to separate your recycling. This helps to keep the quality high, produces a better end product and means we can sell the recycling to invest back into council services which helps to keep your council tax down."],"\n",["P",{},"All of our material goes to reprocessors in the UK and EU, so there is less travelling for the materials before they are recycled - saving both CO",["SUP",{},"2"]," ",["SPAN",{},"emissions and money. ",["A",{"data-cms-link-uri":"articles/581","href":"/pages/recycling_containers","title":""},"Find out what happens to your recycling"],". "]],"\n",["P",{},["SPAN",{"class":"text"},"For the latest news and updates:"]],"\n",["UL",{},"\n",["LI",{},["SPAN",{"class":"text"},"Follow our "],["A",{"data-cms-link-uri":"","href":"https://twitter.com/NWLEnviro#"},"Twitter "],"page"],"\n",["LI",{},"Sign up to our quarterly ",["A",{"data-cms-link-uri":"","href":"http://www.nwleics.gov.uk/enviroletter"},"NWL Enviro e-newsletter"]],"\n",["LI",{},"Visit our ",["A",{"data-cms-link-uri":"articles/1024","href":"/pages/recycling_news"},"recycling news"]," page",["SPAN",{},["BR"]]],"\n"],"\n\n"],"\n",["ARTICLE",{"class":"module a