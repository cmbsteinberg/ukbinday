ludo-search-default.min.css","type":"text/css","rel":"stylesheet"}],"\n    ",["STYLE",{},"\n        .search-input-wrapper-xs {\n            overflow: visible;\n        }\n    "],"\n    ","\n\n    ","\n    ","\n    ","\n    ","\n"],"\n\n","\n\n",["DIV",{"id":"main"}],"\n\n",["DIV",{"class":"container-fluid p-0 bg-light-grey"},"\n    ",["DIV",{"class":"container"},"\n        ",["DIV",{"class":"row"},"\n            ",["DIV",{"class":"col-12"},"\n                \n\n\n\n",["OL",{"class":"breadcrumb","role":"list"},"\n    ",["LI",{"class":"breadcrumb-item","role":"list-item"},"\n        ",["A",{"href":"/home","class":"text-decoration-none fw-bold","target":"_self","aria-label":"Homepage page link"},"Home"],"\n    "],"\n\n\n\n                        ",["LI",{"class":"breadcrumb-item","role":"listitem"},"\n                            ",["A",{"href":"https://www.tandridge.gov.uk/Recycling-and-rubbish","class":"text-decoration-none fw-bold","target":"_self","aria-label":"Recycling and rubbish page link"},"Recycling and rubbish"],"\n                    "],"\n                    ",["LI",{"class":"breadcrumb-item active","role":"listitem"},"\n                            ",["DIV",{"class":"text-decoration-none current text-dark fw-bold"},"Has your bin been missed?"],"\n                    "],"\n\n\n"],"\n            "],"\n        "],"\n    "],"\n"],"\n",["DIV",{"id":"maincontent","class":"container content-bg link-scrape-node inner"},"\n    ",["DIV",{"class":"row py-3"},"\n        ",["DIV",{"class":"col-xs-12"},"\n            ",["H1",{"class":"fw-bold"},"\n                Has your bin been missed?"],"\n        "],"\n    "],"\n    ",["DIV",{"class":"row"},"\n        ",["DIV",{"id":"dnn_ContentPane","class":"col-lg-9 col-12 pe-lg-5"},["DIV",{"class":"DnnModule DnnModule-DNN_HTML DnnModule-513"},["A",{"name":"513"}],"\n",["DIV",{"class":"DNNContainer_noTitle","style":"margin-bottom: 30px;"},"\n\t",["DIV",{"id":"dnn_ctr513_ContentPane"},["DIV",{"id":"dnn_ctr513_ModuleContent","class":"DNNModuleContent ModDNNHTMLC"},"\n\t",["DIV",{"id":"dnn_ctr513_HtmlModule_lblContent","class":"Normal"},"\n\t",["P",{},"Please put your bin at the edge of your property before ",["STRONG",{},"6am"]," on the day of your collection. All vehicles have CCTV footage and if your bins are not in the right place at the right time, the crew will not return."],"\n\n",["H2",{},"Rubbish and recycling collections"],"\n\n",["P",{},"If your recycling, food or rubbish collection has been missed, please let us know by completing the ",["A",{"href":"https://tdcws01.tandridge.gov.uk/TDCWebAppsPublic/tfaBranded/384"},"missed collection form"]," within two working days of your scheduled collection date."],"\n\n",["H2",{},"Bin collections "],"\n\n",["P",{},"To minimise delays, please follow these guidelines:"],"\n\n",["UL",{},"\n ",["LI",{},"Put your bins council issued bins or sacks out early, before 6am and leave them out until they’ve been emptied."],"\n ",["LI",{},"Be considerate when parking your car on your collection day. Sometimes our collection vehicles really struggle to turn into and along roads easily."],"\n ",["LI",{},"Put the right items in the right bins. Use the ",["A",{"href":"https://u6122735.ct.sendgrid.net/ls/click?upn=ngyhxfR4-2FB-2B-2FnGqaQKBriVnZn9xNfJefXdey8pMTUqYJUiXzxcqvCtYZGvxOdu4f8MY3HJhB-2FnVC4o41OpWllA-3D-3DFxeT_X1LMBPpNA4XRsYh-2BJGQ11t1yl2Hb0RiaIrVEdLUrdLzB3SB7LKM1NU5f1HUlf0MDLp-2FORTWFIO3eyMI9F0EXWYI-2FoBWjUpkycMsWZA8m1t9EQSEbkM-2BmUHY24XELkplYlH-2F5Nxt8IWJ1cqGEFia2yWEVcGSjZCopZfGiMmfct7z2aspR69vaqZUqD2rxEYJcDLFxlYfCWdEw-2B-2FtHxQClo2shAymzxJX0WR-2F0vDkMTuY5HCS385alBkOSILLjUDYsQU8SQ8w7jaipf6c3CeLO3KgCrCl8dfStMws-2F7Sp2h5-2Byn-2FQO6ofn-2BvH-2FVPVwIYA3910dkC06oFzHZ1Hd0Z-2Bd0VJ2QvYxeiECBUTW3d9xgx-2FG0WmdYWd9hGC7D0BkUBlAznkchEgLZo5tm37kLZ780vYEUtHkBM1ULJNkqEQq4QHdksR2R-2F-2BMzNcE13swf-2F7OINqUL8mkUpormqxoNTzE2IyxHgKeiv9rvHUJfYycH6Y-3D","target":"_blank","aria-label":"Surrey Recycles search tool - opens in new tab"},"Surrey Recycles search tool"]," to find out what goes in which bin."],"\n ",["LI",{},"Reduce the amount of waste you produce. Consider using an alternative reusable item. ",["A",{"href":"https://www.surreyep.org.uk/reduce-reuse-recycle/","target":"_blank","aria-label":"Read these tips on how to reduce the amount of waste you produce. - opens in new tab"},"Read these tips on how to reduce the amount of waste you produce."]],"\n ",["LI",{},"Empty, wash and squash your recycling into bins as much as possible to maximise space and only put bins out when they’re full."],"\n ",["LI",{},"Start composting at home. You can ",["A",{"href":"https://www.surreyep.org.uk/reduce-reuse-recycle/garden-waste/composting/compost-bin-sales/","target":"_blank","aria-label":"buy a compost bin at a reduced rate - opens in new tab"},"buy a compost bin at a reduced rate"],", but if you’d like to compost all your food waste, consider ",["A",{"href":"https://www.surreyep.org.uk/reduce-reuse-recycle/garden-waste/composting/compost-bins-and-food-waste-digesters/","target":"_blank","aria-label":"buying a waste digester - opens in new tab"},"buying a waste digester"],"."],"\n"],"\n\n",["H2",{},["STRONG",{},"Garden waste collections"]],"\n\n",["P",{},"To report a missed garden waste collection, please call the Green Waste Club on ",["STRONG",{},"0800 0858286"],", e-mail ",["A",{"href":"mailto:gwc@biffa.co.uk"},"gwc@biffa.co.uk"]," or log into your online account at ",["A",{"href":"https://www.greenwasteclub.co.uk","target":"_blank","aria-label":"www.greenwasteclub.co.uk - opens in new tab"},"www.greenwasteclub.co.uk"],". Missed collections need to be reported within two working days of your scheduled collection date."],"\n\n",["H2",{},["STRONG",{},"Community recycling centres"]],"\n\n",["UL",{},"\n ",["LI",{},"Caterham CRC is open 8am to 4pm Monday, Tuesday, Wednesday and Friday and 9am -4pm on Saturday and Sunday (Closed Thursday)."],"\n ",["LI",{},"Warlingham CRC is open 8am to 4pm Thursday and Friday and 9am to 4pm on Saturday (Closed Sunday to Wednesday)."],"\n ",["LI",{},"Earlswood CRC is open 8am to 4pm Monday to Friday and 9am to 4pm Saturday and Sunday."],"\n"],"\n\n",["P",{},"The",["STRONG",{}," ",["A",{"href":"https://www.westsussex.gov.uk/find-my-nearest/recycling-centre/details/api/type/recyclingsite/view/east-grinstead","target":"_blank","aria-label":"East Grinstead waste recycling site - opens in new tab"},"East Grinstead waste recycling site"]]," kindly allows residents, living in certain postcodes in the south of the district, to take their waste there. Please note you will need to book online before visiting the site."],"\n\n",["P",{},"More information about the ",["A",{"href":"http://www.surreycc.gov.uk/waste-and-recycling/community-recycling-centres","target":"_blank","aria-label":"community recycling centres - opens in new tab"},"community recycling centres"],"."],"\n\n",["UL",{},"\n"],"\n\n"],"\n\n"]],"\n\t",["DIV",{"class":"clear"}],"\n"],"\n"]],"\n        ",["DIV",{"class":"col-lg-3 col-12"},"\n            ",["DIV",{"id":"dnn_SidebarContentPane"},["DIV",{"class":"DnnModule DnnModule-2sxc-app DnnModule-4529 DnnVersionableControl"},["A",{"name":"4529"}],"\n",["DIV",{"class":"DNNContainer_noTitle","style":"margin-bottom: 30px;"},"\n\t",["DIV",{"id":"dnn_ctr4529_ContentPane"},["DIV",{"id":"dnn_ctr4529_ModuleContent","class":"DNNModuleContent Mod2sxcappC"},"\n\t",["DIV",{"class":"sc-content-block","data-cb-instance":"4529","data-cb-id":"4529"},"\n\n \n\n",["SECTION",{"role":"region"},"\n    ",["DIV",{"class":"buttons-app"},"\n        \n        ",["DIV",{"class":"col pb-lg-0 pb-3 ","role":"listitem"},"\n            ",["A",{"href":"https://tdcws01.tandridge.gov.uk/TDCWebAppsPublic/tfaBranded/384","class":"btn btn-danger  text-white text-start","target":"_self","aria-label":"Report a missed collection"},"Report a missed collection ",["I",{"class":"fa-solid fa-chevron-right ps-1 ","aria-hidden":"true"}]],"\n        "],"\n    "],"\n"],"\n"],"\n"]],"\n\t",["DIV",{"class":"clear"}],"\n"],