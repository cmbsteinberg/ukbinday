/sustainability"},"Sustainability"],"\n\t\t\t\n        "],"\n\t\t\n        ",["LI",{},"\n        \t",["A",{"href":"https://www.newrymournedown.org/whats-on-and-events"},"Culture, Arts, Heritage and Events"],"\n\t\t\t\n        "],"\n\t\t\n        ",["LI",{},"\n        \t",["A",{"href":"https://www.newrymournedown.org/new-telephone-numbers"},"Key Telephone Numbers"],"\n\t\t\t\n        "],"\n\t\t\n    "],"\n"],"\n"],"\n                \n                ",["SECTION",{"class":"section_content_nav"},"\n                \n                    \n\t\t",["H1",{"class":"h1sub"},"Bin Collection Information "],"\n    ",["H3",{},"Bin Collection Calendar"],"\n\n",["P",{},"The Council has recently introduced a postcode search facility. This facility is so residents can find address specific information about their bin collection day and schedule."],"\n\n",["P",{},["STRONG",{},"Please note:"]," We have not changed any collection schedules and ask that if the calendar associated with your postcode features the wrong collection day, you let us know by contacting us on 0330 137 4047. Thank you."],"\n\n",["H3",{},["STRONG",{},["A",{"href":"https://www.newrymournedown.org/weekly-bin-collections"},["FONT",{"color":"#0066cc"},"Click here"]]," "],"to enter your postcode to view bin collection dates for your area."],"\n\n",["P",{},"We are currently collecting all domestic bins on your normal collection day, we just ask that they are out by ",["STRONG",{},"6am"]," on the morning of collection",["STRONG",{},"."]," Please",["STRONG",{}," do not "],"leave",["STRONG",{}," "],"side waste or extra rubbish bags next to your bins."],"\n\n",["P",{},"We have three different coloured bins for the separate collection of household waste. The ",["A",{"href":"https://www.newrymournedown.org/blue-green-bin"},["U",{},"blue/green"]]," and ",["A",{"href":"https://www.newrymournedown.org/brown-bin"},["U",{},"brown"]]," bins are for recycling and the ",["A",{"href":"https://www.newrymournedown.org/black-bin"},["U",{},"black"]," "],"is for non-recyclable waste. "],"\n\n",["H3",{},"Important Information"],"\n\n",["P",{},"Please place your bin at the kerbside no later than ",["STRONG",{},"6am"],". Please leave the bin with handles facing the road and the lid closed. We will not collect loose or bagged waste."],"\n\n",["P",{},["STRONG",{},"IN THE EVENT OF UNFORESEEN CIRCUMSTANCES (E.G ADVERSE WEATHER) AND YOUR BIN HAS NOT BEEN COLLECTED PLEASE LEAVE YOUR BIN AT THE KERBSIDE FOR CATCH UP COLLECTION SERVICES.  "]],"\n\n",["P",{},["STRONG",{},["SPAN",{"style":"color: rgb(139, 69, 19);"},"Brown Bin"],":"]," food waste must go in the brown bin. You can purchase compostable brown bin liners in most local shops and supermarkets. Old newspapers can also be used to line your brown bin. ",["STRONG",{},"Strictly no food waste in the black bin."]],"\n\n",["P",{},["STRONG",{},["SPAN",{"style":"color: rgb(0, 0, 255);"},"Blue Bin"],":"]," all clean and dry recyclable waste including glass bottles and jars should go in the blue bin. Materials that can be recycled in your blue bin are:"],"\n\n",["UL",{},"\n\t",["LI",{},"mixed paper, newspaper and magazines"],"\n\t",["LI",{},"cardboard"],"\n\t",["LI",{},"metal cans and aerosols"],"\n\t",["LI",{},"cartons"],"\n\t",["LI",{},"gass bottles and jars"],"\n\t",["LI",{},"plastic bottles, pots, tubs and trays"],"\n"],"\n\n",["P",{},"For more detailed information about what you can put in your brown/ blue bin ",["A",{"href":"https://www.newrymournedown.org/media/uploads/recycle_right.pdf"},"click here "],"or phone 0330 137 4047.  "],"\n\n",["H3",{},"Battery Recycling"],"\n\n",["P",{},"Batteries must not be placed in the Council’s black, brown or blue/green wheelie bins. This is because batteries contain dangerous chemicals. When batteries are mixed with other waste they can cause fires at waste and recycling facilities, causing damage and posing a danger to those who work there."],"\n\n",["P",{},["STRONG",{},"So where can you safely recycle batteries?"]],"\n\n",["P",{},"Batteries can be recycled at your local ",["STRONG",{},"Household Recycling Centre (HRC)"]," where there are bins clearly labelled for batteries."],"\n\n",["P",{},"Some shops and supermarkets also provide recycling bins for batteries in store and your local school or community group may also have set up a collection scheme."],"\n\n",["P",{},"Remember the following when recycling batteries:"],"\n\n",["UL",{},"\n\t",["LI",{},"never put batteries in normal rubbish or recycle bins"],"\n\t",["LI",{},"only recycle batteries at your local Household Recycling Site or by using a proper battery recycling and collection scheme"],"\n\t",["LI",{},"remove batteries from devices if you can and recycle both the battery and the device separately in the bins provided at your local Household Recycling Centre"],"\n\t",["LI",{},"if you can’t remove the battery from the device recycle both together in the small electrical items bin at the HRC."],"\n"],"\n\n",["P",{},"Still unsure what to do visit ",["A",{"href":"http://www.takecharge.org.uk/"},"www.takecharge.co.uk"]," or email ",["A",{"href":"mailto:environment@nmandd.org "},"environment@nmandd.org "]],"\n\n",["H3",{}," "],"\n\n",["H3",{},"What Do I Do If My Bin Is Damaged?"],"\n\n",["P",{},"Refuse crews must report if they damage a bin whilst emptying. If this happens, the Council will replace your bin."],"\n\n",["P",{},"Sometimes bins split or become damaged due to normal wear and tear. In cases like this it is the responsibility of the householder to buy a replacement bin. For health and safety reasons, crews may not lift damaged bins.",["STRONG",{}," "]],"\n\n",["P",{},["A",{"href":"http://www.newrymournedown.org/buy-a-bin"},"Buy a Bin"],"."],"\n\n",["H3",{},"Contact Details"],"\n\n",["P",{},"If you need any further information, please contact:"],"\n\n",["P",{},"Waste Department Customer Services Section",["BR"],"\nTelephone: 0330 137 4047",["BR"],"\nEmail: ",["A",{"href":"mailto:environment@nmandd.org "},"environment@nmandd.org "]],"\n\n    \n\t",["DIV",{"class":"clearboth"}],"\n    \n\t\n                \n                "],"\n            \n            "],"\n        \n\t\t",["DIV",{"class":"spacer clearboth"}],"\n","\n",["DIV",{"class":"pswp","tabindex":"-1","role":"dialog","aria-hidden":"true"},"\n\n    ","\n    ",["DIV",{"class":"pswp__bg"}],"\n\n    ","\n    ",["DIV",{"class":"pswp__scroll-wrap"},"\n\n        ","\n        ","\n        ",["DIV",{"class":"pswp__container"},"\n            ",["DIV",{"class":"pswp__item"}],"\n            ",["DIV",{"class":"pswp__item"}],"\n            ",["DIV",{"class":"pswp__item"}],"\n        "],"\n\n        ","\n        ",["DIV",{"class":"pswp__ui pswp__ui--hidden"},"\n\n            ",["DIV",{"class":"pswp__top-bar"},"\n\n                ","\n\n                ",["DIV",{"class":"pswp__counter"}],"\n\n                ",["BUTTON",{"class":"pswp__button pswp__button--close","title":"Close (Esc)"}],"\n\n                ",["BUTTON",{"class":"pswp__button pswp__button--share","title":"Share"}],"\n\n                ",["BUTTON",{"class":"pswp__button pswp__button--fs","title":"Toggle fullscreen"}],"\n\n                ",["BUTTON",{"class":"pswp__button pswp__button--zoom","title":"Zoom in/out"}],"\n\n                ","\n                ","\n                ",["DIV",{"class":"pswp__preloader"},"\n                    ",["DIV",{"class":"pswp__preloader__icn"},"\n                      ",["DIV",{"class":"pswp__preloader__cut"},"\n                        ",["DIV",{"class":"pswp__preloader__donut"}],"\n                      "],"\n                    "],"\n                "],"\n            \n            "],"\n\n            ",["DIV",{"class":"pswp__share-modal pswp__share-modal--hidden pswp__single-tap"},"\n                ",["DIV",{"class":"pswp__share-tooltip"}]," \n            "],"\n\n            ",["BUTTON",{"class":"pswp__button pswp__button--arrow--left","title":"Previous (arrow left)"},"\n            "],"\n\n            ",["BUTTON",{"class":"pswp__butt