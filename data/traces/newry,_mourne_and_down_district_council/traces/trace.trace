phone Numbers"],"\n\t\t\t\n        "],"\n\t\t\n    "],"\n"],"\n"],"\n                \n                ",["SECTION",{"class":"section_content_nav"},"\n                \n                    \n\n",["H1",{},"Weekly Bin Collections and Calendar "],"\n\n",["H3",{},["SPAN",{"style":"color:#FF0000;"},"Please Note: Updated 2025/26 Bin Collection Calendars Are Now Available for Download on this page-see below!"]],"\n\n",["H2",{},"We aim to collect all bins on their scheduled collection day. However, sometimes for various reasons we may miss some. When a delay has occurred we will return to collect your bin on the next available day. We are asking all households to do the following:"],"\n\n",["OL",{},"\n\t",["LI",{},"Place bins out for collection no later than ",["STRONG",{},"6am"]," every morning or alternatively the night before."],"\n\t",["LI",{},"Please do not put out extra bins or place additional rubbish bags next to your bin as we cannot facilitate the collection of these."],"\n\t",["LI",{},"Help to keep our schedules on track by being mindful of where you park, making sure your vehicle doesn’t limit access on bin collection days – and spread the word to your neighbours too – thank you! "],"\n\t",["LI",{},"Residents are encouraged to maximise the use of their household bins by using the correct bin for your waste items – ie Black bin, Brown bin and Blue bin."],"\n\t",["LI",{},"Remember Food or Recyclable Waste should ",["STRONG",{},"NOT "],"be placed in your Black Bin. Bins containing the wrong materials may not be collected."],"\n"],"\n\n",["P",{},["STRONG",{},"TIPS:"]],"\n\n",["UL",{},"\n\t",["LI",{},["STRONG",{},"BLUE: "],"Flatten boxes"],"\n\t",["LI",{},["STRONG",{},"BLUE: "],"Flatten containers and remove lids"],"\n\t",["LI",{},["STRONG",{},"BLACK: "],"Do not place garden waste into your black bin"],"\n\t",["LI",{},["STRONG",{},"BROWN:"]," Use this bin for all food waste, start composting your garden waste "],"\n\t",["LI",{},"Wash your hands when handling bins and ensure bin handles are cleaned or wiped-down before and after use. Our staff will appreciate this"],"\n\t",["LI",{},"Do not approach our staff without following the minimum two-metre social distancing guidance."],"\n\t",["LI",{},"You must not put items such as used tissues, gloves or disposable cleaning cloths into your recycling bins. This is very important, they must be bagged and placed into your black bin."],"\n"],"\n\n",["H2",{},["STRONG",{},"Updated 2025/26 Bin Collection Calendars Now Available!"]],"\n\n",["H3",{},"To Access Your Weekly Bin Collection Schedule:"],"\n\n",["P",{},"1. Under  '",["STRONG",{},"SELECT"],"' move the arrow to the correct ",["STRONG",{},"FIRST 4 DIGITS "],"of your postcode and click your mouse to select it e.g BT24"],"\n\n",["P",{},"2. Move across to the second box and enter the",["STRONG",{}," LAST 3 digits"]," of your postcode e.g. 8ZH"],"\n\n",["P",{},"3. Finally click on '",["STRONG",{},"SEARCH"],"' to view your 'Weekly Bin Collection Schedule'"],"\n\n    ",["DIV",{"class":"spacer clearboth"}],"\n\n",["DIV",{"id":"search"}],"\n",["P",{"style":"font-size:18px;"},"Enter your postcode to view bin collection dates for you area:",["BR"],["SPAN",{"style":"font-size:14px;"},"(you will need to select the first part of your postcode where it says 'Select' before you begin)"]],"\n\n",["FORM",{"name":"mainbodyform","id":"mainbodyform","action":"#search","method":"post","class":"form_search_bin"},"\n    ",["SELECT",{"id":"PostcodeBT","name":"PostcodeBT"},"\n        ",["OPTION",{"__playwright_selected_":"true","value":""},"Select"],"\n        ",["OPTION",{"__playwright_selected_":"false","value":"BT23"},"BT23"],"\n        ",["OPTION",{"__playwright_selected_":"false","value":"BT24"},"BT24"],"\n        ",["OPTION",{"__playwright_selected_":"false","value":"BT25"},"BT25"],"\n        ",["OPTION",{"__playwright_selected_":"false","value":"BT27"},"BT27"],"\n        ",["OPTION",{"__playwright_selected_":"false","value":"BT30"},"BT30"],"\n        ",