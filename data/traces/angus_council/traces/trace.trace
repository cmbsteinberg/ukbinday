,"for":"rbCalendarType-0-AF-Field-e5c1d96e-e117-4044-b887-e80631379bb9-1b99647675"},"Full calendar"]],["SPAN",{"class":"radio-wrapper"},"\t",["INPUT",{"__playwright_value_":"S","__playwright_checked_":"false","type":"radio","id":"rbCalendarType-1-AF-Field-e5c1d96e-e117-4044-b887-e80631379bb9-1b99647675","name":"rbCalendarType","value":"S","required":"true","class":"radio2 ","autocomplete":"off"}],["LABEL",{"class":"radio-label ","for":"rbCalendarType-1-AF-Field-e5c1d96e-e117-4044-b887-e80631379bb9-1b99647675"},"Symbol calendar"]],["SPAN",{"class":"radio-wrapper"},"\t",["INPUT",{"__playwright_value_":"D","__playwright_checked_":"false","type":"radio","id":"rbCalendarType-2-AF-Field-e5c1d96e-e117-4044-b887-e80631379bb9-1b99647675","name":"rbCalendarType","value":"D","required":"true","class":"radio2 ","autocomplete":"off"}],["LABEL",{"class":"radio-label ","for":"rbCalendarType-2-AF-Field-e5c1d96e-e117-4044-b887-e80631379bb9-1b99647675"},"Text calendar"]]],["DIV",{"class":"screen-reader-error","aria-live":"polite","aria-atomic":"true"}]]," "],["DIV",{"class":"field","data-field-name":"autolookup1","data-field-type":"autoLookup","style":"display: none;"},["DIV",{"class":"fieldContent"},"\t",["DIV",{"data-name":"autolookup1","data-type":"autoLookup","class":"conditional fieldInput non-input autoLookup ","data-lookup":"66599c39c4c55","data-display-condition":"{rbShowCalendar} is 'yes'"}],["DIV",{"class":"screen-reader-error","aria-live":"polite","aria-atomic":"true"}]]," "],["DIV",{"class":"field","data-field-name":"html7","data-field-type":"html","style":"display: none;"},["DIV",{"class":"fieldContent"},"\t",["SPAN",{"data-name":"html7","data-type":"html","class":"col-xs-11 col-sm-11 conditional fieldInput content html non-input ","data-content":"<!DOCTYPE html>\n<html>\n<head>\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n<style>\n.loader {\n  border: 6px solid #f3f3f3;\n  border-radius: 50%;\n  border-top: 6px solid #3498db;\n  width: 40px;\n  height: 40px;\n  -webkit-animation: spin 1s linear infinite; /* Safari */\n  animation: spin 1s linear infinite;\n}\n\n/* Safari */\n@-webkit-keyframes spin {\n  0% { -webkit-transform: rotate(0deg); }\n  100% { -webkit-transform: rotate(360deg); }\n}\n\n@keyframes spin {\n  0% { transform: rotate(0deg); }\n  100% { transform: rotate(360deg); }\n}\n</style>\n</head>\n<body>\n\n<h4>Please wait while data is being loaded</h4>\n\n<div class=\"loader\"></div>\n\n</body>\n</html>","data-display-condition":"{rbShowCalendar} is 'yes' and {month1HTML} is ''"}],["DIV",{"class":"screen-reader-error","aria-live":"polite","aria-atomic":"true"}]]," "],["DIV",{"class":"field","data-field-name":"html6","data-field-type":"html","style":"display: none;"},["DIV",{"class":"fieldContent"},"\t",["SPAN",{"data-name":"html6","data-type":"html","class":"col-xs-11 col-sm-11 conditional fieldInput content html non-input ","data-content":"<style>\n/* --- Main body style --- */\n\ntable.outer\n{\n\tmargin-bottom:5px;\n}\ntable.smalltext\n{\n\tfont-family: Verdana, Arial, sans-serif;\n\tFONT-SIZE: 8px;\n}\n}\ntable.calmonth\n{\n\tpadding: 0px 1px;\n\tborder:3px solid #000;\n\tmargin-left: 15px;\n}\ntable.calmonthdate\n{\n\tpadding: 0px 0px;\n\tborder:3px solid #000;\n\tmargin-left: 15px;\n\tborder-collapse: collapse;\n}\ntd.norm\n{\n\twidth: 40px;\n\ttext-align: left;\n\tbackground-repeat: no-repeat;\n\tbackground-size: 100% 100%;\n\tbackground-position: center;\n}\n.head\n{\n\t/*background-color: #14A884;*/\n\tbackground-color: #0e7a5f;\n\tcolor: white;\n\tfont-weight: bold;\n\ttext-align: center;\n}\ntd.publichol\n{\n\tcolor:#ffffff;\n\tbackground-image:url(\"https://fs-filestore-eu.s3.amazonaws.com/angus/images/bins/publicholiday.gif\");\n\twidth: 40px;\n\ttext-align:center;\n\tbackground-repeat: no-repeat;\n\tbackground-size: 100% 100%;\n\tbackground-position: center;\n}\ntd.emptydate\n{\n\twidth: 30px;\n\ttext-align:center;\n\t/*border-bottom: 1px solid black;*/\n}\ntd.daybreak\n{\n\twidth: 40px;\n\ttext-align:right;\n\tfont-family: \"Courier New\", Courier, monospace;\n\twhite-space: nowrap;\n\t/*border-bottom: 1px solid black;*/\n}\ntd.keydate\n{\n\twidth: 30px;\n\ttext-align:center;\n}\ntd.fooddate\n{\n\tcolor:#ffffff;\n\tbackground-image:url(\"https://fs-filestore-eu.s3.amazonaws.com/angus/images/bins/BrownDate.gif\");\t\n\twidth: 30px;\n\ttext-align:center;\n\tbackground-repeat: no-repeat;\n\tbackground-size: 100% 100%;\n\tbackground-position: center;\n\t/*border-bottom: 1px solid black;*/\n\tpadding-top: 2px;\n}\ntd.gardendate\n{\n\tcolor:#ffffff;\n\tbackground-image:url(\"https://fs-filestore-eu.s3.amazonaws.com/angus/images/bins/GreenDate.gif\");\n\twidth: 30px;\n\ttext-align:center;\n\tbackground-repeat: no-repeat;\n\tbackground-size: 100% 100%;\n\tbackground-position: center;\n\t/*border-bottom: 1px solid black;*/\n\tpadding-top: 2px;\n}\ntd.generaldate\n{\n\tcolor:#ffffff;\n\tbackground-image:url(\"https://fs-filestore-eu.s3.amazonaws.com/angus/images/bins/PurpleDate.gif\");\n\twidth: 30px;\n\ttext-align:center;\n\tbackground-repeat: no-repeat;\n\tbackground-size: 100% 100%;\n\tbackground-position: center;\n\t/*border-bottom: 1px solid black;*/\n\tpadding-top: 2px;\n}\ntd.recyclingdate\n{\n\tcolor:#ffffff;\n\tbackground-image:url(\"https://fs-filestore-eu.s3.amazonaws.com/angus/images/bins/Greydate.gif\");\n\twidth: 30px;\n\ttext-align:center;\n\tbackground-repeat: no-repeat;\n\tbackground-size: 100% 100%;\n\tbackground-position: center;\n\t/*border-bottom: 1px solid black;*/\n\tpadding-top: 2px;\n}\ntd.fibredate\n{\n\tcolor:#ed1f11;\n\tbackground-image:url(\"https://fs-filestore-eu.s3.eu-west-1.amazonaws.com/angus/images/bins/Bluedate.gif\");\n\twidth: 30px;\n\ttext-align:center;\n\tbackground-repeat: no-repeat;\n\tbackground-size: 100% 100%;\n\tbackground-position: center;\n\t/*border-bottom: 1px solid black;*/\n\tpadding-top: 2px;\n}\nbody\n{\n\tfont-family: Verdana, Arial, sans-serif;\n\tFONT-SIZE: 12px;\n}\n.headfoot\n{\n\tfont-s