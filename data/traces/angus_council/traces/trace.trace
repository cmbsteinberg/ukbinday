,{"data-name":"html14","data-type":"html","class":"col-xs-11 col-sm-11 conditional fieldInput content html non-input ","data-content":"<p><h4><u>{p5FormattedDate}</u></h4></p>\n<p><b>{p5BinType}</b> ({p5BinTypeDesc}{p5GreenWasteSuffix})</p>\n<p>Your {p5LCBinType} bin is collected {p5binCollected} </p>\n\n<!---<p>{#p1BinCollected}</p>--->\n<p><a href=\"https://www.angus.gov.uk/bins_and_recycling/what_goes_in_your_bins\" target=\"_blank\" rel=\"noopener\">What goes in the {p5LCBinType} bin</a></p>","data-display-condition":"{p5BinType} isnt ''"}],["DIV",{"class":"screen-reader-error","aria-live":"polite","aria-atomic":"true"}]]," "],["DIV",{"class":"field","data-field-name":"statictext12","data-field-type":"html","style":"opacity: 1;"},["DIV",{"class":"fieldContent"},"\t",["SPAN",{"data-name":"statictext12","data-type":"html","class":"col-xs-11 col-sm-11 conditional fieldInput content html non-input ","data-content":"<p> <br></p><p><hr></p>\n<div><a href=\"https://www.angus.gov.uk/recycle/report_a_missed_bin\" target=\"_none\">Report a missed bin</a></div>","data-display-condition":"length({calendarURL}) = 0"},["P",{}," ",["BR"]],["P"],["HR"],["P"],"\n",["DIV",{},["A",{"href":"https://www.angus.gov.uk/recycle/report_a_missed_bin","target":"_none"},"Report a missed bin"]]],["DIV",{"class":"screen-reader-error","aria-live":"polite","aria-atomic":"true"}]]," "],["DIV",{"class":"field","data-field-name":"statictext11","data-field-type":"html","style":"display: none;"},["DIV",{"class":"fieldContent"},"\t",["SPAN",{"data-name":"statictext11","data-type":"html","class":"col-xs-11 col-sm-11 conditional fieldInput content html non-input ","data-content":"<p> <br></p><p><hr></p>\n<div><a href=\"https://www.angus.gov.uk/recycle/report_a_missed_bin\" target=\"_none\">Report a missed bin</a></div>\n<div> </div>\n\n<!---<div>\n<a href=\"{calendarURL}\" target=\"_blank\" rel=\"noopener\">View 12 month calendar for this address</a></div>--->","data-display-condition":"length({calenda