          ",["A",{"href":"https://forms.huntingdonshire.gov.uk/CONTACTUSFORM/launch?dept=Refuse","target":"_blank","class":"external-link"},"Request Help With This Calendar\n                ",["I",{"class":"ml-1 fas fa-external-link-alt added-external-link"}]],"\n        "],"\n        \n        ",["LI",{"id":"importantInfo","title":"Important Information"},"\n            ",["A",{"href":"#","data-bs-toggle":"modal","data-bs-target":"#importantInfoModal"},"Important Information"],"\n        "],"\n    "],"\n\n        "],"\n        \n    ",["DIV",{"id":"importantInfoModal","class":"modal fade"},"\n        ",["DIV",{"class":"modal-dialog"},"\n            ",["DIV",{"class":"modal-content"},"\n                ",["DIV",{"class":"modal-header d-flex justify-content-between"},"\n                    ",["H3",{"class":"modal-title h4"},"Important Information"],"\n                    ",["BUTTON",{"type":"button","class":"close text-dark btn-close","data-bs-dismiss":"modal","aria-label":"Close"}],"\n                "],"\n                ",["DIV",{"class":"modal-body"},"\n                    Thanks for visiting the bin calendar page.Please take note of the following important points:\n                                        ",["UL",{},"\n                                            ",["LI",{},"the earliest you can put out your waste bins/bags is 6pm the day before collection"],"\n                                            ",["LI",{},"wheeled bins should be returned to your property as soon as possible after they are emptied"],"\n                                            ",["LI",{},"do not put black or dark-coloured bin bags in your recycling bin - our collection crew will not be able to see if the contents can be recycled and may reject  your bin"],"\n                                            ",["LI",{},"take clothing and textiles to your ",["A",{"href":"/bins-waste/recycling-centres/#RecyclingBanks"}," local clothing bank"]," or favourite charity shop to be recycled.Please do not put any clothing in your recycling bins"],"\n                                            ",["LI",{},"if you have any queries, please",["A",{"href":"/bins-waste","title":"go to Huntingdonshire District Council's main web site"}," visit our website"]," where you can find lots of useful information on waste and recycling"],["LI",{},"note this site uses ",["A",{"href":"/council-democracy/our-website/cookies","title":"view our cookie policy"},"cookies"]," to store your address"]],"\n\n                    ",["P",{"class":"alert alert-warning"},"By clicking on Save and Close below, you give us consent to save a cookie to your browser to remember your choice(you can view this pop-up again by clicking on Important Information link on the homepage)."],"\n                "],"\n                ",["DIV",{"class":"modal-footer"},"\n                    ",["BUTTON",{"type":"button","class":"btn btn-primary","data-bs-dismiss":"modal","id":"saveAndCloseModal"},"Save and Close"],"\n                    ",["BUTTON",{"type":"button","class":"btn btn-default","data-bs-dismiss":"modal"},"Close"],"\n                "],"\n            "],"\n        "],"\n    "],"\n\n        ",["DIV",{"class":"col-12 col-md-9 order-0 order-md-1 body-text"},"\n    ",["H1",{},"Refuse Calendar"],"\n    ",["P",{"class":"border-bottom"},"To find your collection information we first need your address."],"\n    ",["P",{},"Please type your postcode into the box below and click search to find your address."],"\n\n    ",["DIV",{"class":"row g-3 needs-validation","novalidate":""},"\n        ",["DIV",{"class":"col-auto"},"\n            ",["LABEL",{"for":"postcode-search-input","class":"fw-bold"},"Enter postcode"],"\n        "],"\n        ",["DIV",{"class":"col-md-6"},"\n            ",["INPUT",{"__playwright_value_":"","id":"postcode-search-input","type":"text","class":"form-control","required":"","pattern":"([Gg][Ii][Rr] 0[Aa]{2})|((([A-Za-z][0-9]{1,2})|(([A-Za-z][A-Ha-hJ-Yj-y][0-9]{1,2})|(([A-Za-z][0-9][A-Za-z])|([A-