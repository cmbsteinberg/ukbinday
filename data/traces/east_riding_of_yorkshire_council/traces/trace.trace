e"},"            ",["DIV",{"id":"tabs-9670","class":"er-tabs "},"\n\n                ",["DIV",{"class":"header"},"\n      ",["DIV",{"class":"tabs"},"\n                              ",["A",{"href":"#","id":"cookie-settings","class":"tab  active","data-id":"1","title":"Switch to the Settings tab"},"\n              ",["DIV",{"class":"inner"},"\n                ",["DIV",{"class":"tab-text"},"\n                  ",["I",{"class":"fad fa-cog","aria-hidden":"true"}],"                  ",["DIV",{"class":"text"},"\n                    ",["SPAN",{"class":"title"},"Settings"],"\n                                      "],"\n                "],"\n              "],"\n            "],"\n                                        ",["A",{"href":"#","id":"cookie-statement","class":"tab  ","data-id":"2","title":"Switch to the Statement tab"},"\n              ",["DIV",{"class":"inner"},"\n                ",["DIV",{"class":"tab-text"},"\n                  ",["I",{"class":"fad fa-text","aria-hidden":"true"}],"                  ",["DIV",{"class":"text"},"\n                    ",["SPAN",{"class":"title"},"Statement"],"\n                                      "],"\n                "],"\n              "],"\n            "],"\n                        "],"\n    "],"\n    \n    ",["DIV",{"class":"content slick-initialized slick-slider"},"\n                        ",["DIV",{"class":"slick-list draggable","style":"height: 0px;"},["DIV",{"class":"slick-track","data-adaptiveheight":"true","style":"opacity: 1; width: 0px; transform: translate3d(0px, 0px, 0px);"},["DIV",{"class":"wrapper active slick-slide slick-current slick-active","data-id":"1","data-name":"Settings","data-slick-index":"0","aria-hidden":"false","style":"width: 0px;"},"\n              ",["DIV",{"class":"content "},["DIV",{"id":"er-cookie-placeholder-settings"},["DIV",{"class":"er-cookie-settings-intro er-cookie-padding"},"\n        ",["H2",{"class":"er-cookie-heading "},"Cookies are used on this site"],"\n        ",["P",{},"Cookies are files saved in the browser of your computer, tablet or phone, when you visit a website. These cookies store various information such as whether you are logged in, what pages you visit, user preferences, and can be linked to online marketing campaigns. More information is available in the ",["A",{"href":"/","class":"er-cookie-advanced-jump"},"advanced cookie settings"]," area below, as well as in the ",["A",{"href":"/","class":"er-cookie-information-link","aria-label":"Open Cookies Statement tab in cookie consent manager"},"Cookies Statement"],"."],"\n        ",["P",{},"You can change your cookies settings at any time by visiting the ",["A",{"href":"/cookies"},"Cookies"]," page or from the Cookies link in the footer."],"\n\n        ",["A",{"href":"#","class":"er-btn-primary accept er-cookie-trigger"},["I",{"aria-hidden":"true","class":"fa fa-check"}]," ",["SPAN",{},"Accept all cookies"]],"\n        ",["A",{"href":"#","class":"er-btn-warning refuse er-cookie-trigger"},["I",{"aria-hidden":"true","class":"fa fa-times"}]," ",["SPAN",{},"Reject all cookies"]],"\n      "]]],"              ",["DIV",{"class":"position","data-particle-id":"cookie-settings"},["DIV",{"id":"accordion-1366-particle","class":"g-content g-particle"},"            ",["DIV",{"id":"accordion-1366","class":"er-accordion "},"\n\n    \n    ",["DIV",{"class":"accordions"},"\n                \n      \n                                                        \n                        \n                \n        ",["DIV",{"class":"accordion closed meta-none  ","id":"advanced-cookie-settings","data-order-latest":"2507211134","data-order-atoz":"advancedsettings"},"\n          ",["A",{"class":"styled accordion-header closed","href":"#advanced-cookie-settings"},"\n            ",["SPAN",{"class":"title acc-icon-active"},["SPAN",{"class":"title-text"},["I",{"class":"fad fa-cogs","aria-hidden":"true"}],["P",{},"Advanced settings"]]],"\n            ",["SPAN",{"class":"open-close-text"}],"\n            ",["I",{"aria-hidden":"true","class":"arrow"}],"\n          "],"\n          ",["DIV",{"class":"content accordion-content","style":""},"\n            ",["DIV",{"class":"desc accordion-desc"},"\n              ",["DIV",{"id":"er-cookie-placeholder-advanced"},["DIV",{"class":"er-cookie-group"},"\n          ",["H3",{"class":" er-cookie-heading"},"Necessary cookies"],"\n          ",["P",{},"Necessary cookies are required to enable core functionality, such as logging in. These can only be turned off by changing your browser preferences."],"\n          ",["DIV",{"class":"er-cookie-group-checkbox necessary"}],"\n        "],"\n\n        ",["DIV",{"class":"er-cookie-group"},"\n          ",["H3",{"class":" er-cookie-heading"},"Statistics cookies"],"\n          ",["P",{},"Statistics cookies measure web usage, such as Google Analytics and Hotjar. These cookies store information anonymously, such as what pages are visiting, which links are clicked and length of time on page."],"\n          ",["DIV",{"class":"er-cookie-group-checkbox statistics"},"\n            ",["INPUT",{"__playwright_value_":"on","__playwright_checked_":"true","type":"checkbox","id":"er-cookie-check-statistics"}],"\n            ",["LABEL",{"for":"er-cookie-check-statistics","class":"er-cookie-check-btn "},"\n              Accept statistics cookies\n            "],"\n          "],"\n        "],"\n\n        ",["DIV",{"class":"er-cookie-group"},"\n          ",["H3",{"class":" er-cookie-heading"},"User settings cookies"],"\n          ",["P",{},"User settings cookies can store preferences such as default leisure centre location."],"\n          ",["DIV",{"class":"er-cookie-group-checkbox preferences"},"\n            ",["INPUT",{"__playwright_value_":"on","__playwright_checked_":"true","type":"checkbox","id":"er-cookie-check-preferences"}],"\n            ",["LABEL",{"for":"er-cookie-check-preferences","class":"er-cookie-check-btn "},"\n              Accept user settings cookies\n            "],"\n          "],"\n        "],"\n\n        ",["DIV",{"class":"er-cookie-group"},"\n          ",["H3",{"class":" er-cookie-heading"},"Marketing cookies"],"\n          ",["P",{},"Marketing cookies are used to track ad performance, such as Facebook posts, and provide data to third parties for targeted ads."],"\n          ",["DIV",{"class":"er-cookie-group-checkbox marketing"},"\n            ",["INPUT",{"__playwright_value_":"on","__playwright_checked_":"true","type":"checkbox","id":"er-cookie-check-marketing"}],"\n            ",["LABEL",{"for":"er-cookie-check-marketing","class":"er-cookie-check-btn "},"\n              Accept marketing cookies\n            "],"\n          "],"\n        "],"\n\n        ",["DIV",{"class":"er-cookie-group"},"\n          ",["A",{"href":"#","class":"er-btn-cta save er-cookie-trigger"},["I",{"aria-hidden":"true","class":"fa fa-save"}]," ",["SPAN",{},"Save advanced cookie settings"]],"\n        "]],"\n            "],"\n\n            \n            \n            \n          "],"\n\n          \n        "],"\n              "],"\n\n  "],"\n            "]],"\n              \n            "],["DIV",{"class":"wrapper slick-slide","data-id":"2","data-name":"Statement","data-slick-index":"1","aria-hidden":"true","style":"width: 0px;"},"\n              ",["DIV",{"class":"content "},["DIV",{"id":"er-cookie-placeholder-statement"},["DIV",{"class":"er-cookie-border-bottom er-cookie-padding er-cookie-bg"},"\n        ",["H2",{"class":""},"Cookies Statement"],"\n        ",["P",{},"Explains what information we will collect about you, what cookies are and how we use your information."],"\n      "],"\n\n      ",["DIV",{"class":"er-cookie-border-bottom er-cookie-padding er-cookie-bg-alt"},"\n        ",["H3",{"class":""},"What are cookies?"],"\n        ",["P",{},"A cookie is a small text file that resides on your computer. Cookies are used to remember your settings when you revisit a website and to identify how visitors navigate the site. Cookies provide valuable information to website owners to adapt and make changes to the site in order to improve the user experience."],"\n        ",["P",{},"Cookies are anonymous and contain no personal data. If you never register or leave personal information at a site, the only confirmation they give is that you are a returning visitor. The cookie will only contain information that you freely provide to a website."],"\n\n        ",["H4",{"class":""},"Types of cookies"],"\n        ",["P",{},"Cookies tend to be one, or a combination of, the following types:"],"\n\n        ",["H5",{"class":""},"Session cookies"],"\n        ",["P",{},"Files that allow a site to link the actions of a visitor during a single browser session. These might be used by an internet bank or webmail service. They are not stored long term and are considered \"less privacy intrusive\" than persistent cookies."],"\n\n        ",["H5",{"class":""},"Persistent cookies"],"\n        ",["P",{},"These remain on the user's device between sessions and allow one or several sites to remember details about the visitor. They may be used by marketers to target advertising or to avoid the user having to provide a password each visit."],"\n\n        ",["H5",{"class":""},"First and third-party cookies"],"\n        ",["P",{},"A cookie is classed as being first-party if it is set by the site being visited. It might be used to study how people navigate a site."],"\n        ",["P",{},"It is classed as third-party if it is issued by a different server to that of the domain being visited. It could be used to trigger a banner advert based on the visitor's viewing habits."],"\n        ",["P",{},"You can read more about cookies on the ",["A",{"target":"_blank","href":"https://www.allaboutcookies.org/"},"All About Cookies website (Opens in new tab or window)"]],"\n      "],"\n\n      ",["DIV",{"class":"er-cookie-border-bottom er-cookie-padding er-cookie-bg"},"\n        ",["H3",{"class":""},"Why do you use cookies?"],"\n        ",["P",{},"When people visit any of the East Riding of Yorkshire Council's websites we collect some standard internet usage information, and details of visitor behaviour patterns. This is done to learn how customers use our sites, to help us improve them."],"\n        ",["P",{},"We collect this data in a way which does not identify anyone. We do not make any attempt to find out the identities of those visiting our websites (unless you have previously approved us to do so). We will not associate any data gathered from these sites with any personally identifying information from any source."],"\n        ",["P",{},"If we want to collect personally identifiable information through our website, we will tell you beforehand. We will make it clear when we collect this information and will explain what we intend to do with."],"\n      "],"\n\n      ",["DIV",{"class":"er-cookie-border-bottom er-cookie-padding er-cookie-bg-alt"},"\n        ",["H3",{"class":""},"How can I control your cookies on my computer?"],"\n        ",["P",{},"You can control your cookie preferences for this site on the ",["A",{"href":"/","class":"er-cookie-settings-link","aria-label":"Open Settings tab in cookie consent manager"},"Settings"]," tab."],"\n\n        ",["H4",{"class":""},"More about controlling cookies"],"\n        ",["P",{},"Most web browsers also allow some control of most cookies through the browser settings. You can find out more about cookies, including how to see what cookies have been set and how to manage and delete them, on the ",["A",{"target":"_blank","href":"https://www.allaboutcookies.org/"},"All About Cookies website (Opens in new tab or window)"]],"\n\n      "],"\n\n      ",["DIV",{"class":"er-cookie-border-bottom er-cookie-padding er-cookie-bg"},"\n        ",["H3",{"class":""},"What cookies do you use on this website?"],"\n        ",["P",{},"The table below shows cookies which may be used on this site."],"\n\n        ",["TABLE",{"class":" stacktable small-only"},["CAPTION",{},"List of cookies"],["TBODY",{},["TR",{"class":"  "},["TH",{"clas