{"type":"frame-snapshot","snapshot":{"callId":"call@164","snapshotName":"before@call@164","pageId":"page@1a30a7e77d67e7662265c898e2a10f71","frameId":"frame@9582ad88eb635fadced7420c5291b568","frameUrl":"https://static.addtoany.com/menu/sm.25.html#type=core&event=load","doctype":"html","html":["HTML",{},["HEAD",{},["BASE",{"href":"https://static.addtoany.com/menu/sm.25.html#type=core&event=load"}],["TITLE",{},"A2A"],["META",{"name":"robots","content":"noindex"}]],["BODY",{"style":"background-color:transparent"}]],"viewport":{"width":1,"height":1},"timestamp":52217.099,"wallTime":1753084247841,"collectionTime":0.8000000002793968,"resourceOverrides":[],"isMainFrame":false}}
