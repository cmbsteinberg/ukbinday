ss":"localgov-alert-banner__dismiss"},"\n            ",["BUTTON",{"class":"localgov-alert-banner__close js-localgov-alert-banner__close","aria-label":"Hide alert: Earlier waste collections during hot weather","data-once":"allAlertBannerCloseButtons"},"Hide"],"\n          "],"\n        "],"\n          "],"   "]," "],"\n\n  "],"\n\n    "],"\n\n          "],"\n    \n  "],"\n\n\n\n\n\n",["DIV",{"class":"banner-placeholder","xmlns":"http://www.w3.org/1999/html"},"\n  ",["DIV",{"class":"lgd-container padding-horizontal"},"\n    ",["DIV",{"class":"lgd-row"},"\n      ",["DIV",{"class":"lgd-row__full"},"\n        ",["DIV",{"class":"banner-info"},"\n          ",["H1",{"class":"banner-title"}," Garden waste "],"\n\n                            "],"\n      "],"\n    "],"\n  "],"\n"],"\n",["DIV",{"class":"banner-breadcrumbs"},"\n  \n  \n  \n\n  ",["DIV",{"class":"lgd-region lgd-region--breadcrumb region region-breadcrumb"},"\n\n        ",["DIV",{"class":"lgd-container padding-horizontal"},"\n      ",["DIV",{"class":"lgd-row"},"\n        ",["DIV",{"class":"lgd-row__full"},"\n          \n          ",["DIV",{"class":"lgd-region__inner lgd-region__inner--breadcrumb"},"\n            ",["DIV",{"id":"block-havant-theme-localgov-breadcrumbs-base","class":"block block-system block-system-breadcrumb-block"},"\n  \n    \n      \n  \n\n  ",["NAV",{"class":"breadcrumbs","aria-labelledby":"system-breadcrumbs"},"\n    ",["H2",{"id":"system-breadcrumbs","class":"visually-hidden"},"Breadcrumbs"],"\n    ",["OL",{"class":"breadcrumbs__list"},"\n              ",["LI",{"class":"breadcrumbs__item"},"\n                      ",["A",{"class":"breadcrumbs__link","href":"/"},"Home"],"\n                    "],"\n              ",["LI",{"class":"breadcrumbs__item"},"\n                      ",["A",{"class":"breadcrumbs__link","href":"/bin-collections"},"Bin collections"],"\n                    "],"\n                "],"\n  "],"\n\n  "],"\n",["DIV",{"id":"block-emailsnippet","class":"block block-block-content block-block-content852311d5-06c0-48d0-b6b8-55e3eca5145c"},"\n  \n    \n      \n            ",["DIV",{"class":"clearfix field field--name-body field--type-text-with-summary field--label-hidden field__item"}],"\n      \n  "],"\n\n          "],"\n\n                  "],"\n      "],"\n    "],"\n    \n  "],"\n\n"],"\n\n",["A",{"id":"main-content","tabindex":"-1"}]," \n",["MAIN",{"class":"main","id":"main"},"\n  \n  ",["DIV",{"class":"lgd-container"},"\n    ",["DIV",{"class":"lgd-row"},"\n\n                        ",["ASIDE",{"class":"lgd-row__one-third sidebar sidebar--first"},"\n        \n  \n  \n      \n  \n\n  ",["DIV",{"class":"lgd-region lgd-region--sidebar-first region region-sidebar-first"},"\n\n    \n    ",["DIV",{"class":"lgd-region__inner lgd-region__inner--sidebar-first"},"\n      ",["DIV",{"id":"block-pagecontents","class":"block block-block-content block-block-content75ae0ffb-6a47-4dab-ad30-996006c536fb"},"\n  \n      ",["H2",{},"Page Contents"],"\n    \n      ",["DIV",{"id":"service-page-contents"},"\n    \n    "],"\n  "],"\n\n    "],"\n\n    \n  "],"\n\n      "],"\n      ",["DIV",{"class":"lgd-row__two-thirds"},"\n        ",["DIV",{"class":"padding-horizontal"},"\n          \n  \n  \n  \n\n  ",["DIV",{"class":"lgd-region lgd-region--content region region-content"},"\n\n    \n    ",["DIV",{"class":"lgd-region__inner lgd-region__inner--content"},"\n      ",["DIV",{"id":"block-havant-theme-localgov-mainpagecontent-base--2","class":"block block-system block-system-main-block"},"\n  \n    \n      \n\n\n\n\n\n\n\n",["ARTICLE",{"class":"localgov-services-page node node--type-localgov-services-page node--with-restricted-width node--promoted node--view-mode-full"},"\n\n  \n      \n\n    \n        ",["DIV",{"class":"node__restricted-width-section"},"\n      \n      ",["DIV",{"class":"localgov-services-page__content node__content"},"\n        ",["SPAN",{"class":"a2a_kit a2a_kit_size_32 addtoany_list","data-a2a-url":"https://www.havant.gov.uk/bin-collections/garden-waste","data-a2a-title":"Garden waste"},["A",{"class":"a2a_dd addtoany_share","href":"https://www.addtoany.com/share#url=https%3A%2F%2Fwww.havant.gov.uk%2Fbin-collections%2Fgarden-waste&title=Garden%20waste"}],["A",{"class":"a2a_button_facebook","alt":"Share on Facebook","aria-label":" opens in new window"}],["A",{"class":"a2a_button_twitter","alt":"Share on Twitter","aria-label":" opens in new window"}],["A",{"class":"a2a_button_whatsapp","alt":"Share on Whatsapp","aria-label":" opens in new window"}]],"\n\n      ",["DIV",{"class":"field field--name-field-main-content field--type-entity-reference-revisions field--label-hidden field__items"},"\n              ",["DIV",{"class":"field__item"},"  ",["DIV",{"class":"paragraph paragraph--type--localgov-text paragraph--view-mode--default"},"\n          \n            ",["DIV",{"class":"clearfix field field--name-localgov-text field--type-text-long field--label-hidden field__item"},["P",{},["STRONG",{},"Havant Borough Council has now moved to a new finance system so you will notice some changes to the way our payment screens look, there has also been a change to the web address on the payment link."]],"\n",["H2",{},"Sign-up to garden waste collections"],"\n",["P",{},["A",{"href":"https://waste.havant.gov.uk"},["STRONG",{},"Sign up now for the 2025/26 garden waste subscription using our customer portal"]],["STRONG",{},"."]],"\n",["P",{},"The portal allows residents to manage garden waste subscription online and view calendars for all scheduled waste collections. Residents can manage up to three properties from one customer account."],"\n",["P",{},["A",{"href":"https://www.havant.gov.uk/bin-collections/frequently-asked-questions-new-garden-waste-resident-portal"},"Frequently asked questions for the garden waste customer portal"],"."],"\n",["H2",{},"What is the garden waste collection service?"],"\n",["P",{},"It is an opt-in, chargeable service to have household garden waste collected from your home using a brown 240 litre or 140 litre wheeled bin. If you are a new subscriber your bin will be delivered to you when you subscribe to the service."],"\n",["P",{},"Collections are carried out every two weeks except during Christmas and New Year when the service is suspended, totalling 25 collections per year. Subscriptions commence either on the 1 April each year, or on the date of payment if this is later, and end on the 31 March in the succeeding year."],"\n",["H3",{},"How much does it cost?"],"\n",["UL",{},"\n",["LI",{},"1 x 240 litre wheeled bin (standard size): £85.00"],"\n",["LI",{},"1 x 140 litre wheeled bin (smaller size): £58.00"],"\n"],"\n",["P",{},"There is no charge to supply a bin. Terms and conditions can be viewed below:"],"\n",["UL",{},"\n",["LI",{},["A",{"href":"/media/9624/download?inline","data-entity-type":"media","data-entity-uuid":"914d811b-4941-483b-9f49-ddadac9a2f05","data-entity-substitution":"media_download_inline","title":"Havant Borough Council Garden Waste Collection Service Terms and Conditions 2024.docx"},"Garden Waste terms and conditions 2024"]," (word 22.2 kb)"],"\n",["LI",{},["A",{"href":"/media/10225/download?inline","data-entity-type":"media","data-entity-uuid":"180b0947-65e8-43fc-903a-f645bea44ff4","data-entity-substitution":"media_download_inline","title":"Garden waste terms and conditions 2025.pdf"},"Garden waste terms and conditions 2025"]," (pdf 96 kb)"],"\n"],"\n",["P",{},"We aim to process all subscriptions within 15 working days. Once we have received your payment we will send you a confirmation letter and a sticker for your bin. We will only collect from garden waste bins issued by Havant Borough Council with a valid subscription and sticker visible on the bin."],"\n",["P",{},"You may cancel the service at any time, however a refund will only be given if you cancel within 10 working days of making payment."],"\n",["H3",{},"Collection dates"],"\n",["P",{},"You can check your collection calendar below, on the ",["A",{"href":"https://waste.havant.gov.uk"},"new customer portal"]," or by scanning the QR code on your permit sticker."],"\n",["UL",{},"\n",["LI",{},["A",{"href":"/media/10226/download?inline","data-entity-type":"media","data-entity-uuid":"e843c730-9184-4ec3-aa2e-d62e9ddd0f6e","data-entity-substitution":"media_download_inline","title":"Garden waste calendar 2025-26.pdf"},"Garden waste calendar 2025-26"]," (pdf 386 kb)"],"\n"],"\n",["H2",{},"Frequently asked questions"],"\n",["H3",{},"My bin wasn’t collected, what should I do?"],"\n",["P",{},"Your bin should be presented by 7am on the collection day and accessible by our crews. We will only empty it if:"],"\n",["UL",{},"\n",["LI",{},"There is a valid subscription at the property"],"\n",["LI",{},"There is a permit sticker on the handle side of the bin"],"\n",["LI",{},"It only contains household garden waste and is not contaminated by other items"],"\n",["LI",{},"Our crews can safely access and move the bin"],"\n"],"\n",["P",{},"If your bin has been missed, please ",["A",{"href":"https://waste.havant.gov.uk"},"report this to us using the customer portal"],". Missed bins must be reported by 4pm on the next working day after your scheduled collection."],"\n",["H3",{},"I’ve let my licence lapse what do I do?"],"\n",["P",{},"If you do not have a current subscription then your bin will not be emptied, please sign up as a new subscriber via the customer portal and we will issue you with a subscription permit sticker within 15 working days."],"\n",["H3",{},"Can I have more than one garden waste bin?"],"\n",["P",{},"Yes, you can have a maximum of three 240 litre bins and a maximum of two 140 litre bins at a property."],"\n",["H3",{},"Where will my garden waste bin be delivered?"],"\n",["P",{},"Your garden waste bin will be delivered to the boundary to your property. Please be advised we cannot take special location requests for delivery."],"\n",["H3",{},"How long will it take for my bin to be delivered?"],"\n",["P",{},"If you are a new garden waste subscriber, you will need to subscribe by the 15 March 2025 to ensure your bin is delivered in time for the service to commence on the 1 April 2025. If you subscribe after this date, please allow up to 15 working days for your bin to be delivered."],"\n",["H3",{},"If I sign up do I own the bin?"],"\n",["P",{},"No, the charge is for the collection of the waste, not the purchase of the new wheeled bin. The bin remains the property of the council."],"\n",["H3",{},"Can I have an assisted collection for the garden waste collection service?"],"\n",["P",{},"If you sign up to the new service and you already have an authorised assisted collection, where the bin is pulled out and returned for you, this will continue."],"\n",["H3",{},"My garden waste bin is damaged or broken – how do I receive a new one?"],"\n",["P",{},"The wheeled bin remains the property of Havant Borough Council and a charge may be applied for replacement and exchange of bins."],"\n",["P",{},"What happens if I move house?"],"\n",["P",{},"If the subscriber moves property within the Borough, the subscription can be transferred to the new property. It is the householder’s responsibility to move the bin(s) to the new property. A subscription cannot be terminated within the year, collections will continue until the end of the current subscription period. If the current subscriber leaves the property, then the new occupier must apply for a new subscription for subsequent years. The subscriber must contact customer services to advise of the change of address on 023 9244 6019."],"\n",["H2",{},"About the bin permit stickers"],"\n",["P",{},"How should I put the permit sticker on the bin?"],"\n",["P",{},"Please place the permit sticker on the handle side of the bin with your house name or number clearly displayed so we can identify that you are a garden waste subscriber. There are clear instructions on the reverse of the permit sticker to advise you how to attach it to your bin."],"\n",["P",{},["STRONG",{},"What happens if I haven’t received my garden waste permit sticker?"]],"\n",["P",{},"Please allow 15 working days for your garden waste permit sticker to arrive if you subscribed on 1 April or after.  If after 15 working days you still haven't received your permit sticker, please contact customer services on 023 9244 6019."],"\n",["P",{},["STRONG",{},"Why do I need a subscription permit sticker?"]],"\n",["P",{},"This helps to ensure that we only collect bins with a valid subscription. The first line of your address is printed on the sticker, helping to ensure that your bin is not lost or swapped with neighbours. We will only collect from garden waste bins issued by Havant Borough Council with a with a valid subscription and permit sticker visible on the bin."],"\n",["H2",{},"What I can and can’t recycle"],"\n",["H3",{},"What can I recycle in my garden waste bin?"],"\n",["P",{},"Any biodegradable waste from gardening activities at the property, including grass cuttings, hedge cuttings, small branches, leaves, weeds, real Christmas trees (cut down to fit within the bin), prunings, waste fruit and vegetables grown directly within the property’s garden."],"\n",["H3",{},"What can’t I recycle in my garden waste bin?"],"\n",["P",{},"Soil, concrete, rubble, treated wood, vegetable peelings, food scraps, coal, ash, animal waste, commercial waste, general household waste and any other waste which is not household garden waste. Waste must not be put in plastic, biodegradable or compostable sacks. The bin will not be collected if it contains incorrect items. Please remove these items and re-present the bin on your next scheduled collection day."],"\n",["H3",{},"What happens to my garden waste recycling?"],"\n",["P",{},"The garden waste we collect is taken to composting sites across Hampshire and is processed into a range of composts and soil conditioners, which are used in local parks and formal gardens. Composting Garden waste helps to tackle climate change and improves local soils, making it one of the easiest ways to play your part in improving our environment."],"\n"],"\n      \n      "],"\n"],"\n          "],"\n  \n\n        \n    "],"\n\n        \n    \n        "],"\n    \n    "],"\n\n  "],"\n\n    "],"\n\n    \n  "],"\n\n        "],"\n      "],"\n      \n      \n      \n            \n    "],"\n  "],"\n\n  "],"\n\n",["FOOTER",{"class":"lgd-footer"},"\n\n        ",["DIV",{"class":"lgd-footer__pre-footer"},"\n    ",["DIV",{"class":"lgd-container"},"\n      ",["DIV",{"class":"lgd-row"},"\n                  \n  \n  \n\n  ",["DIV",{"class":"lgd-region lgd-region--footer-first region region-footer-first"},"\n\n        ",["DIV",{"class":"lgd-container padding-horizontal"},"\n      ",["DIV",{"class":"lgd-row"},"\n        ",["DIV",{"class":"lgd-row__full"},"\n          \n          ",["DIV",{"class":"lgd-region__inner lgd-region__inner--footer-first"},"\n            \n  \n\n",["NAV",{"aria-labelledby":"block-havant-theme-footer-menu","id":"block-havant-theme-footer","class":"block block-menu navigation navigation--footer"},"\n            \n  ",["H2",{"class":"visually-hidden","id":"block-havant-theme-footer-menu"},"Footer"],"\n  \n\n        \n      \n        \n    \n            ",["UL",{"class":"menu menu--footer"},"\n                    ",["LI",{"class":"menu-item"},"\n        ",["A",{"href":"https://public.govdelivery.com/accounts/UKHAVANT/subscriber/new"},"Sign-up for our newsletters and service updates."],"\n              "],"\n        "],"\n  \n\n\n  "],"\n",["DIV",{"id":"block-havant-theme-footersocialicons","class":"block block-block-content block-block-content6c3c7e7d-e558-4b51-9c95-28765ba6b953"},"\n  \n    \n      \n            ",["DIV",{"class":"clearfix field field--name-body field--type-text-with-summary field--label-hidden field__item"},["DIV",{"class":"fontawesome-icons","style":"font-size: 50px;"},"\n",["UL",{},"\n",["LI",{},"\n",["DIV",{"class":"fontawesome-icon"},["A",{"href":"https://www.facebook.com/HavantBorough","aria-label":"Havant Borough Council 