{"type":"before","callId":"call@49","startTime":37298.999,"class":"Frame","method":"evaluateExpression","params":{"expression":"() => {\n    const greenBinText = document.querySelector('[ref=\"e308\"]').textContent;\n    const brownBinText = document.querySelector('[ref=\"e309\"]').textContent;\n    const blueBinText = document.querySelector('[ref=\"e310\"]').textContent;\n    const orangeBinText = document.querySelector('[ref=\"e311\"]').textContent;\n\n    const extractInfo = (text) => {\n        const dateMatch = text.match(/\\: (.*?)\\s*\\(/);\n        const frequencyMatch = text.match(/\\((.*?)\\)/);\n        return {\n            next_pickup_day: dateMatch ? dateMatch[1].trim() : null,\n            frequency: frequencyMatch ? frequencyMatch[1].trim() : null\n        };\n    };\n\n    return {\n        greenBin: extractInfo(greenBinText),\n        brownBin: extractInfo(brownBinText),\n        blueBin: extractInfo(blueBinText),\n        orangeBin: extractInfo(orangeBinText)\n    };\n}","isFunction":true,"arg":{"value":{"v":"undefined"},"handles":[]}},"pageId":"page@5224fe4c537d6273273f491d152c41ec","beforeSnapshot":"before@call@49"}
