{"type":"before","callId":"call@47","startTime":29827.784,"class":"Frame","method":"evaluateExpression","params":{"expression":"() => {\n    const greenBin = document.evaluate(\"//strong[contains(text(), 'Green bin (general waste)')]/following-sibling::text()[1]\", document, null, XPathResult.STRING_TYPE, null).stringValue.trim();\n    const brownBin = document.evaluate(\"//strong[contains(text(), 'Brown bin (garden waste)')]/following-sibling::text()[1]\", document, null, XPathResult.STRING_TYPE, null).stringValue.trim();\n    const blueBin = document.evaluate(\"//strong[contains(text(), 'Blue bin (recycling)')]/following-sibling::text()[1]\", document, null, XPathResult.STRING_TYPE, null).stringValue.trim();\n    const orangeBin = document.evaluate(\"//strong[contains(text(), 'Orange bin (food waste)')]/following-sibling::text()[1]\", document, null, XPathResult.STRING_TYPE, null).stringValue.trim();\n\n    const greenBinFreq = document.evaluate(\"//strong[contains(text(), 'Green bin (general waste)')]/following-sibling::text()[2]\", document, null, XPathResult.STRING_TYPE, null).stringValue.trim();\n    const brownBinFreq = document.evaluate(\"//strong[contains(text(), 'Brown bin (garden waste)')]/following-sibling::text()[2]\", document, null, XPathResult.STRING_TYPE, null).stringValue.trim();\n    const blueBinFreq = document.evaluate(\"//strong[contains(text(), 'Blue bin (recycling)')]/following-sibling::text()[2]\", document, null, XPathResult.STRING_TYPE, null).stringValue.trim();\n    const orangeBinFreq = document.evaluate(\"//strong[contains(text(), 'Orange bin (food waste)')]/following-sibling::text()[2]\", document, null, XPathResult.STRING_TYPE, null).stringValue.trim();\n\n    return {\n        greenBin: greenBin,\n        brownBin: brownBin,\n        blueBin: blueBin,\n        orangeBin: orangeBin,\n        greenBinFreq: greenBinFreq,\n        brownBinFreq: brownBinFreq,\n        blueBinFreq: blueBinFreq,\n        orangeBinFreq: orangeBinFreq\n    };\n}","isFunction":true,"arg":{"value":{"v":"undefined"},"handles":[]}},"pageId":"page@5224fe4c537d6273273f491d152c41ec","beforeSnapshot":"before@call@47"}
