{"type":"before","callId":"call@55","startTime":55307.415,"class":"Frame","method":"evaluateExpression","params":{"expression":"() => {\n    const results = {\n        general_waste: null,\n        garden_waste: null,\n        recycling: null,\n        food_waste: null\n    };\n\n    const binTypeMap = {\n        'General waste wheeled bin': { color: 'grey', type: 'general_waste' },\n        'Brown garden waste wheeled bin': { color: 'brown', type: 'garden_waste' },\n        'Blue kerbside box - paper': { color: 'blue', type: 'recycling' },\n        'Green kerbside box - cans, glass and aluminium foil': { color: 'green', type: 'recycling' },\n        'Plastic and cardboard wheeled bin': { color: 'blue', type: 'recycling' }\n    };\n\n    const dateHeadings = document.querySelectorAll('h4');\n\n    dateHeadings.forEach(heading => {\n        const nextPickupDay = heading.textContent.trim().replace('(*)', '').trim();\n        let currentElement = heading.nextElementSibling;\n\n        while (currentElement && currentElement.tagName !== 'H4') {\n            if (currentElement.tagName === 'UL') {\n                const listItems = currentElement.querySelectorAll('li');\n                listItems.forEach(item => {\n                    const binText = item.querySelector('a')?.textContent.trim();\n                    if (binText) {\n                        for (const [key, value] of Object.entries(binTypeMap)) {\n                            if (binText.includes(key) && !results[value.type]) {\n                                results[value.type] = {\n                                    bin_colour: value.color,\n                                    frequency: 'Fortnightly',\n                                    next_pickup_day: nextPickupDay\n                                };\n                            }\n                        }\n                    }\n                });\n            }\n            currentElement = currentElement.nextElementSibling;\n        }\n    });\n\n    return results;\n}","isFunction":true,"arg":{"value":{"v":"undefined"},"handles":[]}},"pageId":"page@5224fe4c537d6273273f491d152c41ec","beforeSnapshot":"before@call@55"}
