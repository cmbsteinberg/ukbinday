{"type":"before","callId":"call@53","startTime":48940.35,"class":"Frame","method":"evaluateExpression","params":{"expression":"() => {\n    const results = {};\n\n    const binTypes = {\n        'General waste wheeled bin': { color: 'grey', type: 'general_waste' },\n        'Brown garden waste wheeled bin': { color: 'brown', type: 'garden_waste' },\n        'Blue kerbside box - paper': { color: 'blue', type: 'recycling' },\n        'Green kerbside box - cans, glass and aluminium foil': { color: 'green', type: 'recycling' },\n        'Plastic and cardboard wheeled bin': { color: 'blue', type: 'recycling' }\n    };\n\n    for (const [binName, binInfo] of Object.entries(binTypes)) {\n        const links = Array.from(document.querySelectorAll(`a[href*=\"bins-boxes-and-bags/\"]`)).filter(link => link.textContent.includes(binName));\n        if (links.length > 0) {\n            const firstLink = links[0];\n            let currentElement = firstLink;\n            let nextPickupDay = null;\n\n            while (currentElement && currentElement.tagName !== 'BODY') {\n                if (currentElement.tagName === 'H4') {\n                    nextPickupDay = currentElement.textContent.trim();\n                    break;\n                }\n                currentElement = currentElement.parentElement;\n            }\n\n            if (nextPickupDay) {\n                // Check for asterisk indicating bank holiday\n                const isBankHoliday = nextPickupDay.includes(\"(*)\");\n                if (isBankHoliday) {\n                    nextPickupDay = nextPickupDay.replace(\"(*)\", \"\").trim();\n                }\n\n                // Determine frequency (assuming fortnightly based on typical patterns and available data)\n                const frequency = \"Fortnightly\";\n\n                // Store the first found collection for each bin type\n                if (!results[binInfo.type]) {\n                    results[binInfo.type] = {\n                        bin_colour: binInfo.color,\n                        frequency: frequency,\n                        next_pickup_day: nextPickupDay\n                    };\n                }\n            }\n        }\n    }\n\n    return results;\n}","isFunction":true,"arg":{"value":{"v":"undefined"},"handles":[]}},"pageId":"page@5224fe4c537d6273273f491d152c41ec","beforeSnapshot":"before@call@53"}
