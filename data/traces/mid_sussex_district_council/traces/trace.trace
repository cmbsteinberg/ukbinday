section-header grid-padding-x","id":"waste-recycling-header"},"\n                    ",["DIV",{"class":"cell medium-9 large-8 show-for-medium"},"\n                        ",["NAV",{"aria-label":"You are here:"},"\n                                ",["UL",{"class":"breadcrumbs"},"\n                                        ",["LI",{},["A",{"href":"/"},"Home"]],"\n                                        ",["LI",{},["A",{"href":"/waste-recycling/"},"Waste & Recycling"]],"\n                                    ",["LI",{},["SPAN",{"class":"show-for-sr"},"Current: "],"Household Rubbish"],"\n                                "],"\n                        "],"\n                    "],"\n                    ",["DIV",{"class":"cell medium-3 large-4 show-for-medium"},"\n                        ",["DIV",{"class":"header-section-logo"}],"\n                    "],"\n                    ",["DIV",{"class":"cell show-for-small-only"},"\n                        ",["DIV",{"class":"breadcrumb-bg"}],"\n                        ",["NAV",{"aria-label":"Go up a level","class":"breadcrumbs breadcrumb-small"},["A",{"href":"/waste-recycling/"},"Back to Waste & Recycling"]],"\n                    "],"\n                "],"\n            "],"\n        "],"\n\n\n        ",["DIV",{"id":"bg-page-content"},"\n            ",["DIV",{"class":"waste-recycling-page"},"\n    ",["DIV",{"class":"grid-container","id":"page-content","role":"main","aria-labelledby":"page-title"},"\n        ",["DIV",{"class":"grid-x grid-padding-x","id":"content-container"},"\n            ",["DIV",{"class":"cell"},"\n                \n\n    ",["DIV",{"id":"page-title-content","class":"grid-x grid-padding-x"},"\n        ",["DIV",{"class":"cell","role":"banner","aria-label":"page title"},"\n            ",["H1",{"id":"page-title"},"Household Rubbish"],"\n        "],"\n    "],"\n\n",["DIV",{"class":"grid-x grid-padding-x"},"\n        ",["DIV",{"class":"cell small-12"},"\n            \n                ",["DIV",{"class":"content-row ","id":"abed612b-f78e-c0fd-e723-bf85d0891961"},"\n                            ",["DIV",{"class":"grid-x grid-padding-x"},"\n                                            ",["DIV",{"class":"cell content-text"},"\n                                                \n\n\n",["P",{},"Your black bin is for non-recyclable household rubbish only (those items that cannot be recycled or composted). Please do not overfill your rubbish bin and keep the lid closed at all times."],"\n",["P",{},"It is commonly used for:"],"\n",["UL",{},"\n",["LI",{},"Nappies"],"\n",["LI",{},"Cooked food waste"],"\n",["LI",{},"Pet waste"],"\n",["LI",{},"Non-recyclable packaging"],"\n"],"\n",["DIV",{},"Please ",["STRONG",{},"DO NOT "],"put the following items in your household rubbish bin. These should be disposed of responsibly using the links below or download our ",["A",{"data-udi":"umb://media/3648e46b7cce42f19fced1574f39b744","href":"/media/7498/a-guide-to-using-your-mid-sussex-rubbish-bin.pdf","title":"A guide to using your Mid Sussex rubbish bin (1)"},"handy information leaflet"," (3 MB, PDF) ",["SPAN",{"aria-hidden":"true","class":"fas fa-file-pdf"}]]," for further information. "],"\n",["UL",{},"\n",["LI",{},["STRONG",{},"Hazardous waste"]," (these items can put human health or the environment at risk). This includes items such as asbestos, batteries, chemicals, paints, solvents and fluorescent bulbs. Please take these items to your nearest ",["A",{"data-udi":"umb://document/f78a31e6c50e4da5af2736ed590903ab","href":"/waste-recycling/recycling-centres/","title":"Recycling Centres (local tips)"},"Recycling Centre"],". "],"\n",["LI",{},["STRONG",{},"Medical waste"]," such as syringes, stoma bags, epi-pens and dressings. These require a ",["A",{"data-udi":"umb://document/9b653d692a61416ea96419c58ede88fb","href":"/waste-recycling/clinical-waste/","title":"Clinical Waste"},"special clinical waste collection"],"."],"\n",["LI",{},["STRONG",{},"DIY waste"]," including paint tins, tiles, bricks and rubble can be taken to your nearest ",["A",{"data-udi":"umb://document/f78a31e6c50e4da5af2736ed590903ab","href":"/waste-recycling/recycling-centres/","title":"Recycling Centres (local tips)"},"Recycling Centre"],". "],"\n",["LI",{},["STRONG",{},"Textiles, clothes and shoes"]," can be taken to a local charity shop, bring bank or one of your local ",["A",{"data-udi":"umb://document/f78a31e6c50e4da5af2736ed590903ab","href":"/waste-recycling/recycling-centres/","title":"Recycling Centres (local tips)"},"Recycling Centres"],". You can find details of your nearest site using the ",["SPAN",{},["A",{"rel":"noopener","href":"https://www.recyclenow.com/local-recycling","target":"_blank"},"Recycling Locator"," ",["SPAN",{"aria-hidden":"true","title":"leave this site","class":"fas fa-external-link-alt"}]]]],"\n",["LI",{},["STRONG",{},"Electrical items  - "],"smaller items such as kettles, toasters, electric toothbrushes, and games consoles can be recycled using our ",["A",{"data-udi":"umb://document/c96caa7de3254a758e6ed6cc16bf0788","href":"/waste-recycling/small-electrical-collections/","title":"Small Electrical Collections"},"kerbside collection service"],". ",["SPAN",{},"Larger items such as TV’s "],["SPAN",{},"should be"]," taken for recycling at your local ",["A",{"data-udi":"umb://document/f78a31e6c50e4da5af2736ed590903ab","href":"/waste-recycling/recycling-centres/","title":"Recycling Centres (local tips)"},"Recycling Centre"]," ",["SPAN",{}," "],["SPAN",{},"or find other recycling options using the ",["A",{"rel":"noopener","href":"https://www.recycleyourelectricals.org.uk/","target":"_blank"},"Recycle Your Electricals locator."," ",["SPAN",{"aria-hidden":"true","title":"leave this site","class":"fas fa-external-link-alt"}]]]],"\n",["LI",{},["STRONG",{},"Garden waste"]," can be taken to a local ",["A",{"data-udi":"umb://document/f78a31e6c50e4da5af2736ed590903ab","href":"/waste-recycling/recycling-centres/","title":"Recycling Centres (local tips)"},"Recycling Centre"]," or subscribe to our kerbside ",["A",{"data-udi":"umb://document/023238180a634fccac66dfaee1db0bfb","href":"/waste-recycling/garden-waste/","title":"Garden Waste"},["SPAN",{},"garden waste collection service."]]],"\n",["LI",{},["STRONG",{},"Business waste"]," is not currently collected by Mid Sussex District Council. If you have waste as a result of your business you will need to dispose of it separately. You can find local registered waste carriers using the search facility on the ",["SPAN",{},["A",{"rel":"noopener","href":"https://environment.data.gov.uk/public-register/view/search-waste-carriers-brokers","target":"_blank"},"public register"," ",["SPAN",{"aria-hidden":"true","title":"leave this site","class":"fas fa-external-link-alt"}]]]," maintained by the Environment Agency who regulate waste carriers through a licensing system."],"\n",["LI",{},["STRONG",{},"Bulky waste"]," (those household items you would typically take with you if moving home) can be disposed of using our Bulky Waste Collection Service for a small fee. Visit our ",["SPAN",{},["A",{"href":"https://www.midsussex.gov.uk/waste-recycling/bulky-household-waste/"},"bulky waste collection page"]]," for further details."],"\n"],"\n",["P",{},"Download our ",["A",{"data-udi":"umb://media/3648e46b7cce42f19fced1574f39b744","href":"/media/7498/a-guide-to-using-your-mid-sussex-rubbish-bin.pdf","title":"A guide to using your Mid Sussex rubbish bin (1)"},"handy information leaflet"," (3 MB, PDF) ",["SPAN",{"aria-hidden":"true","class":"fas fa-file-pdf"}]]," for further information and also visit our ",["SPAN",{},["A",{"href":"http://www.midsussex.gov.uk/waste-recycling/community-recycling"},"community recycling page"]]," for alternative local recycling options for many household items."],"\n\n\n                                            "],"\n                            "],"\n                "],"\n\n\n        "],"\n"],"\n            "],"\n        "],"\n            ",["DIV",{"class":"grid-x grid-padding-x","id":"updated-row"}