field--type-text-with-summary field--label-hidden clearfix"},"\n              \n    "],"\n\n","\n\n",["DIV",{"class":"add-info-container field field--name-field-add-content-info- field--type-entity-reference-revisions field--label-hidden clearfix"},"\n                ",["DIV",{"class":"paragraph paragraph--type--text-editor paragraph--view-mode--default"},"\n          \n",["DIV",{"class":"field field--name-field-text field--type-text-long field--label-hidden clearfix"},"\n              ",["P",{},"Use this form to find out your next household collection date."],"\n\n",["P",{},"Your garden waste bin collection will only take place on the date shown if you have ",["A",{"href":"/node/6155"},"signed up for your collections"]],"\n\n",["P",{"class":"text-editor-cta","id":"title-0"},["A",{"href":"https://account.barnet.gov.uk/Forms/Home/Redirector/Index/?id=6a2ac067-3322-46e5-96e4-16c0c214454a&mod=OA&casetype=BAR&formname=BNTCOLDATE","class":"external-link"},"Find your household collection day"]],"\n\n",["P",{},"Place your bins at the boundary of your property by 6am on your collection day."],"\n\n",["H2",{},"Collections during severe weather"],"\n\n",["P",{},"In severe weather there may be some delay to your collection. We will try to complete all collections wherever possible."],"\n\n",["P",{},"We will ",["A",{"href":"/node/5163"},"provide updates"]," on this website and on our ",["A",{"href":"https://en-gb.facebook.com/BarnetCouncil/","class":"external-link"},"Facebook",["SPAN",{"class":"visually-hidden"}," External link"]]," and ",["A",{"href":"https://twitter.com/BarnetCouncil","class":"external-link"},"Twitter",["SPAN",{"class":"visually-hidden"}," External link"]]," feeds."],"\n    "],"\n\n      "],"\n\n    "],"\n\n  "],"\n\n  \n"],"\n\n  "],"\n\n  "],"\n\n              "],"\n            ",["ASIDE",{"aria-label":"Sidebar","class":"column-third"},"\n                      ",["DIV",{"id":"block-obbarnet-relatedpages--2"},"\n  \n    \n          ",["DIV",{"class":"sidebar