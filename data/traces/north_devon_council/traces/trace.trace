k__card-bubble{display:flex;flex-direction:column;overflow:hidden;border-radius:12px;border-width:1px;padding:0;border-color:#5252802e;border-style:solid;max-width:100%;box-sizing:border-box;font-size:14px;width:-moz-max-content;width:max-content}.livesdk__dark .livesdk__card-bubble{border-color:#444b53}.livesdk__text-bubble{max-width:316px;white-space:pre-wrap;word-wrap:break-word;border-radius:12px;padding:10px 12px;font-size:14px;line-height:20px;box-sizing:border-box;position:relative;overflow:hidden}.livesdk__chat-sdk-window-fullscreen .livesdk__text-bubble{max-width:calc(100vw - 96px)}.livesdk__chat-container{display:flex;height:100%;width:100%;flex-direction:column;font-family:ui-sans-serif,system-ui,-apple-system,Segoe UI,Roboto,Ubuntu,Cantarell,Noto Sans,sans-serif,BlinkMacSystemFont,Segoe UI,Roboto,Helvetica Neue,Arial,Noto Sans,sans-serif,\"Apple Color Emoji\",\"Segoe UI Emoji\",Segoe UI Symbol,\"Noto Color Emoji\";overflow:hidden}.livesdk__dark .livesdk__chat-container{background:#131619}.livesdk__chat-container__body{box-sizing:border-box;flex:1 1 0%;position:relative;overflow:hidden}.livesdk__chat-container__bottom-border{border-radius:8px;border:1px solid #DFE3E8;margin:16px}.livesdk__dark .livesdk__chat-container__bottom-border{border:1px solid #444B53}[dir=rtl] .livesdk__svg-icon-scaleX{transform:scaleX(-1)}.livesdk__svg-icon-margin-right{margin-right:4px}[dir=rtl] .livesdk__svg-icon-margin-right{margin-right:0;margin-left:4px}.livesdk__editor-container{display:flex;min-height:70px;border-top-width:1px;border-top-color:#5252802e;border-top-style:solid;flex-direction:column}.livesdk__editor-container-hide-border{border:medium none currentcolor;border:initial}.livesdk__dark .livesdk__editor-container{border-top-color:#444b53}.livesdk__editor-container .ql-editor.ql-blank:before{color:#6e7680}.livesdk__dark .livesdk__editor-container .ql-editor.ql-blank:before{color:#98a0a9}.livesdk__editor{box-sizing:border-box;display:flex;flex:1 1 0%;align-items:cen