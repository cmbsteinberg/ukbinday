lass":"gi-breadcrumb__link","href":"https://www.spelthorne.gov.uk/"},"Home"],"\t\t\t\t\t"],"\n\t\t\t\t\t",["LI",{"class":"gi-breadcrumb__item"},"\n",["A",{"class":"gi-breadcrumb__link","href":"https://www.spelthorne.gov.uk/article/16339/Residents"},"Residents"],"\t\t\t\t\t"],"\n\t\t\t\t\t",["LI",{"class":"gi-breadcrumb__item"},"\n",["A",{"class":"gi-breadcrumb__link","href":"https://www.spelthorne.gov.uk/rubbishwasterecycling"},"Rubbish and recycling"],"\t\t\t\t\t"],"\n\t\t\t\t\t",["LI",{"class":"gi-breadcrumb__item"},"\n",["A",{"class":"gi-breadcrumb__link","href":"https://www.spelthorne.gov.uk/kerbsidecollections"},"Kerbside collection services"],"\t\t\t\t\t"],"\n\t\t"],"\n\t"],"\n\n\t\t\t\t\t\t"],"\n\t\t\t\t\t"],"\n\t\t\t"],"\n\t\t\t\t",["MAIN",{"id":"maincontent","class":"maincontent"},"\n\n\n\t\t\t\t\t\n\t\t\t\t\t",["DIV",{"class":"container"},"\n\n\n\t",["DIV",{"class":"a-heading a-heading--default"},"\n\t\t",["H1",{"class":"a-heading__title"},"Rubbish collections"],"\n\t"],"\n\t\t\t\t\t\t",["DIV",{"class":"maincolumns"},"\n\t\t\t\t\t\t\t",["DIV",{"class":"maincontent__left"},"\n\n\n\n\n\n\n\t",["DIV",{"class":"a-body a-body--default"},"\n\n\n",["P",{},"Your rubbish is collected every two weeks. On your collection day, put your dark green bin kerbside with the handles facing the kerbside by 6am with the lid firmly closed. Please move it back onto your property as soon as possible after emptying."],["P",{},["A",{"class":"a-body__link","href":"https://spelthorne-self.achieveservice.com/service/Waste_Collections","target":"_self"},"Find your collection day or report a missed bin"]],["H2",{},"What can go in my bin?"],["P",{},"All household waste that cannot be recycled, composted or reused can be put in your rubbish bin."],["P",{},"You ",["STRONG",{},"cannot "],"put the following items in your rubbish bin:"],["UL",{"style":"margin-left: 40px"},["LI",{},["A",{"class":"a-body__link","href":"https://www.spelthorne.gov.uk/article/18505/Business-waste-and-recycling"},"business waste and recycling"]],["LI",{},"furniture (can be collected via the ",["A",{"class":"a-body__link","href":"https://www.spelthorne.gov.uk/bulkywaste"},"bulky waste collection"]," service)"],["LI",{},"wood"],["LI",{},"garden waste (we offer a ",["A",{"class":"a-body__link","href":"https://www.spelthorne.gov.uk/gardenwaste"},"garden waste collection"]," service)"],["LI",{},"mattresses or carpets"],["LI",{},"non-combustible construction material"],["LI",{},"any part of a motor vehicle"],["LI",{},"liquid wastes - including oil sludge's etc"],["LI",{},"paints, cleaning fluids and other hazardous waste"],["LI",{},"electrical products (we offer a ",["A",{"class":"a-body__link","href":"https://www.spelthorne.gov.uk/smallelectrical"},"small electrical recycling service"]," or larger appliances can be taken to selected ",["A",{"class":"a-body__link","href":"https://www.spelthorne.gov.uk/recyclingbanks"},"Recycling banks"],")"],["LI",{},"hazardous waste (asbestos and household chemicals)"]],["P",{},"All of the above materials can be taken to the ",["A",{"class":"a-body__link","href":"https://www.surreycc.gov.uk/waste-and-recycling/community-recycling-centres/shepperton","target":"_self"},"Community Recycling Centre"],"."],["H2",{},"Excess rubbish"],["P",{},"This will not be removed. Please wait until your next collection or take it to Community Recycling Centre."],["H2",{},"Missed collections"],["P",{},"If you think your bin has been accidentally missed, contact us within one working day by completing the online form above or contact Customer Services. Either we will return to collect your bin or you will need to wait until your next scheduled collection date."],["H2",{},"Order a new bin"],["P",{},"To request an additional or replacement please complete the online form."],["P",{},["SPAN",{"class":"calltoaction__link"},"\n",["A",{"class":"calltoaction__link calltoaction__link--Green","href":"https://spelthorne-self.achieveservice.com/service/Bins___order_form","title":"Bins - order form"},"Order a new bin form"],"\t\t"]],["H2",{},"Reducing bin smells"],["P",{},"Smells come from rotting rubbish. If possible:"],["UL",{},["LI",{},"separate food waste in to your caddy so it is collected weekly or in a food digester"],["LI",{},"store your wheelie bin out of direct sunlight"],["LI",{},"keep the lid closed at all times"],["LI",{},"wash inside your bin with disinfectant or bleach regularly to keep it fresh"],["LI",{},"put solids from disposable nappies down the toilet and then double bag (try using real cloth nappies)"],["LI",{},"hang insecticide strips inside your bin to help control flies should they get in"],["LI",{},"squeeze air out of bags before placing them in your bin to slow the decomposing process"]],["P",{},"If you do get maggots, once the bin has been emptied, pour boiling water over flies and maggots to kill them and leave water in the bin to cool before tipping it out. Clean the bin out with disinfectant or bleach as this will help to deter flies in the future."],"\n\t"],"\n\n\t\t\t\t\t\t\t\t \n\n\n\n",["DIV",{"class":"a-share"},"\n\t",["P",{"class":"a-share__label"},"Share this page"],"\n\t",["A",{"class":"a-share__link","target":"_blank","href":"https://www.facebook.com/sharer/sharer.php?u=https://www.spelthorne.gov.uk/rubbish"},"\n\t\t",["IMG",{"__playwright_current_src__":"https://www.spelthorne.gov.uk/images/facebook.png","class":"a-share__image","src":"images/facebook.png","alt":"Share on Facebook"}],"\n\t"],"\n\t",["A",{"class":"a-share__link","target":"_blank","href":"https://twitter.com/share?url=https://www.spelthorne.gov.uk/rubbish"},"\n\t\t",["IMG",{"__playwright_current_src__":"https://www.spelthorne.gov.uk/images/twitter.png","class":"a-share__image","src":"images/twitter.png","alt":"Share on Twitter"}],"\n\t"],"\n\t",["A",{"class":"a-share__link","href":"mailto:?subject=Rubbish%20collections&body=I%20thought%20you%20might%20be%20interested%20in%20this%20web%20page%20-%20https://www.spelthorne.gov.uk/rubbish"}