der: 1px solid #b1b4b6;\n    color: #0b0c0c;\n    background: #f3f2f1;\n}\n\n.warning-text {\n    position: relative;\n   /* margin-bottom: 20px;*/\n    padding: 10px 0;\n}\n\n.warning-text__icon {\n    -webkit-font-smoothing: antialiased;\n    -moz-osx-font-smoothing: grayscale;\n    font-weight: 700 !important;\n    -webkit-box-sizing: border-box;\n    box-sizing: border-box;\n    display: inline-block;\n    position: absolute;\n    left: 0;\n    min-width: 35px;\n    min-height: 35px;\n    margin-top: -7px;\n    border: 3px solid #0b0c0c;\n    border-radius: 50%;\n    color: #fff;\n    background: #0b0c0c;\n    font-size: 25px !important;\n    line-height: 29px;\n    text-align: center;\n    -webkit-user-select: none;\n    -moz-user-select: none;\n    -ms-user-select: none;\n    user-select: none;\n}\n\n\n.warning-text__text {\n    -webkit-font-smoothing: antialiased;\n    -moz-osx-font-smoothing: grayscale;\n    font-weight: 700 !important;\n    font-size: 16px;\n    font-size: 1rem;\n    line-height: 1.5em;\n    color: #0b0c0c;\n    display: block;\n    padding-left: 45px;\n/*padding-top:10px;*/\n}\n\n.warning-text__assistive {\n    position: absolute !important;\n    width: 1px !important;\n    height: 1px !important;\n    margin: 0 !important;\n    padding: 0 !important;\n    overflow: hidden !important;\n    clip: rect(0 0 0 0) !important;\n    -webkit-clip-path: inset(50%) !important;\n    clip-path: inset(50%) !important;\n    border: 0 !important;\n    white-space: nowrap !important;\n\n}\n\n</style>\n\n\n<div class=\"info-box\">\n<div class=\"warning-text\">\n<span class=\"warning-text__icon\" aria-hidden=\"true\">!</span>\n<strong class=\"warning-text__text\">\n<span class=\"warning-text__assistive\">Warning</span>\nThe service starts this week on the 12th of February for collection week 1 and the 19th of February for collection week 2. <br><br>\nPlease note that {checkGwWeek}\n</strong>\n</div>\n</div>\nnote display condition: {GWStartDate} isnt '' and {GWEndDate} isnt ''","data-display-condition":"1=2"}],["DIV",{"class":"screen-reader-error","aria-live":"polite","aria-atomic":"true"}]]," "],["DIV",{"class":"field","data-field-name":"html4","data-field-type":"html","style":"display: none;"},["DIV",{"class":"fieldContent"},"\t",["SPAN",{"data-name":"html4","data-type":"html","class":"col-xs-11 col-sm-11 conditional fieldInput content html non-input ","data-content":"<style>\n    .bt_container {\n        font-size: 16px;\n        box-shadow: 2px 2px 4px lightgrey;\n        padding: 15px;\n    }\n    \n    .bt_info {\n        margin: 15px 0;\n       \n    }\n    \n    .bt_info span {\n        margin-left: 10px;\n        padding: 5px;\n        font-size: 11px;\n        font-weight: bold;\n        color: #fff;\n        background: gray;\n    }\n    \n</style>\n\n<div class=\"bt_container\">\n        <div class=\"bt_info\">Your last collection was : <strong>{GwPrevFormatted}</strong>\n    <div class=\"bt_info\">Your next collection is : <strong>{GwNextFormatted}</strong></div>\n\n</div>","data-display-condition":"{GwPrevCollection} isnt '' and {GwNextCollection} isnt '' and {GWCheck} is 'true'"}],["DIV",{"class":"screen-reader-error","aria-live":"polite","aria-atomic":"true"}]]," "],["DIV",{"class":"field","data-field-name":"html10","data-field-type":"html","style":"display: none;"},["DIV",{"class":"fieldContent"},"\t",["SPAN",{"data-name":"html10","data-type":"html","class":"col-xs-11 col-sm-11 conditional fieldInput content html non-input ","data-content":"<style>\n/* Information box*/\n\n.info-box {\n    -webkit-font-smoothing: antialiased;\n    -moz-osx-font-smoothing: grayscale;\n    font-weight: 700;\n    font-size: 17px !important;\n    font-size: .875rem;\n    line-height: 1.5em;\n    padding-top: 25px;\n    padding: 15px;\n    border: 1px solid #b1b4b6;\n    color: #0b0c0c;\n    background: #f3f2f1;\n}\n\n.warning-text {\n    position: relative;\n   /* margin-bottom: 20px;*/\n    padding: 10px 0;\n}\n\n.warnin