em gi-sitenav__item--lvl3"},"\n",["A",{"href":"https://www.newforest.gov.uk/article/1069/Contracts-register","class":"gi-sitenav__link gi-sitenav__link--lvl3"},"Contracts register"],"\n"],"\n",["LI",{"class":"gi-sitenav__item gi-sitenav__item--lvl3"},"\n",["A",{"href":"https://www.newforest.gov.uk/article/1070/Procurement-strategy","class":"gi-sitenav__link gi-sitenav__link--lvl3"},"Procurement strategy"],"\n"],"\n",["LI",{"class":"gi-sitenav__item gi-sitenav__item--lvl3"},"\n",["A",{"href":"https://www.newforest.gov.uk/standardtermsandconditions","class":"gi-sitenav__link gi-sitenav__link--lvl3"},"Procurement standard terms and conditions"],"\n"],"\n"],"\n"],"\n"],"\n",["LI",{"class":"gi-sitenav__item gi-sitenav__item--lvl2"},"\n",["A",{"href":"https://www.newforest.gov.uk/article/1293/Health-and-safety-for-businesses","class":"gi-sitenav__link gi-sitenav__link--lvl2"},"Health and safety for businesses"],"\n",["DIV",{"class":"gi-sitenav gi-sitenav--lvl3","aria-label":"Health and safety for businesses","role":"region"},"\n",["UL",{"class":"gi-sitenav__list gi-sitenav__list--lvl3"},"\n",["LI",{"class":"gi-sitenav__item gi-sitenav__item--lvl3"},"\n",["A",{"href":"https://www.newforest.gov.uk/article/1289/Complaints-about-health-and-safety-at-work","class":"gi-sitenav__link gi-sitenav__link--lvl3"},"Complaints about health and safety at work"],"\n"],"\n",["LI",{"class":"gi-sitenav__item gi-sitenav__item--lvl3"},"\n",["A",{"href":"https://www.newforest.gov.uk/article/1487/Health-and-safety-inspections-advice-for-businesses","class":"gi-sitenav__link gi-sitenav__link--lvl3"},"Health and safety inspections - advice for businesses"],"\n"],"\n",["LI",{"class":"gi-sitenav__item gi-sitenav__item--lvl3"},"\n",["A",{"href":"https://www.newforest.gov.uk/events","class":"gi-sitenav__link gi-sitenav__link--lvl3"},"Tell us about a public event"],"\n"],"\n",["LI",{"class":"gi-sitenav__item gi-sitenav__item--lvl3"},"\n",["A",{"href":"https://www.newforest.gov.uk/article/1453/Smokefre