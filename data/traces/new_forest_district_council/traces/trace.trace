its of inclusive economic growth and investment"],"\n"],"\n",["LI",{"class":"gi-sitenav__item gi-sitenav__item--lvl3"},"\n",["A",{"href":"https://www.newforest.gov.uk/article/3662/2-Protecting-our-climate-coast-and-natural-world","class":"gi-sitenav__link gi-sitenav__link--lvl3"},"2: Protecting our climate, coast, and natural world"],"\n"],"\n",["LI",{"class":"gi-sitenav__item gi-sitenav__item--lvl3"},"\n",["A",{"href":"https://www.newforest.gov.uk/article/3665/2-Supporting-our-high-quality-business-base-and-economic-centres-to-thrive-and-grow","class":"gi-sitenav__link gi-sitenav__link--lvl3"},"2: Supporting our high-quality business base and economic centres to thrive and grow "],"\n"],"\n",["LI",{"class":"gi-sitenav__item gi-sitenav__item--lvl3"},"\n",["A",{"href":"https://www.newforest.gov.uk/article/3572/People-priorities","class":"gi-sitenav__link gi-sitenav__link--lvl3"},"People priorities"],"\n"],"\n"],"\n"],"\n"],"\n",["LI",{"class":"gi-sitenav__item gi-sitenav__item--lvl2"},"\n",["A",{"href":"https://www.newforest.gov.uk/article/1087/Council-budgets-and-spending","class":"gi-sitenav__link gi-sitenav__link--lvl2"},"Council budgets and spending"],"\n"],"\n",["LI",{"class":"gi-sitenav__item gi-sitenav__item--lvl2 gi-sitenav__item--viewall"},"\n",["A",{"href":"https://www.newforest.gov.uk/yourcouncil","class":"gi-sitenav__link gi-sitenav__link--lvl2"},"View all Council sections"],"\n"],"\n"],"\n"],"\n"],"\n"],"\n"],"\n","\n\n\n\n\n\n\t",["DIV",{"class":"header__nav-search"},"\n\t\t",["FORM",{"id":"headersearch","class":"gi-sitesearch gi-sitesearch--header","action":"https://www.newforest.gov.uk/search","method":"get","role":"search","data-collapsible":"true","data-suppress-closebtn":"true","data-focus-open":"true","data-collapsed":"true"},"\n  ",["DIV",{"class":"gi-sitesearch__container"},"\n    ",["DIV",{"class":"gi-sitesearch__closetoggle"},"\n      ",["BUTTON",{"type":"button","class":"btn btn--close btn--icon-only gi-sitesearch__button gi-sitesearch__button--close"},"\n        ",["SPAN",{"class":"btn__text gi-sitesearch__buttontext accessibility"},"Close"],"\n      "],"\n    "],"\n    ",["DIV",{"class":"gi-sitesearch__searchfield"},"\n      ",["LABEL",{"id":"headersearch_input_label","class":"gi-sitesearch__label accessibility","for":"headersearch_input"},"Search newforest.gov.uk"],"\n\n\n\n",["DIV",{"class":"search-suggestion-wrapper"},"\n\t",["DIV",{"id":"headersearch_input_container"},"\n\t\t",["INPUT",{"__playwright_value_":"","data-dataurl":"https://www.newforest.gov.uk/search","id":"headersearch_input","class":"searchform__inputtxt searchform__inputtxt--sitesearch","placeholder":"Search newforest.gov.uk","name":"q","value":"","type":"text","maxlength":"100","autocomplete":"off","role":"combobox","aria-expanded":"false","aria-controls":"headersearch_input_suggestions","aria-haspopup":"listbox","aria-autocomplete":"list","aria-labelledby":"headersearch_input_label"}],"\n\t"],"\n\t",["UL",{"id":"headersearch_input_suggestions","class":"search-suggestion","role":"listbox"}],"\n"],"\n","\n    "],"\n    ",["DIV",{"class":"gi-sitesearch__searchtoggle"},"\n      ",["BUTTON",{"type":"submit","class":"btn btn--search btn--icon-only gi-sitesearch__button gi-sitesearch__button--search"},"\n        ",["SPAN",{"class":"btn__text gi-sitesearch__buttontext accessibility"},"Find"],"\n      "],"\n    "],"\n  "],"\n"],"\n","\n\n\t"],"\n\t\t"],"\n\t"],"\n"],"\n\n\n\t\t\t\t\t",["DIV",{"class":"breadcrumb"},"\n\t\t\t\t\t\t",["DIV",{"class":"container"},"\n\t",["NAV",{"class":"gi-breadcrumb","aria-label":"page breadcrumb"},"\n\t\t",["OL",{"class":"gi-breadcrumb__list"},"\n\t\t\t\t\t",["LI",{"class":"gi-breadcrumb__item"},"\n",["A",{"class":"gi-breadcrumb__link","href":"https://www.newforest.gov.uk/"},"New Forest District Council website"],"\t\t\t\t\t"],"\n\t\t\t\t\t",["LI",{"class":"gi-breadcrumb__item"},"\n",["A",{"class":"gi-breadcrumb__link","href":"https://www.newforest.gov.uk/article/932/Residents"},"Residents"],"\t\t\t\t\t"],"\n\t\t\t\t\t",["LI",{"class":"gi-breadcrumb__item"},"\n",["A",{"class":"gi-breadcrumb__link","href":"https://www.newforest.gov.uk/recyclingandrubbish"},"Recycling and rubbish"],"\t\t\t\t\t"],"\n\t\t"],"\n\t"],"\n\n\t\t\t\t\t\t"],"\n\t\t\t\t\t"],"\n\t\t\t"],"\n\t\t\t\t",["MAIN",{"id":"maincontent","class":"maincontent"},"\n\n\n\t\t\t\t\t\n\t\t\t\t\t",["DIV",{"class":"container"},"\n\n\n\t",["DIV",{"class":"a-heading a-heading--default"},"\n\t\t",["H1",{"class":"a-heading__title"},"Household rubbish"],"\n\t"],"\n\t\t\t\t\t\t",["DIV",{"class":"maincolumns"},"\n\t\t\t\t\t\t\t",["DIV",{"class":"maincontent__left"},"\n\n\n\n\n\n\n\t",["DIV",{"class":"a-body a-body--default"},"\n\n\n",["P",{},"We are introducing a new waste collection service  from June 2025 to March 2026. It will be introduced in 3 phases, with different areas starting at different times. "],["P",{},"Households will get wheelie bins for alternate week recycling and rubbish collections, and food waste caddies for weekly food waste collections."],["P",{},"We'll be delivering wheelie bins and food waste caddies before new waste collections start for each phase:  "],["UL",{},["LI",{},"phase 1 area - was April to June 2025 "],["LI",{},"phase 2 area - August to October 2025 "],["LI",{},"phase 3 area - January to March 2026 "]],["P",{},"A more specific bin delivery timeframe will be shared closer to the time."],["P",{},["A",{"href":"https://www.newforest.gov.uk/findmyphase"},"Check which phase you are in"]],["DIV",{"class":"jumplist"},"\n        \n        ",["P",{"class":"jumplist__heading"},"On this page:"],"\n        \n        ",["DIV",{"id":"jumplistcontainer","class":"jumplist__listcontainer"},["UL",{"class":"jumplist__linklist"},["LI",{"class":"jumplist__listitem"},["A",{"href":"https://www.newforest.gov.uk/rubbish#h20","class":"jumplist__link"},"New collections information"]],["LI",{"class":"jumplist__listitem"},["A",{"href":"https://www.newforest.gov.uk/rubbish#h21","class":"jumplist__link"},"Waste collections for phase 2 and 3 households"]],["LI",{"class":"jumplist__listitem"},["A",{"href":"https://www.newforest.gov.uk/rubbish#h22","class":"jumplist__link"},"What we collect"]],["LI",{"class":"jumplist__listitem"},["A",{"href":"https://www.newforest.gov.uk/rubbish#h23","class":"jumplist__link"},"How we collect"]],["LI",{"class":"jumplist__listitem"},["A",{"href":"https://www.newforest.gov.uk/rubbish#h24","class":"jumplist__link"},"What to do on collection day"]],["LI",{"class":"jumplist__listitem"},["A",{"href":"https://www.newforest.gov.uk/rubbish#h25","class":"jumplist__link"},"Waste colouring sheet"]]]],"\n    "],["H2",{"id":"h20"},"New collections information"],["P",{},"If you are in phase 1 for waste and recycling collections, you can ",["A",{"class":"a-body__link","href":"https://www.newforest.gov.uk/article/3869/New-rubbish-collections"},"find out more about your waste collections"],"."],["H2",{"id":"h21"},"Waste collections for phase 2 and 3 households"],["P",{},"We collect general household waste from all households in the New Forest every week. Your rubbish is collected in black plastic sacks, or from your communal general rubbish bin if you live in flats."],["P",{},"Black rubbish sacks are for general rubbish that cannot be ",["A",{"class":"a-body__link","href":"https://www.newforest.gov.uk/recycling"},"collected for recycling"],"."],["P",{},"You can check your household rubbish collection day by using our online postcode lookup below."],["P",{"class":"a-ctalink"},["A",{"href":"https://forms.newforest.gov.uk/ufs/ufsmain?formid=FIND_MY_COLLECTION&ebz=1_1586362925470&ebd=0&ebz=1_1586362925470","target":"_blank"},"Find your collection day"]],["H2",{"id":"h22"},["A",{"id":"what"}],"What we collect"],["P",{},"You can use your black rubbish sack for most general household waste that you cannot put in your ",["A",{"class":"a-body__link","href":"https://www.newforest.gov.uk/recycling"},"clear recycling sack"],"."],["P",{},["STRONG",{},"Do not"]," use black rubbish sacks to dispose of:"],["UL",{},["LI",{},"garden waste"],["LI",{},"electrical items"],["LI",{},"batteries"],["LI",{},"hazardous waste (such as asbestos)"],["LI",{},"bulky household items"],["LI",{},"knives"],["LI",{},"tins of paint (unless completely empty).             "]],["P",{},"You can recycle garden waste though our  or you can ",["A",{"class":"a-body__link","href":"https://www.newforest.gov.uk/article/982/Take-rubbish-to-the-tip"},"take it to the tip"],"."],["P",{},"Batteries can be recycled at many retail outlets. To check where you can recycle batteries near you, ",["A",{"href":"https://www.recycleyourelectricals.org.uk/electrical-recycling-near-me/"},"visit the Recycle Your Electricals website (recycleyourelectricals.org.uk)"],"."],["P",{},"The other items listed above can also be ",["A",{"class":"a-body__link","href":"https://www.newforest.gov.uk/article/982/Take-rubbish-to-the-tip"},"taken to the tip"],"."],["P",{},"You can ",["A",{"class":"a-body__link","href":"https://www.newforest.gov.uk/glass"},"recycle glass bottles and jars"]," through your black box or communal bin, or take it to a ",["A",{"class":"a-body__link","href":"https://www.newforest.gov.uk/recyclingbanks"},"community recycling bank"],"."],["H3",{},"Sharp items"],["P",{},"Broken glass and ceramics should be wrapped securely before being placed in your black sack."],["P",{"class":"gi-info gi-info--muted"},"Medical syringes should never be placed in the black refuse sack, even if you believe they are securely wrapped or contained. The council provides a free ",["A",{"class":"a-body__link","href":"https://www.newforest.gov.uk/article/983/Healthcare-waste-collection"},"healthcare waste collection service"]," for this type of waste."],["H2",{"id":"h23"},["A",{"id":"how"}],"How we collect"],["P",{},"Your general household waste is collected in black plastic sacks, or from your communal general waste bin if you live in flats."],["P",{},"We deliver 26 black plastic sacks to each property every six months."],["P",{},"For operational reasons, the exact dates for sack delivery may vary. You can ",["A",{"class":"a-body__link","href":"https://www.newforest.gov.uk/article/3216/Black-and-clear-sack-delivery"},"check when to expect your sack delivery"],"."],["P",{},"You can purchase extra sacks at your local ",["A",{"class":"a-body__link","href":"https://www.newforest.gov.uk/article/1163/Information-offices"},"Information Office"],".  "],["P",{},"You can also purchase non-council black sacks from a supermarket or other retailer."],["H2",{"id":"h24"},["A",{"id":"day"}],"What to do on collection day"],["P",{},"Rubbish sacks are collected every week, on the same day as your clear recycling sacks."],["P",{},"Fill your black sack with general household waste and tie it securely, to prevent waste from spilling from sacks and attracting pests."],["P",{},"Put out your sacks at the edge of your property no earlier than 6pm the day before, and by 6am on your collection day."],["P",{},"You can help your collection team by ensuring that parked cars are not restricting access to your road."],["H3",{},"Wildlife and black sacks"],["P",{},"If your property is in an area accessible to commoner's livestock, keep your sacks inside your gate or cattle grid to help prevent harm to grazing animals and wildlife."],["P",{},"If you are concerned about animal strikes, you can put your black sacks in a traditional dustbin at the boundary of your property. Our collection team will remove the sacks and replace the lids. We cannot empty a wheelie bin. If you have a wheelie bin, please remove your rubbish sacks before your collection is due."],["P",{},"Your rubbish is your responsibility before it has been collected. If animals split the sacks, it is your responsibility to clear it up. If our collection team spills the contents of the sack, they will clear it up."],["H3",{},"Missed collection"],["P",{},"If your black sacks were not collected, you can contact us to ",["A",{"class":"a-body__link","href":"https://www.newforest.gov.uk/MissedCollections"},"report a missed collection"],"."],["H3",{},"Bank holidays"],["P",{},"Black sack collections will still take place over the Easter and summer bank holidays."],["P",{},"Some changes are made to black sack collection days at Christmas and New Year. These will be published on the ",["A",{"href":"https://forms.newforest.gov.uk/ufs/ufsmain?formid=FIND_MY_COLLECTION&ebz=1_1586362925470&ebd=0&ebz=1_1586362925470"},"find my collection day"]," page at the beginning of December. Details will also be printed on your black sacks, and published in the local press and on social media."],["H3",{},"If you need help"],["P",{},"Residents who are unable to put their sacks out at the edge of their property due to a disability, illness or injury can contact us to request an ",["A",{"class":"a-body__link","href":"https://www.newforest.gov.uk/assistedcollections"},"assisted collection"],"."],["P",{},"For updates on assisted collections and other waste collections, follow us on ",["A",{"href":"https://twitter.com/newforestdc","target":"_self"},"Twitter"],", ",["A",{"href":"https://www.facebook.com/newforestgov","target":"_self"},"Facebook"],", and ",["A",{"href":"https://nextdoor.co.uk/","target":"_self"},"NextDoor"],"."],["P",{},"You can also ",["A",{"class":"a-body__link","href":"https://www.newforest.gov.uk/emails"},"sign up to receive our update emails."],"."],["H2",{"id":"h25"},"Waste colouring sheet"],["P",{},"Download our waste truck colouring in sheet:"],["P",{},["A",{"href":"https://www.newforest.gov.uk/media/1517/Waste-colouring-sheet/pdf/refuse_truck_colouring_sheet.pdf?m=1627404226993","class":"media-link media-link--pdf"},["SPAN",{"class":"media-link__text"},"Waste colouring sheet "],["SPAN",{"class":"media-link__bracket"},"("],["SPAN",{"class":"media-link__type"},"PDF, "],["SPAN",{"class":"media-link__filesize"},"512 KB"],["SPAN",{"class":"media-link__bracket"},")"]]],"\n\t"],"\n\n\t\t\t\t\t\t\t\t \n\n\n\n\t",["DIV",{"class":"a-share"},"\n\t\t",["P",{"class":"a-share__label"},"Share this page"],"\n\t\t",["A",{"class":"a-share__link","target":"_blank","href":"https://www.facebook.com/sharer/sharer.php?u=https://www.newforest.gov.uk/rubbish"},"\n\t\t\t",["IMG",{"__playwright_current_src__":"https://www.newforest.gov.uk/images/social/facebook.png","class":"a-share__image","src":"images/social/facebook.png","alt":"Share on Facebook"}],"\n\t\t"],"\n\t\t",["A",{"class":"a-share__link","target":"_blank","href":"https://twitter.com/share?url=https://www.newforest.gov.uk/rubbish"},"\n\t\t\t",["IMG",{"__playwright_current_src__":"https://www.newforest.gov.uk/images/social/twitter.png","class":"a-share__image","src":"images/social/twitter.png","alt":"Share on Twitter"}],"\n\t\t"],"\n\t\t",["A",{"class":"a-share__link","href":"mailto:?subject=Household%20rubbish&body=I%20thought%20you%20might%20be%20interested%20in%20this%20web%20page%20-%20https://www.newforest.gov.uk/rubbish"},"\n\t\t\t",["IMG",{"__playwright_current_src__":"https://www.newforest.gov.uk/images/social/email.png","class":"a-share__image","src":"images/social/email.png","alt":"Share by email"}],"\n\t\t"],"\n\t\t",["P",{"class":"a-share__label","id":"share-print-label","style":"display: initial;"},"Print"],"\n\t\t",["A",{"class":"a-share__link","id":"share-print-link","href":"javascript:window.print();","style":"display: initial;"},"\n\t\t\t",["IMG",{"__playwright_current_src__":"https://www.newforest.gov.uk/images/social/print.png","class":"a-share__image","src":"images/social/print.png","alt":"Print this page"}],"\n\t\t"],"\n\t\t","\n\t"],"\n\t\t\t\t\t\t\t"],"\n\t\t\t\t\t\t"],"\n\t\t\t\t\t"],"\n\t\t\t\t"],"\n\n\n\n\n",["FOOTER",{"class":"footer footer--site","aria-label":"footer section"},"\n\t",["DIV",{"class":"container"},"\n\t\t",["DIV",{"class":"footer__left"},"\n\n\n",["DIV",{"class":"footer__logos"},"\n"],"\n\n\n",["DIV",{"class":"footer__socialmedia"},"\n"],"\n\t\t"],"\n\t\t",["DIV",{"class":"footer__right"},"\n\n\n",[