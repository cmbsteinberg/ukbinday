ceholder_p_lt_ctl02_BinCollectionSearch_txtBinSearch","id":"p_lt_ctl07_pageplaceholder_p_lt_ctl02_BinCollectionSearch_lblBinSearch"},"Find your bin collection schedule & more"],"\n\t\t\t",["DIV",{"class":"entry-field"},"\n\t\t\t\t",["INPUT",{"__playwright_value_":"","name":"p$lt$ctl07$pageplaceholder$p$lt$ctl02$BinCollectionSearch$txtBinSearch","type":"text","id":"p_lt_ctl07_pageplaceholder_p_lt_ctl02_BinCollectionSearch_txtBinSearch","placeholder":"Search street name"}],"\n\t\t\t\t",["DIV",{"class":"btn-holder"},"\n\t\t\t\t\t",["INPUT",{"__playwright_value_":"Go","type":"submit","name":"p$lt$ctl07$pageplaceholder$p$lt$ctl02$BinCollectionSearch$btnBinSearch","value":"Go","id":"p_lt_ctl07_pageplaceholder_p_lt_ctl02_BinCollectionSearch_btnBinSearch"}],"\n\t\t\t\t"],"\n\t\t\t"],"\n\t\t\n\t"],"\n\t\t\n\t\t\n\t\t\n\t\n"],"\n\n"],"\n"],"\n  "],"\n\n"],"\n","\n",["DIV",{"id":"notificationBar","class":"notification-bar"},"\n    ",["DIV",{"class":"grid-container"},"\n        ",["DIV",{"class":"grid-x grid-padding-x"},"\n            ",["DIV",{"class":"cell large-8 medium-6 small-12 align-self-middle"},"\n                ",["UL",{"class":"notif-items"},"\n                    ",["LI",{"class":"divider"},["SPAN",{"class":"notif-icon"}],["STRONG",{},"Important Notice"]],"\n                    ",["LI",{},"For Bryson Collection Schedule Please Click Here"],"\n                "],"\n            "],"\n            ",["DIV",{"class":"cell large-4 medium-6 small-12 text-right align-self-middle"},"\n                ",["A",{"class":"btn-view","href":"https://www.brysonrecycling.org/northern-ireland/kerbside-collections/collection-day/","title":"Bryson Recycling Website","target":"_blank"},"Bryson Recycling Website"],"\n                ",["BUTTON",{"id":"notifClose","class":"btn-close","type":"button","aria-label":"Close"},"Close"],"\n            "],"\n        "],"\n    "],"\n"],["DIV",{"class":"wrapper-white wysiwyg"},"\n\t\t\t",["DIV",{"class":"grid-container"},"\n",["DIV",{"class":"grid-x grid-padding-x"},"\n  ",["DIV",{"class":"cell medium-12"},"\n  ",["H2",{},"Bin Collection FAQs"],"\n",["P"],["UL",{"class":"sz-accordion"},"\n",["LI",{},"\n    ",["A",{"href":"#","class":"title","name":"what-day-is-my-bin-due-to-be-collected?--how-do-i-get-a-collection-calendar?"},"What day is my bin due to be collected?  How do I get a collection calendar?"],"\n    ",["DIV",{"class":"content wysiwyg","style":"display: none;"},"\n        ",["P",{},"You can check what day your bin is due to be collected by using our ",["A",{"href":"/binchecker/"},"bin checker"]],"\n\n    "],"\n"],["LI",{},"\n    ",["A",{"href":"#","class":"title","name":"where-should-i-leave-my-bin?"},"Where should I leave my bin?"],"\n    ",["DIV",{"class":"content wysiwyg","style":"display: none;"},"\n        Your bin should be left at the edge of your property or at the designated collection point, with the handle turned out.\n\n    "],"\n"],["LI",{},"\n    ",["A",{"href":"#","class":"title","name":"what-should-i-do-with-my-bin-when-there-is-high-wind?-"},"What should I do with my bin when there is high wind? "],"\n    ",["DIV",{"class":"content wysiwyg","style":"display: none;"},"\n        ",["P",{},"When the weather is forecast for wind please leave your bin in a secure place and avoid leaving your bin kerbside overnight. "],"\n\n",["P",{},"Bin collections start from 7am so we would advise to leave your bin out as close to this time as possible. "],"\n\n    "],"\n"],["LI",{},"\n    ",["A",{"href":"#","class":"title","name":"what-time-will-my-bin-be-emptied?"},"What time will my bin be emptied?"],"\n    ",["DIV",{"class":"content wysiwyg","style":"display: none;"},"\n        Your bin collection can take place at any time from 7am onwards.  As collection times can vary, it is important that always leave your bin out for 7am to ensure that it is emptied.  We do not have sufficient resources to go back for a bin which was not out on time.\n    "],"\n"],["LI",{},"\n    ",["A",{"href":"#","class":"title","name":"will-extra-bags-be-lifted?"},"Will extra bags be lifted?"],"\n    ",["DIV",{"class":"content wysiwyg","style":"display: none;"},"\n        Due to health and safety concerns, only waste which is within the main body of the bin can be collected.  Therefore additional bags cannot be accepted.\n    "],"\n"],["LI",{},"\n    ",["A",{"href":"#","class":"title","name":"can-i-put-my-bin-out-with-the-lid-raised?"},"Can I put my bin out with the lid raised?"],"\n    ",["DIV",{"class":"content wysiwyg","style":"display: none;"},"\n        Due to health and safety concerns, if your bin lid is raised it will not be emptied.  You will be asked to ensure that the lid is fully closed when your bin is presented on your next collection day.  We do not have sufficient resources to go back for a bin which was rejected due to a raised lid.\n    "],"\n"],["LI",{},"\n    ",["A",{"href":"#","class":"title","name":"what-type-of-waste-should-i-put-in-the-bin?"},"What type of waste should I put in the bin?"],"\n    ",["DIV",{"class":"content wysiwyg","style":"display: none;"},"\n        Please see our what can be ",["A",{"href":"/recycling/"},"recycled page"],".\n    "],"\n"],["LI",{},"\n    ",["A",{"href":"#","class":"title","name":"what-happens-if-i-present-the-wrong-size-of-bin-or-two-bins?"},"What happens if I present the wrong size of bin or two bins?"],"\n    ",["DIV",{"class":"content wysiwyg","style":"display: none;"},"\n        If a larger bin or multiple bins are presented without prior approval from Council they will not be emptied.\n    "],"\n"],["LI",{},"\n    ",["A",{"href":"#","class":"title","name":"what-happens-if-my-bin-appears-to-have-been-missed?"},"What happens if my bin appears to have been missed?"],"\n    ",["DIV",{"class":"content wysiwyg","style":"display: none;"},"\n        ",["P",{},"We will always try to empty your bin on your scheduled collection day. However, sometimes for various reasons we may miss some e.g. parked cars, roadworks blocking access to your street, difficult road conditions or adverse weather. Where you are not at fault, and resources permit, we will attempt to go back out for your bin. In these instances, continue to leave your bin out and, if necessary, contact a member of the Waste Team the next day following your collection date on: ",["BR"],"\nE. ",["A",{"href":"mailto:waste@antrimandnewtownabbey.gov.uk"},"waste@antrimandnewtownabbey.gov.uk "],["BR"],"\nT. ",["A",{"href":"tel:00442890340056"},"028 9034 0056"]," or",["BR"],"\nLive Chat: Look for the purple chat icon on our website",["BR"],"\n",["BR"],"\nPlease note: Council reserves the right not to return to collect a bin which was not presented on time, had a raised lid or was rejected because it was an unauthorised larger bin. All missed bins must be reported before 5pm on the next working day of the scheduled collection for us to look into the matter on your behalf."],"\n\n    "],"\n"],["LI",{},"\n    ",["A",{"href":"#","class":"title","name":"what-happens-to-the-waste-i-put-in-my-black-bin?"},"What happens to the waste I put in my black bin?"],"\n    ",["DIV",{"class":"content wysiwyg","style":"display: none;"},"\n        All waste from domestic black bins goes to landfill.  Please help us reduce this waste pollution by ensuring that you recycle as much as possible.\n    "],"\n"],["LI",{},"\n    ",["A",{"href":"#","class":"title","name":"what-happens-to-the-recycling-waste-i-put-in-my-blue-bin?"},"What happens to the recycling waste I put in my blue bin?"],"\n    ",["DIV",{"class":"content wysiwyg","style":"display: none;"},"\n        It is taken to a mechanical recovery facility where the waste is separated into it’s various components before they are sent to be recycled into new materials.\n    "],"\n"],["LI",{},"\n    ",["A",{"href":"#","class":"title","name":"what-happens-when-i-move-house?"},"What happens when I move house?"],"\n    ",["DIV",{"class":"content wysiwyg","style":"display: none;"},"\n        ",["P",{},"Your bins are you own property and should be taken with you when you move house.  If you are moving into a new property in the Borough you can purchase new bins from the Council."],"\n\n    "],"\n"],["LI",{},"\n    ",["A",{"href":"#","class":"title","name":"what-happens-if-my-brown-bin-is-too-heavy-when-filled?"},"What happens if my brown bin is too heavy when filled?"],"\n    ",["DIV",{"class":"content wysiwyg","style":"display: none;"},"\n        Please note that we ",["STRONG",{},"cannot empty bins"]," that exceed the limiter on the bin lorry lifters. This limit is in place to ensure the Health and Safety of our staff.",["BR"],"\n",["BR"],"\nTo ensure that your bin is not too heavy, we advise you to present it when it is half full, especially when the organic waste is wet. If your bin has not been collected because it is too heavy, please remove some of the waste and present it on your next collection date.",["BR"],"\n",["BR"],"\nWe are unable to return to lift your bin if has not been collected due to being overweight.\n    "],"\n"],"\n"],["P"],"\n\n      "],"\n    "],"\n  "],"\n"],"\n\t\t",["DIV",{"class":"wrapper-white"},"\n\t\t\t",["DIV",{"class":"grid-container"},"\n\t\t\t\t",["DIV",{"class":"grid-x grid-padding-x"},"\n\t\t\t\t\t",["DIV",{"class":"cell auto text-center"},"\n\t\t\t\t\t\t",["H2",{"class":"title-main green"},"Further Bins & Recycling information"],"\n\t\t\t\t\t"],"\n\t\t\t\t"],"\n\t\t\t\t",["DIV",{"class":"grid-x large-up-4 medium-up-3 small-up-2"},"\n          ",["DIV",{"class":"cell"},"\n            ",["A",{"class":"feature-box hero","href":"/recyclingcentres/","title":"Recycle Centres"},"\n              ",["IMG",{"__playwright_current_src__":"https://antrimandnewtownabbey.gov.uk/getmedia/a5ff077e-7490-4006-9316-f0c2fa3538b1/Recycle-Centres.png.aspx?w=61&h=61&ext=.png&width=61","src":"/getmedia/a5ff077e-7490-4006-9316-f0c2fa3538b1/Recycle-Centres.png.aspx?w=61&h=61&ext=.png&width=61","alt":"Recycle Centres"}],"\n              ",["DIV",{"class":"title-block"},"\n                ",["H2",{"class":"title"},"Recycle Centres"],"\n              "],"\n            "],"\n          "],"          ",["DIV",{"class":"cell"},"\n            ",["A",{"class":"feature-box hero","href":"/recycling/","title":"Recycling - How, What & Why?"},"\n              ",["IMG",{"__playwright_current_src__":"https://antrimandnewtownabbey.gov.uk/getmedia/74952421-48af-4c86-b6b9-56c17fae0ee9/What-goes-in-each-bin.png.aspx?w=61&h=61&ext=.png&width=61","src":"/getmedia/74952421-48af-4c86-b6b9-56c17fae0ee9/What-goes-in-each-bin.png.aspx?w=61&h=61&ext=.png&width=61","alt":"What Can Be Recycled?"}],"\n              ",["DIV",{"class":"title-block"},"\n                ",["H2",{"class":"title"},"Recycling - How, What & Why?"],"\n              "],"\n            "],"\n          "],"          ",["DIV",{"class":"cell"},"\n            ",["A",{"class":"feature-box hero","href":"/residents/bins-recycling/special-collection-assisted-lift/","title":"Assisted / Larger Capacity Collections"},"\n              ",["IMG",{"__playwright_current_src__":"https://antrimandnewtownabbey.gov.uk/getmedia/90ba7669-6dbb-40a9-a183-880e77054060/Special-Assistance.png.aspx?w=61&h=61&ext=.png&width=61","src":"/getmedia/90ba7669-6dbb-40a9-a183-880e77054060/Special-Assistance.png.aspx?w=61&h=61&ext=.png&width=61","alt":"Special Collection / Assisted Lift"}],"\n              ",["DIV",{"class":"title-block"},"\n                ",["H2",{"class":"title"},"Assisted / Larger Capacity Collections"],"\n              "],"\n            "],"\n          "],"\n\t\t\t"],"\n\t\t\t"],"\n\t\t"],"\n\n\n\n\n\n",["DIV",{"class":"wrapper-grey"},"\n\t\t\t",["DIV",{"class":"grid-container"},"\n",["DIV",{"class":"grid-x grid-padding-x"},"\n    ",["DIV",{"class":"cell auto text-center"},"\n        ",["H2",{"class":"title-main purple"},"Latest News"],"\n    "],"\n"],"\n",["DIV",{"class":"grid-x grid-padding-x medium-up-2"},"\n  \n  \t\t\t\t\t",["DIV",{"class":"cell medium-12"},"\n\t\t\t\t\t\t",["A",{"class":"news-box