\t\t\t\t\t\n\t\t\t\t"],"\n\t\t\t"],"\n\t\t"],"\n\n\t\t\n\t\t\n\t\t",["DIV",{"class":"row"},"\n\t\t\t",["DIV",{"class":"col-xs-24 col-xs-offset-0 col-sm-15 col-sm-offset-1"},"\n\t\t\t\t\n\t\t\t\t\n\t\t\t"],"\n\t\t"],"\n\t\n\n\t\t\t\n\t\t\t",["DIV",{"class":"row"},"\n\t\t\t\t",["DIV",{"class":"col-xs-24 col-xs-offset-0 col-sm-15 col-sm-offset-1"},"\n\t\t\t\t\t\n\t\t\t\t\t\t",["DIV",{"class":"sdc-panel content-panel"},["DIV",{"class":"page-legend","id":"page-legend"},["STRONG",{},"Information covered on this page"],["HR"],["UL",{"class":"page-legend-list"},["LI",{"class":""},["A",{"title":"Go to Missed Bins section","class":"legend-link","href":"#h21"},"Missed Bins"]],["LI",{"class":""},["A",{"title":"Go to Assistance with your Collection section","class":"legend-link","href":"#h22"},"Assistance with your Collection"]],["LI",{"class":""},["A",{"title":"Go to Contact section","class":"legend-link","href":"#h23"},"Contact"]]]],"\n\t\t\t\t\t\t\t\n\t\t\t\t\t\t\t\n\n","\n\n\n\t\t\t","\n\n\t\t\t\n",["DIV",{"class":"eform-link"},"\n\t",["P",{},["STRONG",{},"Use the online bin calendar to check your bin collection day"]],"\n\t",["A",{"href":"/bins/","class":"btn btn-sdc icon continue"},"Bin calendar"],"\n"],"\n\t\t\t","\n\t\t",["H2",{"id":"h21","class":"page-legend-target"},"Missed Bins"],"\n",["P",{"id":"toppara"},"If your collection has been missed, please report it online or contact the Streetscene team on the details below within two working days."],"\n",["P"],"\n",["P",{},"If we arrange for the crew to return, please ensure that you leave your bins at the normal collection point on your property boundary."],"\n",["H2",{"id":"h22","class":"page-legend-target"},"Assistance with your Collection"],"\n",["P",{},"An assisted collection service is available for residents who cannot place their bins out for collection. Once set up, the crews empty and return the bins to an agreed collection point outside the property. To qualify, there must be nobody else living at the property able to assist."],"\n",["P",{},"The criteria to receive an assisted collection are as follows (one or more):"],"\n",["UL",{},"\n",["LI",{},"Infirmity"],"\n",["LI",{},"Disability"],"\n",["LI",{},"Ill health/medical condition"],"\n"],"\n",["P",{},"You can apply online or by phone, please see below. Collection crews will need to be allowed access to the bins on the scheduled collection day. We carry out a review every two years to check that the assistance is still needed. If circumstances change and it is no longer required, please contact us."],"\n",["P"],"\n",["H2",{"id":"h23","class":"page-legend-target"},"Contact"],"\n",["UL",{},"\n",["LI",{},"Email: ",["A",{"class":"lmail","href":"mailto:streetscene@stratford-dc.gov.uk","title":"Send Email: "},"streetscene@stratford-dc.gov.uk"," ",["I",{"class":"fad fa-fw fa-envelope text-primary"}]]],"\n",["LI",{},"Telephone: 01789 260616"],"\n",["LI",{},"Online forms:\n",["UL",{},"\n",["LI",{},["A",{"class":"lint","title":"Website Page: Missed Bin Report Form","href":"/online-forms/missed-bin-report-form.cfm","data-id":"139395"},"Report a missed bin"," ",["I",{"class":"fad fa-fw fa-link "}]]],"\n",["LI",{},["A",{"class":"lint","title":"Website Page: Assisted Collection Form","href":"/online-forms/assisted-collection-form.cfm","data-id":"139390"},"Request an assisted collection"," ",["I",{"class":"fad fa-fw fa-link "}]]],"\n"],"\n"],"\n"]," \n","\n\n\n\n\n\t\t\t\t\t\t"],"\n\t\t\t\t\t\t",["DIV",{"class":"sdc-panel"},"\n\t\t\t\t\t\t\t\n\n",["DIV",{"class":"author-info d-flex"},"\n\t",["DIV",{"class":"author flex-grow-1"},"\n\t\t\n\t\t\t\t",["P",{},"\n\t\t\t\t\t",["STRONG",{},"Contact: "]," ",["A",{"id":"page-contact","href":"mailto:streetscene@stratford-dc.gov.uk"},"The Streetscene team"],"\n\t\t\t\t"],"\n\t\t\t\n\t\t\t\t",["SMALL",{},"Last updated on 17/12/2024"],"\n\t\t\t\n\t"],"\n\t\t",["DIV",{"class":"back-to-top"},"\n\t\t",["A",{"class":"fs-5","href":"#","title":"back to top"},["I",{"class":"fa-solid fa-square-up"}]," Back to 