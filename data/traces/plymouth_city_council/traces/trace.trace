-11 col-sm-11 conditional fieldInput content html non-input ","data-content":"<div style=\"border-style:solid; padding:10px 10px 10px 10px; text-align:centre;\">\n<h3>We are experiencing high demand at the moment and it might take a little longer to find your collection days. If you've waited longer than a minute please refresh this form and try again</h3>\n</div>","data-display-condition":"((({number1} isnt '') and ({processingCheck} is 'false')) or ({noResponse} isnt '')) and ({addressNotFound} is '') and {mayriseStatusCheck} noticontains 'Waste'"}],["DIV",{"class":"screen-reader-error","aria-live":"polite","aria-atomic":"true"}]]," "],["DIV",{"class":"field fs-hidden","data-field-name":"noResponse","data-field-type":"radio","style":"display: none; padding-top: 0px;"},["DIV",{"class":"fieldContent"},["LABEL",{"id":"label_noResponse","for":"noResponse","class":"col-xs-11 col-sm-11  fieldName hide hideLabel\t\t","style":"display: none;"},["SPAN",{"class":"_fieldName","style":"display: none;"},"noResponse"],"\t\t\t\t"],"\t",["DIV",{"class":"af-block col-xs-1 col-sm-1 hidden-xs hidden-sm hidden-md hidden-lg","style":"display: none;"}],["FIELDSET",{"name":"noResponse","id":"noResponse","data-name":"noResponse","data-type":"radio","role":"radiogroup","aria-label":"noResponse","class":"col-xs-11 col-sm-11     conditional hideLabel fieldInput selectInput radio horizontal ","aria-labelledby":"label_noResponse noResponse prefix_noResponse helpText_noResponse","data-display-condition":"((({number1} isnt '') and ({processingCheck} is 'false')) or ({noResponse} isnt '')) and ({addressNotFound} is '')","data-mandatory-message":"This field is required","style":"display: none;"},["LEGEND",{"class":"hidden","style":"display: none;"},"noResponse"],["SPAN",{"class":"radio-wrapper","style":"display: none;"},"\t",["INPUT",{"__playwright_value_":"Waited more than 30 seconds for details","__playwright_checked_":"false","type":"radio","id":"noResponse-0-AF-Field-1825791e-7482-462d-9dbe-d