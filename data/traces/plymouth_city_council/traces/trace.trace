n\n  "],"\n\n    "],"\n  "],"\n\n",["DIV",{"class":"govuk-width-container"},"\n      ",["MAIN",{"class":"govuk-main-wrapper","id":"main-content"},"\n        ",["DIV",{"class":"govuk-grid-row"},"\n                                      ",["DIV",{"class":"page-region-content govuk-grid-column-full"},"\n          ",["DIV",{"class":"region region-content"},"\n    ",["DIV",{"data-drupal-messages-fallback":"","class":"hidden"}],"\n",["DIV",{"id":"block-plymouth-content","class":"block block-system block-system-main-block"},"\n  ",["ARTICLE",{"about":"/check-your-bin-day"},"\n\n  \n    \n\n  \n  ",["DIV",{},"\n      ",["DIV",{"class":"layout layout--onecol"},"\n    ",["DIV",{"class":"layout__region layout__region--content"},"\n      ",["DIV",{"class":"block block-layout-builder block-extra-field-block--node--basic-page--content-moderation-control"},"\n  "],"\n\n    "],"\n  "],"\n\n  ",["DIV",{"class":"layout layout--twocol-section layout--twocol-section--67-33 govuk-grid-row"},"\n\n          ",["DIV",{"class":"layout__region layout__region--first"},"\n        ",["DIV",{"class":"block block-layout-builder block-field-block--node--basic-page--body"},"\n  \n            ",["DIV",{"class":"field field--name-body field--type-text-with-summary field--label-hidden"},"\n",["P",{},"Your bins will be collected every other week. One week domestic (brown bin) and the other week recycling (green bin)."],"\n\n\n\n",["P",{},"You can also check your garden waste collection dates."],"\n\n\n\n",["DIV",{"class":"wp-block-buttons"},"\n",["DIV",{"class":"wp-block-button"},["A",{"class":"wp-block-button__link","href":"https://plymouth-self.achieveservice.com/en/AchieveForms/?form_uri=sandbox-publish://AF-Process-31283f9a-3ae7-4225-af71-bf3884e0ac1b/AF-Stagedba4a7d5-e916-46b6-abdb-643d38bec875/definition.json&redirectlink=%2Fen&cancelRedirectLink=%2Fen&consentMessage=yes","target":"_blank","rel":"noreferrer noopener"},"Check my collection day (opens new tab)"]],"\n"],"\n\n\n\n",["H2",{"id":"when-to-put-your-binout"},["STRONG",{},"When to put your bin out"]],"\n\n\n\n",["P",{},"Put your bins on the kerbside from 6.30pm the night before your collection day. Return your bin/bags back within your property boundary before midnight on the day of your collection."],"\n\n\n\n",["H3",{"id":"bank-holidays"},["STRONG",{},"Bank holidays"]],"\n\n\n\n",["P",{},"Your bins will be collected one day later than usual if there's a bank holiday."],"\n\n\n\n",["H3",{"id":"community-collection-points"},["STRONG",{},"Community collection points"]],"\n\n\n\n",["P",{},"Some areas of the city have community collection points. These use community bins for waste and recycling. These are collected and emptied as and when required."],"\n\n\n\n",["H2",{"id":"putting-waste-in-bins-bags"},"Putting waste in bins/bags"],"\n\n\n\n",["P",{},"All your waste must be contained inside the relevant Council provided bin/bags. You must not put any rubbish next to your bin/bags. If you have a bin the lid must be completely closed. If you have more household waste than you can fit in your bin/bags you can take it to your nearest recycling centre."],"\n\n\n\n",["P",{},"Visit our ",["A",{"href":"/bins","data-type":"[EN] basic_page","data-id":"11744"},"bins page"]," to find out what goes in each bin."],"\n\n\n\n",["H2",{"id":"help-to-put-out-your-bins"},"Help to put out your bins"],"\n\n\n\n",["P",{},"If you can't put your bins out due to a disability, and there's no-one in your home to help, you might be able to get an ",["A",{"href":"https://www.plymouth.gov.uk/assisted-bin-collections"},"assisted collection"],"."],"\n"],"\n      "],"\n\n      "],"\n    \n          ",["DIV",{"class":"layout__region layout__region--second"},"\n        ",["DIV",{"class":"block block-book block-book-navigation"},["H2",{"id":"in-this-section"},"In this section"],"\n  \n        ",["UL",{"class":"cp-book cp-book--bullets"},"\n                  ",["LI",{"class":"govuk-book__navigation-item menu-item--collapsed"},"\n        ",["