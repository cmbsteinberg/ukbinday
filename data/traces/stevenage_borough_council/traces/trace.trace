04-1.279-.183-1.578-.304-.397-.16-.68-.35-.977-.658a2.739 2.739 0 0 1-.636-1.012c-.116-.31-.255-.776-.292-1.634-.041-.928-.05-1.207-.05-3.557 0-2.35.009-2.628.05-3.556.037-.859.176-1.325.292-1.635.154-.41.338-.704.636-1.012.297-.308.58-.499.977-.658.3-.12.75-.264 1.578-.303.896-.043 1.164-.052 3.433-.052","mask":"url(#b)"}],["path",{"fill":"#D6457D","d":"M8.5 11.421a2.921 2.921 0 1 1 0-5.842 2.921 2.921 0 0 1 0 5.842M8.5 4a4.5 4.5 0 1 0 0 9 4.5 4.5 0 0 0 0-9M14 4a1 1 0 1 1-2 0 1 1 0 0 1 2 0"}]]],["SPAN",{"class":"visuallyHidden__VisuallyHidden-sc-1q0qjf3-0 cgNNHv"},"Instagram - opens in a new window"]]]]]]],["DIV",{"class":"HtmlRaw-s2hey9-0 eOtthb lead__text"},["P",{},"Refuse and recycling is collected on alternative weeks."]],["A",{"class":"Link-sc-1lopz1l-0 ejDSOa ButtonLinkstyled__StyledButtonLink-bmavc8-0 cjctAW button","target":"_self","href":"/find"},"Find out which day your refuse and recycling will be collected "],["DIV",{"class":"HtmlRaw-s2hey9-0 eOtthb text__block"},["H2",{},"Collections"],"\n",["P",{},"Your black refuse bin is collected every other week. Only waste in your refuse bin will be collected (no side waste will be taken)."],"\n",["P",{},"Your recycling containers (red, blue, brown and black) are collected the week in between. If you require ",["A",{"title":"Request new or replacement waste and recycling bins or containers","href":"/waste-and-recycling/request-waste-and-recycling-bins-or-containers","data-nodeid":"bf2f5f60-d68f-4bac-a3b2-737908af20fd","data-nodelanguage":"en-GB","data-entryid":"8e5f9988-c97c-421b-abab-280228eed614"},"additional containers to support increased recycling"],", you can get these from us free of charge."]],["DIV",{"class":"HtmlRaw-s2hey9-0 eOtthb text__block"},["H2",{},"Flat block collections"],"\n",["P",{},"For residents who live in flat blocks, refuse is collected weekly and recycling is collected fortnightly. Collections are dependent on each block."]],["DIV",{"class":"HtmlRaw-s2hey9-0 eOtthb text__block"},["H2",{},"When to put your bins out"],"\n",["P",{},"Put your bins or boxes on your property boundary by 7am on the day of your collection but not before 7pm the night before."],"\n",["P",{},"Enforcement action may be taken if you keep your bins and boxes on the pavement. Bins and boxes kept on pavements can impact negatively upon the local environment, pose an obstruction and be a potential fire risk."]],["DIV",{"class":"ExternalIFramestyled__ExternalIFrameStyled-sc-1nykrr1-0 eUwBfV"},["IFRAME",{"__playwright_bounding_rect__":"{\"left\":20,\"top\":1179.484375,\"right\":513.328125,\"bottom\":1456.96875}","src":"/snapshot/frame@a7691df800c2130ff3733ca966e07447","title":"Information about leaving your bins outside of your property boundary","frameborder":"0","allowfullscreen":""}]],["DIV",{"class":"HtmlRaw-s2hey9-0 eOtthb text__block"},["H2",{},"Service disruptions"],"\n",["P",{},"If there are planned disruptions to your usual collection day, such as a bank holiday, this will be marked on your collection calendar and on the online collection checker."],"\n",["P",{},"Should there be an unplanned service disruption, such as wintry weather, we will advise residents via:"],"\n",["UL",{},"\n",["LI",{},"this website;"],"\n",["LI",{},["A",{"title":"Stevenage Borough Council on Facebook","href":"https://www.facebook.com/stevenageboroughcouncil/","target":"_blank","rel":"noopener"},"Facebook",["SPAN",{"class":"visually-hidden"},"(opens in new window)"]]," and"],"\n",["LI",{},["A",{"title":"Stevenage Borough Council on Twitter","href":"https://twitter.com/stevenagebc","target":"_blank","rel":"noopener"},"Twitter",["SPAN",{"class":"visually-hidden"},"(opens in new window)"]]],"\n"]]],["DIV",{"class":"Columnstyled__StyledColumn-sc-1aq1prz-0 cXPEcD width26 column"},["DIV",{"class":"RelatedLinksstyled__StyledRelatedLinks-kx9h9e-0 dNavki"},["H2",{"class":"Headingstyled__StyledHeading-sc-1tmxkna-0 eswohD"},"Related pages"],["UL",{},["LI",{},["DIV",{"class":"flex-wrapper"},["A",{"class":"Link-sc-1lopz1l-0 fAmSU","target":"_self","href":"/waste-and-recycling/missed-bins"},"Missed Bin Collections"]]],["LI",{},["DIV",{"class":"flex-wrapper"},["A",{"class":"Link-sc-1lopz1l-0 fAmSU","target":"_self","href":"/waste-and-recycling/your-waste-bins-and-recycling-containers"},"Your Waste Bins and Recycling Containers"]]]]],["DIV",{"class":"RelatedLinksstyled__StyledRelatedLinks-kx9h9e-0 dNavki"},["H2",{"class":"Headingstyled__StyledHeading-sc-1tmxkna-0 eswohD"},"Related documents"],["UL",{},["LI",{},["DIV",{"class":"flex-wrapper"},["A",{"class":"Link-sc-1lopz1l-0 fAmSU","target":"_blank","rel":"noopener noreferrer","href":"/documents/waste-and-recycling/household-waste-management-policy.pdf"},"Household Waste Management Policy (PDF, 6.6 MB)",["SPAN",{"class":"visuallyHidden__VisuallyHidden-sc-1q0qjf3-0 cgNNHv"}," - opens document in new window"],["svg",{"class":"ExtSvg-sc-19z86si-0 jBRYNo external-link-icon","xmlns":"http://www.w3.org/2000/svg","width":"16","height":"16","viewBox":"0 0 24 24","fill":"CurrentColor","stroke-linecap":"square","stroke-linejoin":"arcs"},["title",{},"External Link - opens in a new window"],["g",{"fill":"none","fill-rule":"evenodd"},["path",{"d":"M18 14v5a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8c0-1.1.9-2 2-2h5M15 3h6v6M10 14L20.2 3.8"}]]]],["IMG",{"__playwright_current_src__":"https://www.stevenage.gov.uk/static/img/download.svg?47c94ea429d104e361e9b55028fc5703","src":"/static/img/download.svg?47c94ea429d104e361e9b55028fc5703","alt":"Download Household Waste Management Policy","aria-hidden":"true"}]]],["LI",{},["DIV",{"class":"flex-wrapper"},["A",{"class":"Link-sc-1lopz1l-0 fAmSU","target":"_blank","rel":"noopener noreferrer","href":"/documents/waste-and-recycling/household-recycling-leaflet.pdf"},"Household Recycling Information Leaflet (PDF, 2.0 MB)",["SPAN",{"class":"visuallyHidden__VisuallyHidden-sc-1q0qjf3-0 cgNNHv"}," - opens document in new window"],["svg",{"class":"ExtSvg-sc-19z86si-0 jBRYNo external-link-icon","xmlns":"http://www.w3.org/