     ",["H2",{},"Collection dates"],"\n",["P",{},"Enter your postcode to see your next three collection days."],"\n                    "],"\n\n                    ",["SECTION",{"id":"mnsearch","aria-label":"postcode search"},"\n                        ",["DIV",{"id":"mn"},"\n                            ",["FORM",{"class":"site-search clearfix","id":"site-search-form-page"},"\n                                ",["P",{"id":"saveAddressLine"},["INPUT",{"__playwright_value_":"on","__playwright_checked_":"false","type":"checkbox","id":"mnSave"}],["LABEL",{"for":"mnSave","style":"display:inline;"},"Remember your selected address*"]],"\n                                ",["LABEL",{"for":"mnterm","id":"mntermlabel"},"Enter post code or part of address:"],"\n                                ",["INPUT",{"__playwright_value_":"","type":"text","name":"mnterm","id":"mnterm","style":"float:left;"}],"\n                                ",["BUTTON",{"type":"submit","class":"search","id":"findOutBtn","aria-label":"Search for address"},["SPAN",{"class":"fa fa-search"}]],"\n                                ",["P",{},"\n                                    * if you check this box we will use a cookie to remember your chosen address. You can uncheck it at any time by choosing 'select a different address'.\n                                "],"\n                                ",["INPUT",{"__playwright_value_":"Bin Collection Day","type":"hidden","name":"qtype","id":"qtype","value":"Bin Collection Day","onclick":""}],"\n                            "],"\n                        "],"\n                    "],"\n\n\n                    ",["SECTION",{"id":"results","role":"main","aria-label":"Search results"}],"\n\n                    ",["SECTION",{"aria-label":"additional text"},"\n                        ",["P",{},"Please ",["A",{"data-id":"1326","href":"/help-and-accessibility/contact-us/","title":"Contact us"},"contact us"]," if you have your recycling collected from shared wheeled bins."],"\n",["H2",{},"Collection point"],"\n",["P",{},"Put your bins and boxes out as close to the public highway as possible. Usually this is on the pavement outside your house."],"\n",["P",{},"We are unable to come onto your property to collect your bins, unless you have been approved for ",["A",{"href":"/recycling-and-waste/bin-and-box-collections/help-with-collections/","title":"Help with collections","data-anchor":"#"},"assistance with your collections"],"."],"\n",["H2",{},"Collection time"],"\n",["P",{},"We will collect your bins and boxes at any time between 6am and 4pm. "],"\n",["P",{},"We recommend putting your bins out the night before collection. "],"\n",["H2",{},"How to put your recycling out for collection"],"\n",["P",{},["IMG",{"__playwright_current_src__":"","src":"/media/2442/img_5646.jpg?width=500&height=333","alt":"Stacked boxes","width":"500","height":"333"}]],"\n",["P",{},"Please stack your boxes as shown in this picture. Place your blue food waste container on the top box to help stop items from blowing away."],"\n",["P",{},"Your recycling should be contained within your boxes. If you have large cardboard boxes, fold or tear them to fit inside your green box."],"\n",["H2",{},"Wheeled bins"],"\n",["P",{},"Your waste needs to be put inside your bin with the lid closed. We cannot collect extra bags of waste from on top of, or beside your bin."],"\n",["P",{},"If your bin is overfull with the lid open, we may need to leave one of your bags behind. "],"\n",["P",{},"Find out ",["A",{"href":"/recycling-and-waste/bin-and-box-collections/extra-waste/","title":"Extra waste","data-anchor":"#"},"what to do if you have extra waste"],"."],"\n",["H2",{},"Bin and box storage"],"\n",["P",{},"Your bins and boxes need to be stored on your property between collections. After collection, take them back onto your property as soon as possible. "],"\n",["H2",{},"Access"],"\n",["P",{},"Collections will be delayed if our vehicles cannot access your street. Please consider this when parking your cars outside your home and avoid parking on tight corners. "],"\n",["H2",{},"Download a yearly calendar"],"\n",["P",{},"You can ",["A",{"href":"/recycling-and-waste/bin-and-box-collections/download-your-collection-calendar/","title":"Download your collection calendar","data-anchor":"#"},"download a calendar"]," showing all your collection dates for a year from April to March."],"\n                    "],"\n\n                "],"                \n            "],"\n            ",["DIV",{"class":"related-content"},"\n                ",["ASIDE",{"aria-label":"related links"},"\n                    ","\n                    ",["NAV",{"class":"clearfix related-links-nav-container","aria-label":"related links","id":"relatedlinks"},["H2",{},"Related links"],["UL",{},"\n\n                ",["LI",{},["A",{"href":"/recycling-and-waste/what-goes-in-my-bins-and-boxes/","itemprop":"relatedLink","title":"What goes in my bins and boxes"},["DIV",{"class":"link-padder"},["SPAN",{},"What goes in my bins and boxes"]]]],"\n                ",["LI",{},["A",{"href":"/recycling-and-waste/bin-and-box-collections/extreme-weather/","itemprop":"relatedLink","title":"Extreme weather"},["DIV",{"class":"link-padder"},["SPAN",{},"Extreme weather"]]]],"\n                ",["LI",{},["A",{"href":"/recycling-and-waste/bin-and-box-collections/report-a-missed-bin-or-box/","itemprop":"relatedLink","title":"Report a missed bin or box"},["DIV",{"class":"link-padder"},["SPAN",{},"Report a missed bin or box"]]]],"\n\n\n\n"]],"\n\n\n                    ","\n\n\n                "],"\n            "],"\n        "],"\n    "],"\n"],"\n\t\t","\t\t\t\t\t\n\n\t\n    ","\n    \n\n",["FOOTER",{"class":""},"\n    ",["DIV",{"class":"main wrapper clearfix"},"\n        ",["ASIDE",{"class":"page-support clearfix","aria-label":"page support section"},"\n            ","\n            ",["DIV",{"id":"page-support-nav"},"\n    ",["BUTTON",{"id":"page-support-button","class":"article-button page-support-closed"}," Is there anything wrong with this page?"],"\n"],"\n            ","\n            ","\n            \n",["DIV",{"id":"page-support-content"},"\n    ","\n    ",["DIV",{"id":"page-support-report-page-problem-content","class":"content-hidden"},"\n        ",["FORM",{"method":"post","action":"/thank-you-for-your-feedback","class":"clearfix","id":"page-support-report-page-problem-form"},"\n\n            ",["H2",{},"Help us fix teignbridge.gov.uk"],"\n            ",["FIELDSET",{},"\n                ",["LEGEND",{},"Report a problem on this page"],"\n                ",["P",{},"When describing the webpage problem, please don’t give us any confidential personal or financial details. If you would like us to get back to you for further investigation please leave your name and contact email."],"\n                ",["LABEL",{"for":"page-support-report-page-problem-action"},"What you were doing"],"\n                ",["INPUT",{"__playwright_value_":"","type":"text","aria-label":"What were you doing?","name":"page-support-report-page-problem-action","id":"page-support-report-page-problem-action","autocomplete":"off"}],"\n                ",["LABEL",{"for":"page-support-report-page-problem-error"},"What went wrong"],"\n                ",["INPUT",{"__playwright_value_":"","type":"text","aria-label":"What went wrong","name":"page-support-report-page-problem-error","id":"page-support-report-page-problem-error","autocomplete":"off"}],"\n                ",["H3",{},"Getting the right result"],"\n                ",["P",{},"We might need to find out more to establish what the problem is. Please could you leave your contact details in case we need to contact you."],"\n                ",["LABEL",{"for":"page-support-report-page-problem-email"},"Your email address"],"\n                ",["INPUT",{"__playwright_value_":"","type":"text","aria-label":"Your email address","name":"page-support-report-page-problem-email","id":"page-support-report-page-problem-email","autocomplete":"email"}],"\n                