n            ",["A",{"href":"https://my.orkney.gov.uk/","title":"My Orkney"},"\n                My Orkney\n            "],"\n        "],"\n\n\n        ",["LI",{},"\n            ",["A",{"href":"/online/report-it/","title":"Report It"},"\n                Report It\n            "],"\n        "],"\n\n\n        ",["LI",{},"\n            ",["A",{"href":"/online/request-it/","title":"Request It"},"\n                Request It\n            "],"\n        "],"\n            "],"\n        "],"\n    "],"\n\n        "],"\n    "],"\n"]],"\n        "],"\n\n        ",["DIV",{"class":"row content"},"\n            \n\n\n\n",["DIV",{"class":"home-container"},"\n    ",["DIV",{"class":"home-image-container","style":"max-width:33%","width":"33%"},"\n        \n                ",["IMG",{"__playwright_current_src__":"","id":"target","src":"/media/p5fj4qu4/waste1.jpg","alt":"Waste1","role":"presentation"}],"\n\n    "],"\n    ",["DIV",{"class":"home-body-wrapper","style":"margin-left:1px; margin-bottom:10px;"},"\n\n        ",["DIV",{"class":"home-body-container"},"\n            ",["MAIN",{"aria-hidden":"false","aria-label":"Main Content Area","id":"content","class":"newRegion5"},"\n\n\n\n\n",["H1",{},"Waste and Recycling"],"\n",["P",{},"This section contains a wealth of information relating to the collection, recycling and disposal of commercial and household waste in Orkney. You can also find information on Waste plans and how to Reduce, Reuse and Recycle your household waste."],"\n",["P",{},"The material you throw away costs money to dispose of (approximately £150.00 per tonne) as we have to ship the general residual waste to Shetland for incineration. By reducing what you throw away in the first place or recycling these materials instead, not only do you contribute to the sustainability of our environment, but you also make a very valuable contribution to us as a council in saving money that can be re-invested in other key services."],"\n                \n                ",["DIV",{"class":"homeLinkBoxRow"},"\n                    \n",["DIV",{"class":"homeLinkBoxNew","style":"background-color: #9d3900"},"\n    ",["DIV",{"class":"homeLinkHeader"},"\n        ",["DIV",{"class":"homeLinkImage"},"\n            ",["A",{"href":"/our-services/waste-and-recycling/household-waste-and-recycling/","alt":"Household Waste and Recycling"},"\n                ",["IMG",{"__playwright_current_src__":"","src":"/media/s2gf51de/household-waste-icon.png","alt":"Household Waste and Recycling"}],"\n            "],"\n        "],"\n        ",["DIV",{"class":"homeLinkTitle"},"\n            ",["A",{"href":"/our-services/waste-and-recycling/household-waste-and-recycling/","alt":"Household Waste and Recycling"},["LABEL",{"for":"homeLinkBoxNew1"},"Household Waste and Recycling"]],"\n        "],"\n        ",["DIV",{"class":"homeLinkArrow"},"\n            ",["A",{"href":"/our-services/waste-and-recycling/household-waste-and-recycling/","alt":"Household Waste and Recycling"},"➤"],"\n        "],"\n    "],"\n    ",["UL",{},"\n            ",["LI",{},["A",{"href":"https://my.orkney.gov.uk/en/AchieveForms/?form_uri=sandbox-publish://AF-Process-0c7d8834-2e50-4439-b7f5-ed313f4937f7/AF-Stage-218a9604-6ab2-4956-8b69-951a63681985/definition.json&redirectlink=%2Fen&cancelRedirectLink=%2Fen&consentMessage=yes"},"Assisted / Additional / Alternative collections"]],"\n            ",["LI",{},["A",{"href":"https://my.orkney.gov.uk/en/AchieveForms/?form_uri=sandbox-publish://AF-Process-da724cbb-b58a-46a1-bef8-6350fc8b0d0f/AF-Stage-09b88849-ff0d-4fe0-bdad-ea9c13ad600a/definition.json&redirectlink=/en&cancelRedirectLink=/en&consentMessage=yes"},"New or replacement bin or isles bags"]],"\n            ",["LI",{},["A",{"href":"/our-services/waste-and-recycling/household-waste-and-recycling/report-a-missed-bin/"},"Report a Missed Bin"]],"\n            ",["LI",{},["A",{"href":"/our-services/waste-and-recycling/household-waste-and-recycling/special-refuse-collections-households/"},"Special Refuse Collections - Ho