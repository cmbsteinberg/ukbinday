ish-and-Recycling/Domestic%20Heating%20Oil%20Tank%20Disposal.pdf","title":"PDF Link: Domestic Heating Oil Tank"},"Domestic Heating Oil Tank"]],"\n            ",["LI",{},["A",{"href":"/our-services/waste-and-recycling/hazardous-waste-materials/"},"Hazardous Waste Materials"]],"\n            ",["LI",{},["A",{"href":"/our-services/waste-and-recycling/policies-and-plans-waste-and-recycling/"},"Policies and Plans - Waste and Recycling"]],"\n            ",["LI",{},["A",{"href":"/Downloads/Files/Rubbish-and-Recycling/Recycling%20Posters.zip"},"Recycling Posters"]],"\n            ",["LI",{},["A",{"href":"https://www.sepa.org.uk/regulations/waste/"},"Scottish Environment Protection Agency (SEPA)"]],"\n    "],"\n"],"\n                "],"\n\n","\n",["HR"],"\n","\n",["H3",{},"Orkney's Waste Transfer Site - where all your waste and recycling goes"],"\n",["P",{},"All waste and recycling from households and businesses including materials collected from Orkney's Household Waste Recycling Centre network is delivered to Chinglebraes (Orkney’s Waste Transfer Site)."],"\n",["P",{},"Some waste continues to be landfilled at Bossack – but this is a small inert landfill site only. Waste and recyclates are baled and containerised. Recycling is shipped to a range of different re-processors on the Scottish Mainland and in England. All waste that cannot be recycled is shipped to Shetland Islands Council’s EFW Plant (Energy from Waste). The waste at the Gremista facility is incinerated and powers a district heating scheme in Lerwick."],"\n","\n            "],"\n        "],"\n    "],"\n"],"\n        "],"\n\n        ",["DIV",{"class":"row footer"},"\n            ",["FOOTER",{"aria-hidden":"false","aria-label":"Page Footer","class":"newRegion1"},["DIV",{"class":"footerWrapper"},"\n    ",["DIV",{"class":"footerCol"},"\n        ",["P",{},"School Place, Kirkwall, Orkney, KW15 1NY | ",["A",{"href":"tel:01856873535","class":"footerLink"},"01856 873535"]," |",["SPAN",{}," "],["A",{"href":"https://www-o