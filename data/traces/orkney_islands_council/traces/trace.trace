,{"class":"crt-post-c"},["DIV",{},["DIV",{"class":"crt-grid-post-content","style":"padding-bottom: 100%;"},["SPAN",{"role":"link","tabindex":"0","aria-label":"Facebook icon","class":"crt-social-icon"},["svg",{"aria-label":"Facebook icon","viewBox":"0 0 9 17","xmlns":"http://www.w3.org/2000/svg","class":"crt-icon-facebook"},"\n  ",["path",{"d":"M2.61477 17V9.39648H0V6.375H2.61477V3.99434C2.61477 1.40781 4.2375 0 6.60682 0C7.74205 0 8.71705 0.0830078 9 0.119531V2.82227H7.35682C6.06818 2.82227 5.81932 3.41992 5.81932 4.29316V6.375H8.72727L8.32841 9.39648H5.81932V17","fill":"currentColor"}],"\n"]],["DIV",{"aria-label":"Image posted by OICUpdates to facebook","tabindex":"0","role":"img","class":"crt-grid-post-image","style":"background-image: url(\"https://curator-assets.b-cdn.net/f17d6288-f256-465d-91c6-1910c73d0869/373150810.jpg?width=480\");"}]],["DIV",{"class":"crt-post-hover"},["DIV",{},["DIV",{"class":"crt-post-header"},["DIV",{"class":"crt-post-fullname"},["A",{"href":"https://www.facebook.com/OICUpdates","target":"_blank","aria-label":"Visit Orkney Islands Council profile","aria-hidden":"true"},"Orkney Islands Council"]]],["DIV",{"class":"crt-post-text"},"📣 Calling all carers!",["BR"],["BR"],"Orkney Carers Conference will be back in November 2025 ",["BR"],["BR"],"To make the 2025 event as useful and enjoyable as possible, we’re inviting carers to complete a short survey. ",["BR"],["BR"],"📝 Tell us what topics matter most to you - find the survey at 👇 ",["BR"],["A",{"href":"https://bit.ly/4eSaGf4","target":"_blank","rel":"noopener"},"https://bit.ly/4eSaGf4"]," ",["BR"],["BR"],"Prefer to fill it out a survey in person? Visit: ",["BR"],"📍 Crossroads Orkney -  (Travel Centre, Kirkwall) ",["BR"],"📍 Age Scotland Orkney -  (Victoria Street, Kirkwall) ",["BR"],["BR"],["A",{"href":"https://www.facebook.com/search/top/?q=%23HaveYourSay","target":"_blank","rel":"noopener"},"#HaveYourSay"]," ",["A",{"href":"https://www.facebook.com/search/top/?q=%23CarersVoices","target":"_b