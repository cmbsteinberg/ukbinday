b-cdn.net/custom-post-assets/52186/uy6HPEGO.png?width=480\");"}]],["DIV",{"class":"crt-post-hover"},["DIV",{},["DIV",{"class":"crt-post-header"}],["DIV",{"class":"crt-post-title"},"Latest updates from Orkney 2025"],["DIV",{"class":"crt-post-text"},["P",{},["SPAN",{"style":"background-color: rgb(255, 255, 254); color: rgb(0, 0, 0);"},"Links to useful sources of information for visitors and locals during 2025 Orkney International Island Games"]]],["DIV",{"class":"crt-post-footer crt-post-footer-no-user-image"},["SPAN",{"class":"crt-post-date "},["A",{"href":"https://orkney.gov.uk/orkney2025","target":"_blank","aria-hidden":"true","aria-label":"Posted on 1 week ago, click to visit post on unknown","class":"crt-post-date-link"},"1 week ago"]]]]]]],["SPAN",{"tabindex":"0","aria-label":"End of post.","role":"status","class":"crt-hidden"}]]],["DIV",{"aria-hidden":"false","class":"crt-carousel-pane","style":"width: 262.5px;"},["DIV",{"class":"crt-pane-index"}," ","1"," "],["DIV",{"data-post":"372809162","tabindex":"0","role":"article","aria-label":"Post 2, Facebook post by Orkney Islands Council Here’s your reminder for kerbside waste and recycling arrangements for press enter to read more","data-position":"2","aria-setsize":"0","class":"crt-grid-post crt-post-has-image crt-post-has-text crt-post-facebook","style":"padding: 0px 1px 3px; opacity: 1;"},["DIV",{"class":"crt-post-c"},["DIV",{},["DIV",{"class":"crt-grid-post-content","style":"padding-bottom: 100%;"},["SPAN",{"role":"link","tabindex":"0","aria-label":"Facebook icon","class":"crt-social-icon"},["svg",{"aria-label":"Facebook icon","viewBox":"0 0 9 17","xmlns":"http://www.w3.org/2000/svg","class":"crt-icon-facebook"},"\n  ",["path",{"d":"M2.61477 17V9.39648H0V6.375H2.61477V3.99434C2.61477 1.40781 4.2375 0 6.60682 0C7.74205 0 8.71705 0.0830078 9 0.119531V2.82227H7.35682C6.06818 2.82227 5.81932 3.41992 5.81932 4.29316V6.375H8.72727L8.32841 9.39648H5.81932V17","fill":"currentColor"}],"\n"]],["DIV",{"aria-label":"Image posted by OICUpdates to facebook","tabindex":"0","role":"img","class":"crt-grid-post-image","style":"background-image: url(\"https://curator-assets.b-cdn.net/f17d6288-f256-465d-91c6-1910c73d0869/372809162.jpg?width=480\");"}]],["DIV",{"class":"crt-post-hover"},["DIV",{},["DIV",{"class":"crt-post-header"},["DIV",{"class":"crt-post-fullname"},["A",{"href":"https://www.facebook.com/OICUpdates","target":"_blank","aria-label":"Visit Orkney Islands Council profile","aria-hidden":"true"},"Orkney Islands Council"]]],["DIV",{"class":"crt-post-text"},"Here’s your reminder for kerbside waste and recycling arrangements for householders, for the week ahead – the week starting Monday 14 July 2025.  ",["BR"],["BR"],"🏅 First up a reminder that household recycling collections – green bins – in Stromness and the West Mainland (Areas 9 – 15) won't be running 14-18 July, due to the Orkney 2025 International Island Games. Check this page for further details, including changes to tip operating times too 👇",["BR"],["A",{"href":"https://bit.ly/44TBOa9","target":"_blank","rel":"noopener"},"https://bit.ly/44TBOa9"]," ",["BR"]," ",["BR"],"🗑 If next week is a WASTE collection week where you live (Areas 1 to 8 ), please put out your grey bin (or red bags if you use them) on your usual collection day and hold onto your recycling.  ",["BR"]," ",["BR"],"✅ You can look up your Area - and what's being collected week by week - any time on our website. Go to www.orkney.gov.uk/MyBins  ",["BR"]," ",["BR"],"🌬Windy weather can make bin days tricky for everyone - find tips and advice at www.orkney.gov.uk/binclips"],["DIV",{"class":"crt-post-footer"},["IMG",{"__playwright_current_src__":"https://curator-assets.b-cdn.net/f17d6288-f256-465d-91c6-1910c73d0869/372809162_user_image","aria-label":"Profile image for Orkney Islands Council","src":"https://curator-assets.b-cdn.net/f17d6288-f256-465d-91c6-1910c73d0869/372809162_user_image","alt":"Profile image for Orkney Islands Council","class":"crt-post-userimage","aria-hidden":"true"}],["SPAN",{"class":"crt-post-date "},["A",{"href":"https://www.facebook.com/631102302392018/posts/1193569492811960","target":"_blank","aria-hidden":"true","aria-label":"Posted on 1 week ago, click to visit post on Facebook","class":"crt-post-date-link"},"1 week ago"]],["DIV",{"role":"group","aria-label":"Share icon, press tab to proceed with the share buttons","class":"crt-post-share","aria-hidden":"true"},["SPAN",{"class":"crt-share-hint"}],["SPAN",{"class":"crt-share-button"},["svg",{"width":"14","height":"13","viewBox":"0 0 14 13","fill":"none","xmlns":"http://www.w3.org/2000/svg"},"\n  ",["path",{"fill-rule":"evenodd","clip-rule":"evenodd","d":"M8.04826 0.328338C8.35045 0.0450401 8.82507 0.0603507 9.10837 0.362535L13.4173 4.95873C13.6878 5.24722 13.6878 5.69615 13.4173 5.98464L9.10837 10.5808C8.82507 10.883 8.35045 10.8983 8.04826 10.615C7.74608 10.3317 7.73077 9.85711 8.01407 9.55492L10.9733 6.39844H5.12988C3.33496 6.39844 1.87988 7.85352 1.87988 9.64844V11.8755C1.87988 12.2897 1.5441 12.6255 1.12988 12.6255C0.715669 12.6255 0.379883 12.2897 0.379883 11.8755V9.64844C0.379883 7.02509 2.50653 4.89844 5.12988 4.89844H11.3047L8.01407 1.38845C7.73077 1.08626 7.74608 0.611636 8.04826 0.328338Z","fill":"currentColor"}],"\n"]],["DIV",{"class":"crt-popup-share-icon-container"},["P",{},"Share"],["DIV",{"class":"crt-popup-share-icon-container-icons"},["A",{"role":"link","aria-label":"Click to share to facebook","class":"crt-share-facebook","aria-hidden":"true"},["svg",{"aria-label":"Facebook icon","width":"9","height":"17","viewBox":"0 0 9 17","fill":"none","xmlns":"http://www.w3.org/2000/svg","class":"crt-icon-facebook","aria-hidden":"true"},"\n  ",["path",{"d":"M2.61477 17V9.39648H0V6.375H2.61477V3.99434C2.61477 1.40781 4.2375 0 6.60682 0C7.74205 0 8.71705 0.0830078 9 0.119531V2.82227H7.35682C6.06818 2.82227 5.81932 3.41992 5.81932 4.29316V6.375H8.72727L8.32841 9.39648H5.81932V17","fill":"currentColor"}],"\n"]],["A",{"role":"link","aria-label":"Click to share to twitter","class":"crt-share-twitter","aria-hidden":"true"},["svg",{"aria-label":"Twitter icon","width":"24","height":"21","viewBox":"0 0 26 23","fill":"none","xmlns":"http://www.w3.org/2000/svg","class":"crt-icon-twitter","aria-hidden":"true"},"\n  ",["path",{"d":"M0.0632662 0L10.1016 12.6858L0 23H2.27364L11.1177 13.9696L18.2633 23H26L15.3967 9.60076L24.7993 0H22.5256L14.3809 8.31659L7.8 0H0.0632662ZM3.40675 1.58274H6.96097L22.6561 21.4173H19.1019L3.40675 1.58274Z","fill":"currentColor"}],"\n"]]]]]]]]]],["SPAN",{"tabindex":"0","aria-label":"End of post.","role":"status","class":"crt-hidden"}]]],["DIV",{"aria-hidden":"true","class":"crt-carousel-pane","style":"width: 262.5px;"},["DIV",{"class":"crt-pane-index"}," ","2"," "],["DIV",{"data-post":"373152279","tabindex":"0","role":"article","aria-label":"Post 3, Facebook post by Orkney Islands Council There are twenty community councils around Orkney, each offering communities press enter to read more","data-position":"3","aria-setsize":"0","class":"crt-grid-post crt-post-has-image crt-post-has-text crt-post-has-video crt-post-facebook aria-hidden crt-post-video-playing","style":"padding: 0px 1px 3px; opacity: 1;"},["DIV",{"class":"crt-post-c"},["DIV",{},["DIV",{"class":"crt-grid-post-content","style":"padding-bottom: 100%;"},["SPAN",{"role":"link","tabindex":"0","aria-label":"Facebook icon","class":"crt-social-icon"},["svg",{"aria-label":"Facebook icon","viewBox":"0 0 9 17","xmlns":"http://www.w3.org/2000/svg","class":"crt-icon-facebook"},"\n  ",["path",{"d":"M2.61477 17V9.39648H0V6.375H2.61477V3.99434C2.61477 1.40781 4.2375 0 6.60682 0C7.74205 0 8.71705 0.0830078 9 0.119531V2.82227H7.35682C6.06818 2.82227 5.81932 3.41992 5.81932 4.29316V6.375H8.72727L8.32841 9.39648H5.81932V17","fill":"currentColor"}],"\n"]],["DIV",{"aria-label":"Image posted by OICUpdates to facebook","tabindex":"0","role":"img","class":"crt-grid-post-image","style":"background-image: url(\"https://curator-assets.b-cdn.net/f17d6288-f256-465d-91c6-1910c73d0869/373152279.jpg?width=480\");"}],["DIV",{"class":"crt-video-container "},["SPAN",{"tabindex":"0","aria-label":"play video","role":"button","class":"crt-play"},["I",{"class":"crt-play-icon"}]],["VIDEO",{"preload":"none","playsinline":"","aria-label":"Video posted by OICUpdates to facebook","loop":"","poster":"https://scontent-iad3-2.xx.fbcdn.net/v/t15.5256-10/522213261_2136839610133376_1916066796548332987_n.jpg?_nc_cat=106&ccb=1-7&_nc_sid=7965db&_nc_ohc=fZhTzM-cURgQ7kNvwFiWW4E&_nc_oc=AdkQ9VB0tZWpnTGc7-gDmI7L-YaD1DVPFAMoFwObZRc59fmFp3E2Unk1XEXhuy1XU2w&_nc_zt=23&_nc_ht=scontent-iad3-2.xx&edm=AKIiGfEEAAAA&_nc_gid=N2Lq-FkomXtiac63pIgMag&oh=00_AfRR8TNH_b_th8ofODDdC5BgfGx_eHp2xSxD-Jk9MkxdsQ&oe=6883EF72:thumb","class":"aspect-square"},["SOURCE",{"src":"https://curator-assets.b-cdn.net/f17d6288-f256-465d-91c6-1910c73d0869/373152279.mp4","type":"video/mp4"}]]]],["DIV",{"class":"crt-post-hover"},["DIV",{},["DIV",{"class":"crt-post-header"},["DIV",{"class":"crt-post-fullname"},["A",{"href":"https://www.facebook.com/OICUpdates","target":"_blank","aria-label":"Visit Orkney Islands Council profile","aria-hidden":"true"},"Orkney Islands Council"]]],["DIV",{"class":"crt-post-text"},"There are twenty community councils around Orkney, each offering communities a direct way to make their voices heard and raise issues that affect their parish or Island. ",["BR"],["BR"],"Each of those community councils has a dedicated Clerk, making sure meetings run smoothly as community councillors make decisions on behalf of their area. ",["BR"],["BR"],"Clerks receive a payment based on the number of meetings they support each year - but the real rewards are getting to know your community better and helping progress local initiatives.",["BR"],["BR"],"All equipment is provided, as well as ongoing support from the Community Councils team here at OIC.",["BR"],["BR"],"Colin McAlpine has been Clerk for Stronsay Community Council for 15 years. He says he finds his role as a Clerk hugely rewarding: “I enjoy the challenge of it, the excitement, the variety. I would recommend it because it’s a worthwhile job. You're doing something positive to try and help your community.”",["BR"],["BR"],"If you'd like to find out more about the role of Community Council Clerk and any current vacancies, get in contact via communitycouncils",["A",{"href":"https://www.facebook.com/orkney/","target":"_blank","rel":"noopener"},"@orkney"],".gov.uk"],["DIV",{"class":"crt-post-footer"},["IMG",{"__playwright_current_src__":"https://curator-assets.b-cdn.net/f17d6288-f256-465d-91c6-1910c73d0869/373152279_user_image","aria-label":"Profile image for Orkney Islands Council","src":"https://curator-assets.b-cdn.net/f17d6288-f256-465d-91c6-1910c73d0869/373152279_user_image","alt":"Profile image for Orkney Islands Council","class":"crt-post-userimage","aria-hidden":"true"}],["SPAN",{"class":"crt-post-date "},["A",{"href":"https://www.facebook.com/631102302392018/videos/719512654396810","target":"_blank","aria-hidden":"true","aria-label":"Posted on 33 minutes ago, click to visit post on Facebook","class":"crt-post-date-link"},"33 minutes ago"]],["DIV",{"role":"group","aria-label":"Share icon, press tab to proceed with the share buttons","class":"crt-post-share","aria-hidden":"true"},["SPAN",{"class":"crt-share-hint"}],["SPAN",{"class":"crt-share-button"},["svg",{"width":"14","height":"13","viewBox":"0 0 14 13","fill":"none","xmlns":"http://www.w3.org/2000/svg"},"\n  ",["path",{"fill-rule":"evenodd","clip-rule":"evenodd","d":"M8.04826 0.328338C8.35045 0.0450401 8.82507 0.0603507 9.10837 0.362535L13.4173 4.95873C13.6878 5.24722 13.6878 5.69615 13.4173 5.98464L9.10837 10.5808C8.82507 10.883 8.35045 10.8983 8.04826 10.615C7.74608 10.3317 7.73077 9.85711 8.01407 9.55492L10.9733 6.39844H5.12988C3.33496 6.39844 1.87988 7.85352 1.87988 9.64844V11.8755C1.87988 12.2897 1.5441 12.6255 1.12988 12.6255C0.715669 12.6255 0.379883 12.2897 0.379883 11.8755V9.64844C0.379883 7.02509 2.50653 4.89844 5.12