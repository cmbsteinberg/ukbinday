,"title":"Transport"},"\n                Transport\n            "],"\n        "],[[1,199]],["LI",{},"\n            ",["A",{"href":"/our-services/waste-and-recycling/","title":"Waste and Recycling"},"\n                Waste and Recycling\n            "],"\n        "],[[1,205]]],[[1,207]]],[[1,209]]],[[1,211]],["DIV",{"class":"dropdown"},[[1,212]],[[1,215]],[[1,216]],["DIV",{"class":"dropdown-content"},[[1,217]],["UL",{},[[1,218]],["LI",{},"\n            ",["A",{"href":"/online/book-it/","title":"Book It"},"\n                Book It\n            "],"\n        "],[[1,224]],["LI",{},"\n            ",["A",{"href":"/online/pay-it/","title":"Pay It"},"\n                Pay It\n            "],"\n        "],[[1,230]],["LI",{},"\n            ",["A",{"href":"https://my.orkney.gov.uk/","title":"My Orkney"},"\n                My Orkney\n            "],"\n        "],[[1,236]],["LI",{},"\n            ",["A",{"href":"/online/report-it/","title":"Report It"},"\n                Report It\n            "],"\n        "],[[1,242]],["LI",{},"\n            ",["A",{"href":"/online/request-it/","title":"Request It"},"\n                Request It\n            "],"\n        "],[[1,248]]],[[1,250]]],[[1,252]]],[[1,254]]],[[1,256]]],[[1,258]]]],[[1,261]]],[[1,263]],["DIV",{"class":"row content"},[[1,264]],["MAIN",{"id":"content"},[[1,265]],["DIV",{"class":"contentWrapper"},[[1,266]],[[1,267]],[[1,299]],[[1,300]],["DIV",{"class":"contentrow"},[[1,301]],["DIV",{"class":"contentcolumn","id":"contentcolumn"},[[1,302]],[[1,304]],[[1,305]],["P",{},"In an effort to increase recycling rates in the County, encourage reduced consumption and waste generation, and save on waste collection costs, we have - like the majority of all other Scottish Local Authorities, an Alternate Weekly Collection (AWC) service across the Orkney Mainland. Grey bin waste is picked up one week and recyclables in green bins and boxes the next."],[[1,308]],["DIV",{"class":"buttonTextWrapper"},[[1,309]],["P",{},["A",{"rel":"noopener","href":"https://my.orkney.gov.uk/en/AchieveForms/?form_uri=sandbox-publish://AF-Process-0c7d8834-2e50-4439-b7f5-ed313f4937f7/AF-Stage-218a9604-6ab2-4956-8b69-951a63681985/definition.json&redirectlink=%2Fen&cancelRedirectLink=%2Fen&consentMessage=yes","target":"_blank","data-anchor":"?form_uri=sandbox-publish://AF-Process-0c7d8834-2e50-4439-b7f5-ed313f4937f7/AF-Stage-218a9604-6ab2-4956-8b69-951a63681985/definition.json&redirectlink=%2Fen&cancelRedirectLink=%2Fen&consentMessage=yes"},"Request an assisted, additional or alternative domestic collection"],"  ",["A",{"href":"/online/request-it/","title":"Request It"},"Request a new bin"],"  ",["A",{"href":"https://my.orkney.gov.uk/en/AchieveForms/?form_uri=sandbox-publish://AF-Process-410cb8b9-8b31-4539-bd95-8d3001d581a5/AF-Stage-3cb25e22-1d7d-43dc-a178-3da5db80ce27/definition.json&redirectlink=/en&cancelRedirectLink=/en&noLoginPrompt=1&accept=yes&consentMessageIds%5b%5d=9","data-anchor":"?form_uri=sandbox-publish://AF-Process-410cb8b9-8b31-4539-bd95-8d3001d581a5/AF-Stage-3cb25e22-1d7d-43dc-a178-3da5db80ce27/definition.json&redirectlink=/en&cancelRedirectLink=/en&noLoginPrompt=1&accept=yes&consentMessageIds%5b%5d=9"},"Request a special collections"]],[[1,319]]],[[1,321]],[[1,323]],[[1,324]],["P",{},"Every household (paying Council Tax) is entitled to 1 grey refuse bin and 2 green recycling bins (with or without internal caddies for separation of recyclates). The ‘Wheelie Bin Allocation’ guide at the bottom of this page in the ‘Related Downloads’ section, gives further information on the bins provided."],[[1,327]],[[1,329]],[[1,330]],["P",{},"The ‘Bin Collection Guide – Mainland’ document in the ‘Related Downloads’ section of this gives information on how to present your bins on the collection day."],[[1,333]],["P",{},"If a bin store is used, please ensure that all relevant bins are out of the bin store and presented for collection at the kerbside by 08:00 on the day of collection."],[[1,336]],[[1,338]],[[1,339]],["UL",{},[[1,340]],["LI",{},"You can use our ",["A",{"href":"/our-services/waste-and-recycling/household-waste-and-recycling/","title":"Household Waste and Recycling"},"MyBins online search tool"]," to find out when and what is being collected in your area. "],[[1,346]],["LI",{},"Maps for the East and West Mainland are also available in PDF format from the 'Related Downloads' section of this page, graphically summarising the collection areas."],[[1,349]],["LI",{},"Please remember, your bins/bags need to be put out at the collection point by 8am."],[[1,352]]],[[1,354]],[[1,356]],[[1,357]],["P",{},"If you need help with:"],[[1,360]],["UL",{},[[1,361]],["LI",{},"An additional refuse bin - Properties no more than 75 metres from the collection point are provided with 1 grey refuse bin and up to 2 recycling bins. Households can apply for additional capacity if they feel the bins or bags are not sufficient. Residents can also request extra or larger recycling bins/ boxes and bags provided that they have the storage capacity and are presenting additional recyclates for collection on a regular basis."],[[1,364]],["LI",{},"An alternative collection method - For those properties over 75 metres from the collection point or for those who may have storage problems, an annual allocation of up to 75 red bags and a box / 3 bags for recycling can be provided."],[[1,367]],["LI",{},"An assisted waste collection - Assisted Waste Collections can be provided to those who need help, such as the elderly or those with mobility restrictions. Home visits or telephone contact may be carried out as required to determine whether and/or how assisted collections can be performed. ",["A",{"rel":"noopener","href":"https://my.orkney.gov.uk/en/AchieveForms/?form_uri=sandbox-publish://AF-Process-0c7d8834-2e50-4439-b7f5-ed313f4937f7/AF-Stage-218a9604-6ab2-4956-8b69-951a63681985/definition.json&redirectlink=%2Fen&cancelRedirectLink=%2Fen&consentMessage=yes","target":"_blank","data-anchor":"?form_uri=sandbox-publish://AF-Process-0c7d8834-2e50-4439-b7f5-ed313f4937f7/AF-Stage-218a9604-6ab2-4956-8b69-951a63681985/definition.json&redirectlink=%2Fen&cancelRedirectLink=%2Fen&consentMessage=yes"},"Complete our assisted collection form to request this"],"."],[[1,373]]],[[1,375]],["P",{},"If you have any questions or concerns regarding the collection and disposal of Household waste on mainland Orkney, please phone 01856873535 or ",["A",{"href":"mailto:nsi@orkney.gov.uk"},"drop us an email"],". ",["A",{"href":"mailto:developmentandinfrastructure@orkney.gov.uk"},"developmentandinfrastructure@orkney.gov.uk"],"."],[[1,384]],[[1,386]],[[1,387]],["P",{},"If you have any comments or questions regarding the provision of household clinical waste collection, e.g. used syringes, drugs and pharmaceuticals, and disposal services, please contact Development and Infrastructure, Waste Team on Telephone: 01856873535."],[[1,390]],[[1,392]],[[1,393]],["P",{},"Orkney Islands Council does not empty septic tanks or cesspits.  Scottish Water provide this service and can be contacted via their website, available from 'Related Sites' section of this page."],[[1,396]],[[1,398]],[[1,399]],["P",{},"Orkney Islands Council does not offer skips for hire. However, they are available to hire from Orkney Aggregates, who are contactable on 01856871187.  It is the responsibility of the skip hirer to dispose of the contents safely and responsibly. A skip permit may also be required."],[[1,402]],[[1,404]],[[1,405]],["P",{},"If you propose to occupy or open part of a road, i.e. carriageway, footway, footpath or cycle path etc, there is a requirement under the Roads (Scotland) Act 1984 to obtain permission from the local Roads Authority.  This is done by applying for the relevant permit. For further details please contact Development and Infrastructure on telephone 01856873535."],[[1,408]],["P",{},"Links to websites are available from the 'Related Sites' section of this page."],[[1,411]]],[[1,413]],[[1,581]],[[1,582]],[[1,583]],[[1,588]],[[1,589]]],[[1,591]]],[[1,593]]],[[1,595]]],[[1,597]],["DIV",{"class":"row footer"},[[1,598]],["FOOTER",{"aria-hidden":"false","aria-label":"Page Footer","class":"newRegion1"},["DIV",{"class":"footerWrapper"},[[1,599]],["DIV",{"class":"footerCol"},[[1,600]],["P",{},"School Place, Kirkwall, Orkney, KW15 1NY | ",["A",{"href":"tel:01856873535","class":"footerLink"},"01856 873535"]," |",["SPAN",{}," "],["A",{"href":"https://www-orkney-gov-uk.translate.goog/?_x_tr_sl=auto&_x_tr_tl=en&_x_tr_hl=en&_x_tr_pto=wapp","title":"Link to Google Translate","class":"footerLink","data-anchor":"?_x_tr_sl=auto&_x_tr_tl=en&_x_tr_hl=en&_x_tr_pto=wapp"},"Translate"],["SPAN",{}," | "],["A",{"href":"/online/web-guide/accessibility/","title":"accessibility.htm","class":"footerLink"},"Accessibility"],["SPAN",{}," | "],["A",{"href":"https://www.nationalarchives.gov.uk/doc/open-government-licence/version/3/","class":"footerLink"},"Copyright"],["SPAN",{}," | "],["A",{"href":"/privacy/","class":"footerLink"},"Privacy"]],[[1,622]],[[1,626]],[[1,627]]],[[1,629]]]],[[1,632]]],[[1,634]],[[1,635]],[[1,636]],[[1,637]],[[1,638]],[[1,639]],"\n\n\n"]]],"viewport":{"width":800,"height":461},"timestamp":32340.501,"wallTime":1753093528175,"collectionTime":1.800000000745058,"resourceOverrides":[],"isMainFrame":true}}
