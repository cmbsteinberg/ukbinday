":"position","content":"1"}]],["LI",{"class":"inline even","property":"itemListElement","typeof":"ListItem"},["A",{"property":"item","typeof":"WebPage","href":"https://my.northtyneside.gov.uk/category/80/rubbish-and-recycling"},["SPAN",{"property":"name"},"Rubbish and recycling"]],["SPAN",{"class":"breadcrumb-divider","aria-hidden":"true"},"/"],["META",{"property":"position","content":"2"}]],["LI",{"class":"inline odd last","property":"itemListElement","typeof":"ListItem"},["SPAN",{"property":"name"},"What goes in my bins?"],["META",{"property":"position","content":"3"}]]],"\n      ",["SPAN",{"id":"main-content","tabindex":"-1"},["SPAN",{"class":"hidden"},"Main content"]],"\n\n      \n      \n        \n          ",["H1",{"class":"page-header"},"\n\n        \n\n        What goes in my bins?"],"\n\n      \n\n      \n      \n      \n        \n      \n\n      \n\n      \n\n        ",["DIV",{},"\n                \n    \n                        ",["SECTION",{"id":"block-system-main","class":"block block-system clearfix"},"\n\n      \n  ",["DIV",{"class":"bootstrap-twocol-stacked","id":"web-drupal-content"},"\n  ",["DIV",{"class":"row"},"\n      "],"\n  ",["DIV",{"class":"row"},"\n    ",["DIV",{"class":"panel-panel left col-sm-8"},["DIV",{"class":"panel-pane pane-views-panes pane-ntc-category-content-panel-content-full in-full web-content ","id":"web-drupal-content-main"},"\n  \n      \n  \n  ",["DIV",{"class":"pane-content"},"\n    ",["DIV",{"class":"view view-ntc-category-content view-id-ntc_category_content view-display-id-panel_content_full view-dom-id-fcc60c6ef26b640334329599030c1f4a"},"\n        \n  \n  \n      ",["DIV",{"class":"view-content"},"\n        ",["DIV",{"class":"views-row views-row-1 views-row-odd views-row-first views-row-last"},"\n    ",["DIV",{"id":"node-4018","class":"node node-web-page node-sticky view-mode-full clearfix","about":"/page/4018/what-goes-my-bins","typeof":"sioc:Item foaf:Document"},["DIV",{"class":"sectionList"},["H2",{},"Contents"],["UL",{},["LI",{"class":"scrollControl"},["SPAN",{"class":"sectionText"},"Grey bins (recycling)"]],["LI",{"class":"scrollControl"},["SPAN",{"class":"sectionText"},"Brown bins (garden waste)"]],["LI",{"class":"scrollControl"},["SPAN",{"class":"sectionText"},"Green bins (rubbish)"]]]],"\n  \n  ",["SPAN",{"property":"dc:title","content":"What goes in my bins?","class":"rdf-meta element-hidden"}],["SPAN",{"property":"sioc:num_replies","content":"0","datatype":"xsd:integer","class":"rdf-meta element-hidden"}],"\n  \n  ",["DIV",{"class":"content"},"\n    \n  ",["SECTION",{"class":"field field-name-body field-type-text-with-summary field-label-hidden"},"\n    ",["P",{},"For information about how to dispose of lots of household items, such as beds, cardboard etc please refer to our ",["A",{"href":"/category/895/z-rubbish"},"A-Z of rubbish"],"."],"\n  "],"\n\n  ",["SECTION",{"class":"field field-name-field-page-section field-type-entityreference field-label-hidden"},"\n    \n\n",["DIV",{"about":"/node/4017","typeof":"sioc:Item foaf:Document","class":"node node-web-page-section view-mode-full"},"\n    ",["DIV",{"class":"row"},"\n    ",["DIV",{"class":"col-sm-12 "},"\n      ",["DIV",{"class":"field field-name-title field-type-ds field-label-hidden"},["DIV",{"class":"field-items"},["DIV",{"class":"field-item even","property":"dc:title"},["H2",{},"Grey bins (recycling)"]]]],"\n  ",["DIV",{"class":"field field-name-body field-type-text-with-summary field-label-hidden"},"\n    ",["P",{},"Your grey bin is for recycling only. It won't be collected if it contains rubbish."],"\n",["P",{},"Your recycling is collected once a fortnight, on the same day as rubbish collections but at a different time of day, in a grey wheeled bin with a caddy in the top."],"\n",["P",{},"Please use the caddy for:"],"\n",["UL",{},"\n",["LI",{},"glass bottles and jars (no window glass, no pyrex)"],"\n",["LI",{},"if you've more glass than will fit in the caddy please use your nearest recycling site - or save it until the next collection"],"\n",["LI",{},"please do not remove your caddy - for safety reasons it won't be collected unless it is in the bin"],"\n"],"\n",["P",{},"You may use the main part of the bin for:"],"\n",["UL",{},"\n",["LI",{},"cardboard (please flatten)"],"\n",["LI",{},"newspapers, magazines, junk mail and envelopes"],"\n",["LI",{},"shredded paper (must be in a bag, no black bags please)"],"\n",["LI",{},"telephone directories (including yellow pages)"],"\n",["LI",{},"catalogues (no hard backs please)"],"\n",["LI",{},"plastic bottles, pop, squash, milk, sauces, toiletries, household cleaners (please wash and squash items)"],"\n",["LI",{},"drinks cans and food tins, including pet food tins (please wash and squash items)"],"\n",["LI",{},"tetrapaks, e.g. juice cartons (please wash and squash items)"],"\n",["LI",{},"aerosols"],"\n",["LI",{},"plastic pots, tubs and trays, e.g. margarine tubs, yoghurt pots, punnets and food trays (wash and squash items)"],"\n"],"\n",["P",{},"Please do not use your grey bin for:"],"\n",["UL",{},"\n",["LI",{},"black plastic items, e.g. food trays, plastic bottles and yoghurt lids"],"\n",["LI",{},"plastic films (cling film, bread wrappers, crisp packets, biscuit wrappers, vegetable wrappings, frozen foods, magazine wrappings)"],"\n",["LI",{},"hard plastics (toys, kitchenware, electrical plugs, CD and DVD cases, stationery)"],"\n",["LI",{},"textiles (no clothing or bedding please)"],"\n",["LI",{},"Polystyrene"],"\n",["LI",{},"batteries - many retailers and supermarkets have battery disposal points so please take your batteries to these points."],"\n"],"\n",["P",{},"If you would like to reduce the junk mail you receive please contact the ",["A",{"href":"http://www.mpsonline.org.uk/mpsr/","target":"_blank"},"Mailing Preference Service"],"."],"\n",["P",{},"For ways to recycle additional resources please check out:"],"\n",["UL",{},"\n",["LI",{},["A",{"href":"http://www.fill-your-pants.com/councilnappyincentives.html","target":"_blank"},"Real nappy incentives scheme"]],"\n",["LI",{},["A",{"href":"http://recyke-y-bike.org/","target":"_blank"},"Recyke y’Bike"],"​"],"\n",["LI",{},["A",{"href":"https://www.ilovefreegle.org/","target":"_blank"},"Freegle UK"]],"\n"],"\n  "],"\n    "],"\n  "],"\n"],"\n\n\n","\n  "],"\n  ",["SECTION",{"class":"field field-name-field-page-section field-type-entityreference field-label-hidden"},"\n    \n\n",["DIV",{"about":"/node/4026","typeof":"sioc:Item foaf:Document","class":"node node-web-page-section view-mode-full"},"\n    ",["DIV",{"class":"row"},"\n    ",["DIV",{"class":"col-sm-12 "},"\n      ",["DIV",{"class":"field field-name-title field-type-ds field-label-hidden"},["DIV",{"class":"field-items"},["DIV",{"class":"field-item even","property":"dc:title"},["H2",{},"Brown bins (garden waste)"]]]],"\n  ",["DIV",{"class":"field field-name-body field-type-text-with-summary field-label-hidden"},"\n    ",["P",{},"A household garden waste collection service operates in North Tyneside."],"\n",["P",{},"Your brown bin is for garden waste only - your bin won't be collected if it's contaminated with other waste or too heavy."],"\n",["P",{},"Make sure your brown bin is located in the same place you'd normally leave your refuse bin by 6.30am on collection day."],"\n",["P",{},"Use your brown bin for:"],"\n",["UL",{},"\n",["LI",{},"grass cuttings"],"\n",["LI",{},"small tree prunings"],"\n",["LI",{},"dead flowers and house plants"],"\n",["LI",{},"leaves and weeds"],"\n"],"\n",["P",{},"Please don't use your brown bin for:"],"\n",["UL",{},"\n",["LI",{},"plastic bags"],"\n",["LI",{},"plant containers"],"\n",["LI",{},"rubble and gravel"],"\n",["LI",{},"tree trunks and large branches"],"\n",["LI",{},"soil"],"\n",["LI",{},"tools"],"\n",["LI",{},"food or animal waste"],"\n",["LI",{},"pesticides"],"\n",["LI",{},"turf"],"\n"],"\n",["P",{},"Rather than putting your garden waste and some kitchen waste in your brown bin have you thought about ",["A",{"href":"/category/86/composting"},"composting"],"?"],"\n  "],"\n    "],"\n  "],"\n"],"\n\n\n","\n  "],"\n  ",["SECTION",{"class":"field field-name-field-page-section field-type-entityreference field-label-hidden"},"\n    \n\n",["DIV",{"about":"/node/4016","typeof":"sioc:Item foaf:Document","class":"node node-web-page-section view-mode-full"},"\n    ",["DIV",{"class":"row"},"\n    ",["DIV",{"class":"col-sm-12 "},"\n      ",["DIV",{"class":"field field-name-title field-type-ds field-label-hidden"},["DIV",{"class":"field-items"},["DIV",{"class":"field-item even","property":"dc:title"},["H2",{},"Green bins (rubbish)"]]]],"\n  ",["DIV",{"class":"field field-name-body field-type-text-with-summary field-label-hidden"},"\n    ",["P",{},"Put your household rubbish, food waste and any items that cannot be recycled in your green bin."],"\n",["P",{},"Remember:"],"\n",["UL",{},"\n",["LI",{},"we'll collect your rubbish in your wheeled bin once a fornight"],"\n",["LI",{},"collections will be Tuesday to Friday"],"\n",["LI",{},"please place your bin at the kerbside no later than 6.30am on collection day"],"\n",["LI",{},"make sure your rubbish is in the bin - no extra bags will be collected"],"\n",["LI",{},"make sure you don't over fill your bin - if it's too heavy it can't be lifted by the vehicle"],"\n",["LI",{},"don't put your rubbish out for collection any earlier than the evening before your normal collection day"],"\n",["LI",{},"collections aren't affected by bank holidays except at Christmas and New Year"],"\n"],"\n  "],"\n    "],"\n  "],"\n"],"\n\n\n","\n  "],"\n  "],"\n\n    \n"],"\n  "],"\n    "],"\n  \n  \n  \n  \n  \n  \n"],"  "],"\n\n  \n  "],"\n"],"    ",["DIV",{"class":"panel-panel right col-sm-4"},["DIV",{"class":"panel-pane pane-views-panes pane-ntc-category-navigation-panel-cat-navigation-others interest panel"},"\n  \n        ",["H2",{"class":"pane-title"},"\n      Also of interest:    "],"\n    \n  \n  ",["DIV",{"class":"pane-content"},"\n    ",["DIV",{"class":"view view-ntc-category-navigation view-id-ntc_cate