ainer block block-views block-views-block--content-published-information-block-1"},"\n  ",["DIV",{},["DIV",{"class":"content-authored-information-block view-id-content-published-information view-display-id-block-1 js-view-dom-id-1bb0aee18134b95ff968523ac669b704003f38c87d287d69f55b253c1105cbf7"},"\n  \n  \n  \n\n  \n  \n  \n\n  ",["DIV",{},["SPAN",{"class":"views-field views-field-created"},["SPAN",{"class":"views-label views-label-created"},"Published"],["SPAN",{"class":"field-content"},["TIME",{"datetime":"2022-12-15T11:02:17+00:00"},"15 December 2022"],"\n"]],["DIV",{"class":"views-field views-field-revision-timestamp"},["SPAN",{"class":"views-label views-label-revision-timestamp"},"Last updated"],["SPAN",{"class":"field-content"},["TIME",{"datetime":"2025-06-03T15:17:06+01:00"},"03 June 2025"],"\n"]]],"\n    \n\n  \n  \n\n  \n  \n"],"\n"],"\n"],"\n\n    "],"\n  "],"\n\n  ",["DIV",{"class":"layout layout--twocol-section layout--twocol-section--67-33 govuk-grid-row"},"\n\n          ",["DIV",{"class":"layout__region layout__region--first"},"\n        ",["DIV",{"class":"block block-layout-builder block-field-block--node--basic-page--body"},"\n  \n            ",["DIV",{"class":"field field--name-body field--type-text-with-summary field--label-hidden"},"\n",["P",{},"Use our online tool to find or check your bin collection days:"],"\n\n\n\n",["DIV",{"class":"wp-block-buttons"},"\n",["DIV",{"class":"wp-block-button"},["A",{"class":"wp-block-button__link","href":"https://waste.nc.north-herts.gov.uk/w/webpage/find-bin-collection-day-input-address"},"Find your bin collection day"]],"\n"],"\n\n\n\n",["P",{},"Rubbish bins and recycling containers are collected on alternate weeks. Food waste is collected weekly."],"\n\n\n\n",["H2",{"id":"on-the-day"},"On the day"],"\n\n\n\n",["P",{},"On your collection day please make sure:"],"\n\n\n\n",["UL",{},["LI",{},"your containers are out by 7am"],["LI",{},"your containers are placed at the front boundary of your property"],["LI",{},"your rubbish bin does not have anything in it which could be recycled"],["LI",{},"the bin lids are closed"]],"\n\n\n\n",["P",{},["A",{"href":"/what-goes-each-bin","data-type":"basic_page","data-id":"1192"},"Check what goes in each bin here"],"."],"\n\n\n\n",["H2",{"id":"fullbin"},"If your bin is full"],"\n\n\n\n",["P",{},["STRONG",{},"Grey bin:"]," If your grey bin is full you can put extra recycling in a recyclable container e.g. cardboard box or paper bag next to your grey bin, on your usual collection day. The whole container and contents will then be recycled. If you use a non-recyclable container (e.g. plastic storage boxes or old recycling box) the contents will be emptied and the container left. Please do not use plastic carrier bags."],"\n\n\n\n",["P",{},["STRONG",{},"Purple bin:"]," We do not accept additional general waste next to your purple rubbish bin. Extra non-recyclable waste can be taken to your nearest ",["A",{"href":"/recycling-centres","data-type":"basic_page","data-id":"1179"},"Household Waste Recycling Centre"],"."],"\n\n\n\n",["P",{},["STRONG",{},"Brown food caddy:"]," Households with six or more permanent and full time residents can request a second outdoor brown food caddy. Call us on 01462 474000 and choose the waste option to apply, or use the ",["A",{"href":"/request-new-replacement-or-larger-bin","data-type":"basic_page","data-id":"125529"},"extra waste capacity application form here"],"."],"\n\n\n\n",["H2",{"id":"missed-bin"},"Missed bin"],"\n\n\n\n",["P",{},"If you think your bin should have been emptied but wasn't, you can ",["A",{"href":"/report-missed-bin","data-type":"[EN] basic_page","data-id":"1174"},"report a missed bin here"],"."],"\n"],"\n      "],"\n\n      "],"\n    \n          ",["DIV",{"class":"layout__region layout__region--second"},"\n        ",["DIV",{"class":"block block-book block-book-navigation"},["H2",{"id":"in-this-section"},"In this section"],"\n  \n        ",["UL",{"class":"cp-book cp-book--bullets"},"\n          