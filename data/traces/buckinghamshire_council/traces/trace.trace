e7js"},"broken toys"],["LI",{"data-block-key":"2bruj"},"crisps, sweet and biscuit wrappers"],["LI",{"data-block-key":"4dfe7"},"empty paint tins"],["LI",{"data-block-key":"d2ndq"},"nappies and sanitary products"],["LI",{"data-block-key":"9gosi"},"pet bedding and litter"],["LI",{"data-block-key":"4hkpi"},"plant pots"],["LI",{"data-block-key":"3ljlc"},"plastic bags and wrappers"],["LI",{"data-block-key":"ebjq0"},"polystyrene trays, cups and packaging"],["LI",{"data-block-key":"2rid4"},"toothpaste tubes"]]],"\n    \n\n    \n        ",["H3",{"class":"heading heading--m","id":"what-you-cant-put-in-your-general-household-waste-bin"},"What you can't put in your general household waste bin"],"\n\n    \n\n    \n        ",["DIV",{"class":"rich-text"},["P",{"data-block-key":"6sevl"},"Do not put these items in the bin as they can be dangerous:"],["UL",{},["LI",{"data-block-key":"e1tfm"},"batteries - put these in a tied clear bag on top of your bin"],["LI",{"data-block-key":"77jpn"},"gas bottles - take these to a recycling centre"],["LI",{"data-block-key":"8k91q"},"electrical appliances - these can be recycled"],["LI",{"data-block-key":"8r932"},"car batteries - take these to a recycling centre"],["LI",{"data-block-key":"2l7lo"},"sharps, needles or syringes - use our clinical waste service"]],["P",{"data-block-key":"unt7"},"Check what you can take to a ",["A",{"href":"https://www.buckinghamshire.gov.uk/bin-collection-recycling-and-waste/household-recycling-centres/"},"household recycling centre"],"."]],"\n    \n\n\n            "],"\n        "],"\n    \n        ",["DIV",{"class":"accordion","data-accordion":""},"\n            ",["H3",{"class":"accordion__header"},"\n                ",["BUTTON",{"id":"question-20a240bb-c060-4fc6-b020-4ef8bc046645-2","class":"accordion__button","data-accordion-question":"","aria-controls":"answer-20a240bb-c060-4fc6-b020-4ef8bc046645-2","aria-expanded":"false"},"\n                    \n",["svg",{"class":"icon icon-chevron icon--stroke accordion__icon"