span style=\"color: #000080;\"><strong><span style=\"font-size: 12pt;\">Retrieving waste and recycling calendar details, please wait...</span></strong></span></div>","data-display-condition":"{nauprn} != '' and {CountGarden} = ''"}],["DIV",{"class":"screen-reader-error","aria-live":"polite","aria-atomic":"true"}]]," "],["DIV",{"class":"field","data-field-name":"statictext6","data-field-type":"html","style":"display: none;"},["DIV",{"class":"fieldContent"},"\t",["SPAN",{"data-name":"statictext6","data-type":"html","class":"col-xs-11 col-sm-11 conditional fieldInput content html non-input ","data-content":"<div style=\"text-align: center;\"><span style=\"color: #000080;\"><strong><span style=\"font-size: 12pt;\">No Scheduled collections found. This is normally due to the property being a commercial premises or served by a communal Waste and Recycling collection.</span></strong></span></div>","data-display-condition":"{CountGarden} contains 0 and {CountGeneral} contains 0 and {CountRecycling} contains 0"}],["DIV",{"class":"screen-reader-error","aria-live":"polite","aria-atomic":"true"}]]," "],["DIV",{"class":"field","data-field-name":"autolookup1","data-field-type":"autoLookup","style":"display: none;"},["DIV",{"class":"fieldContent"},"\t",["DIV",{"data-name":"autolookup1","data-type":"autoLookup","class":"conditional fieldInput non-input autoLookup ","data-lookup":"583c08ffc47fe","data-display-condition":"{selectProperty} != ''"}],["DIV",{"class":"screen-reader-error","aria-live":"polite","aria-atomic":"true"}]]," "],["DIV",{"class":"field","data-field-name":"autolookup4","data-field-type":"autoLookup","style":"display: none;"},["DIV",{"class":"fieldContent"},"\t",["DIV",{"data-name":"autolookup4","data-type":"autoLookup","class":"conditional fieldInput non-input autoLookup ","data-lookup":"58b9561ad7d88","data-display-condition":"{nauprn} != ''"}],["DIV",{"class":"screen-reader-error","aria-live":"polite","aria-atomic":"true"}]]," "],["DIV",{"class":"field","data-field-name":"autolookup2","data-field-type":"autoLookup","style":"display: none;"},["DIV",{"class":"fieldContent"},"\t",["DIV",{"data-name":"autolookup2","data-type":"autoLookup","class":"conditional fieldInput non-input autoLookup ","data-lookup":"5a3141caf4016","data-display-condition":"{token} != '' and {nauprn} != ''"}],["DIV",{"class":"screen-reader-error","aria-live":"polite","aria-atomic":"true"}]]," "],["DIV",{"class":"field","data-field-name":"statictext1","data-field-type":"html","style":"display: none;"},["DIV",{"class":"fieldContent"},"\t",["SPAN",{"data-name":"statictext1","data-type":"html","class":"col-xs-11 col-sm-11 conditional fieldInput content html non-input ","data-content":"<script type=\"text/javascript\" charset=\"utf-8\">\nfunction hidebins() {\nif ( document.getElementsByName(\"CountRecycling\")[0].value == 0) {\ndocument.getElementById(\"RecyclingHide\").style.display = 'none';\n} else {\ndocument.getElementById('RecyclingHide').style.display = 'block';\n}\nif ( document.getElementsByName(\"CountGeneral\")[0].value == 0) {\ndocument.getElementById(\"GeneralHide\").style.display = 'none';\n} else {\ndocument.getElementById('GeneralHide').style.display = 'block';\n}\nreturn false;\n}\nhidebins();\n</script>\n<style><!--\nimg {\nheight: 100%;\nwidth: 100%;\n}\n\n.divTable{\ndisplay: table;\nwidth: 100%;\nmax-width: 800px;\nborder-collapse: collapse;\nmargin: 0 auto;\ntable-layout:fixed\nborder: 1px solid #ddd;\n}\n\n.divTableRow {\ndisplay: table-row;\nfloat: left;\nwidth: (100%)/3;\nborder: 1px solid #ddd;\nmin-width: 150px;\nalign: centre;\n}\n\n.divTableCell, .divTableHead {\nborder: 1px solid #999999;\ndisplay: table-cell;\npadding: 3px 10px;\ntext-align: center;\ndisplay: block;\n}\n\n.divTableHeading {\ndisplay: table-header-group;\nfont-weight: bold;\n}\n.divTableFoot {\nbackground-color: #EEE;\ndisplay: table-footer-group;\nfont-weight: bold;\n}\n.divTableBody {\ndisplay: table-row-group;\n}\n\n.text {\npadding: 3px 10px;\n}\n--></style>\n<div id=\"wrapper\">\n<div class=\"divTable\">\n<div class=\"divTableHeading\"><span style=\"font-size: 18pt;\">{selectProperty:display}</span></div>\n<div id=\"RecyclingHide\">\n<div class=\"divTableRow\">\n<div class=\"divTableCell\"><img\nsrc=\"data:image/jpeg;base64,\"></div>\n<div style=\"color: rgb(0, 0, 102);\" class=\"divTableCell\">\n<div><strong><span style=\"font-size: 14pt;\">Mixed Recycling Bin</span></strong></div>\n</div>\n<div class=\"divTableCell\">\n<div class=\"text\"><strong><span style=\"font-size: 12pt;\">{RecyclingDate1}</span></strong></div>\n<div class=\"text\"><strong><span style=\"font-size: 12pt;\">{RecyclingDate2}</span></strong></div>\n<div class=\"text\"><strong><span style=\"font-size: 12pt;\">{RecyclingDate3}</span></strong></div>\n<div class=\"text\"><strong><span style=\"font-size: 12pt;\">{RecyclingDate4}</span></strong></div>\n<div class=\"text\"><strong><span style=\"font-size: 12pt;\">{RecyclingDate5}</span></strong></div>\n<div class=\"text\"><strong><span style=\"font-size: 12pt;\">{RecyclingDate6}</span></strong></div>\n<div class=\"text\"><strong><span style=\"font-size: 12pt;\">{RecyclingDate7}</span></strong></div>\n<div class=\"text\"><strong><span style=\"font-size: 12pt;\">{RecyclingDate8}</span></strong></div>\n</div>\n</div>\n</div>\n<div class=\"divTableRow\">\n<div class=\"divTableCell\"><img\nsrc=\"data:image/jpeg;base64,\"></div>\n<div style=\"color: rgb(0, 0, 102);\" class=\"divTableCell\">\n<div><strong><span style=\"font-size: 14pt;\">Food and Garden Bin</span></strong></div>\n</div>\n<div class=\"divTableCell\">\n<div class=\"text\"><strong><span style=\"font-size: 12pt;\">{GardenDate1}</span></strong></div>\n<div class=\"text\"><strong><span style=\"font-size: 12pt;\">{GardenDate2}</span></strong></div>\n<div class=\"text\"><strong><span style=\"font-size: 12pt;\">{GardenDate3}</span></strong></div>\n<div class=\"text\"><strong><span style=\"font-size: 12pt;\">{GardenDate4}</span></strong></div>\n<div class=\"text\"><strong><span style=\"font-size: 12pt;\">{GardenDate5}</span></strong></div>\n<div class=\"text\"><strong><span style=\"font-size: 12pt;\">{GardenDate6}</span></strong></div>\n<div class=\"text\"><strong><span style=\"font-size: 12pt;\">{GardenDate7}</span></strong></div>\n<div class=\"text\"><strong><span style=\"font-size: 12pt;\">{GardenDate8}</span></strong></div>\n</div>\n</div>\n<div id=\"GeneralHide\">\n<div class=\"divTableRow\">\n<div class=\"divTableCell\"><img\nsrc=\"data:image/jpeg;base64,\"></div>\n<div style=\"color: rgb(0, 0, 102);\" class=\"divTableCell\">\n<div><strong><span style=\"font-size: 14pt;\">General Waste Bin</span></strong></div>\n</div>\n<div class=\"divTableCell\">\n<div class=\"text\"><strong><span style=\"font-size: 12pt;\">{GeneralDate1}</span></strong></div>\n<div class=\"text\"><strong><span style=\"font-size: 12pt;\">{GeneralDate2}</span></strong></div>\n<div class=\"text\"><strong><span style=\"font-size: 12pt;\">{GeneralDate3}</span></strong></div>\n<div class=\"text\"><strong><span style=\"font-size: 12pt;\">{GeneralDate4}</span></strong></div>\n<div class=\"text\"><strong><span style=\"font-size: 12pt;\">{GeneralDate5}</span></strong></div>\n<div class=\"text\"><strong><span style=\"font-size: 12pt;\">{GeneralDate6}</span></strong></div>\n<div class=\"text\"><strong><span style=\"font-size: 12pt;\">{GeneralDate7}</span></strong></div>\n<div class=\"text\"><strong><span style=\"font-size: 12pt;\">{GeneralDate8}</span></strong></div>\n</div>\n</div>\n</div>\n</div>\n</div>","data-display-condition":"({CountGarden} > 0 or {CountGeneral} > 0 or {CountRecycling} > 0)"}],["DIV",{"class":"screen-reader-error","aria-live":"polite","aria-atomic":"true"}]]," "],["DIV",{"class":"field","data-field-name":"statictext4","data-field-type":"html","style":"display: none;"},["DIV",{"class":"fieldContent"},"\t",["SPAN",{"data-name":"statictext4","data-type":"html","class":"col-xs-11 col-sm-11 conditional fieldInput content html non-input ","data-content":"<script type=\"text/javascript\" charset=\"utf-8\">\nfunction redirect(attachment) {\nif (attachment == 'pdf') {\nwindow.open('https://fs-filestore-eu.s3.amazonaws.com/Aberdeen/Waste/' + {calendarName} + '.pdf','_blank');\n} else {\nwindow.open('https://fs-filestore-eu.s3.amazonaws.com/Aberdeen/Waste/calReminder' + {calendarName} + '.ics','_blank');\n}\nreturn;\n}\n</script>\n<style><!--\n.Border3{border-radius:25px;background:#FFFFCC;border: 5px solid #FFA833;padding:12px;}\n.list{ font-weight:bold; margin-top: 1em; margin-bottom:1em;}\n--></style>\n<div class=\"Border3\">\n<p class=\"mobile-hide\">This\ncalendar shows your next scheduled collection days. <span>Remember to\nput your bins out by 7am on the collection day</span>. <br>\n<br>\nCheck what you can put in your <a\nhref=\"http://www.aberdeencity.gov.uk/waste/waste_recycling/waste_recycling_kerbside.asp\"\ntarget=\"_blank\">mixed recycling bin</a> and your <a\nhref=\"http://www.aberdeencity.gov.uk/waste/waste_recycling/waste_recycling_brown_bin.asp\"\ntarget=\"_blank\">food and garden waste recycling bin</a>. <span>Please\ndon’t put the wrong materials in your bin as we may not be able to\nempty it if you do.</span></p>\n<p>In exceptional circumstances we may not be able to empty your bins\nas scheduled. If this happens we will let you know of any changes\nthrough the local media, Council website or social media.</p>\n\n<h3><a href=\"javascript:redirect('pdf');\">Download Collection Calendar</a></h3>\n<p>Download a PDF of your collection calendar that you can save or\nprint.</p>\n<!--<h3><a href=\"javascript:redirect('ics');\">Download\nCollection Reminder for a Calendar on Your\nDesktop or Mobile Device</a></h3>\n<p>Depending on the capabilities of the calendar application or app on\nyour desktop, laptop, tablet device or smart phone this download will\nallow your device to remind you of your next collection date a day in\nadvance until the end of March. On some devices clicking the link above\nwill update the calendar automatically whereas on other devices after\nthe download you may have to open it or upload in the calendar app.</p>\n<p>The reminder is in iCalendar(.ics) file format. iCalendar is used\nand\nsupported by a large number of products. But beware that not all\ndevices support this format and some may support in part. As a result\nthis is not guaranteed to work on all calendars on all devices.\nTherefore before you try please read the instruction manual of your\ndevice calendar.</p> -->\n</div>","data-display-condition":"{CountGarden} > 0 or {CountGeneral} > 0 or {CountRecycling} > 0"}],["DIV",{"class":"screen-reader-error","aria-live":"polite","aria-atomic":"true"}]]," "],["DIV",{"class":"field fs-hidden","data-field-name":"nauprn","data-field-type":"text","style":"padding-top: 0px;"},["DIV",{"class":"fieldContent"},["LABEL",{"id":"label_nauprn","for":"nauprn","class":"col-xs-11 col-sm-4   fieldName alignLeft\t\t","style":"display: none;"},["SPAN",{"class":"_fieldName","style":"display: none;"},"UPRN"],"\t\t\t\t"],"\t",["DIV",{"class":"af-block col-xs-1 col-sm-1 hidden-sm hidden-md hidden-lg","style":"display: none;"}],["INPUT",{"__playwright_value_":"","type":"text","data-type":"text","name":"nauprn","id":"nauprn","data-name":"nauprn","aria-labelledby":"label_nauprn nauprn prefix_nauprn helpText_nauprn","readonly":"true","class":"col-xs-11 col-sm-7     fs-hidden-field alignLeft fieldInput text read_only_field ","data-hidden":"true","data-default-value":"{selectProperty:uprn}","data-output-format":"normal","data-mandatory-message":"This field is required","data-min-message":"Please input at least _min_value_ characters","data-max-message":"Please input no more than _max_value_ characters","data-validation-mask-message":"Please input text of the format: _validation_mask_","autocomplete":"off","style":"display: none;"}],["DIV",{"class":"screen-reader-error","aria-live":"polite","aria-atomic":"true","style":"display: none;"}]]," "],["