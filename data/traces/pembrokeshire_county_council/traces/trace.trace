 "],"\n\n    ",["LI",{"class":"col-xs-12 col-sm-6 col-md-4 col-lg-4 lev2menuItem","style":"height: 175.328px;"},"\n      ",["DIV",{"class":"col-xs-12 lev2menuItemTxt"},"\n        ",["H3",{},["A",{"href":"https://www.pembrokeshire.gov.uk/kerbside-collection"},"Kerbside collection"]],"\n        The kerbside sort recycling collection service enables an extensive range of recycling to be collected at the kerbside\n      "],"\n    "],"\n\n    ",["LI",{"class":"col-xs-12 col-sm-6 col-md-4 col-lg-4 lev2menuItem","style":"height: 131.328px;"},"\n      ",["DIV",{"class":"col-xs-12 lev2menuItemTxt"},"\n        ",["H3",{},["A",{"href":"/waste-collections/bulky-household-collections"},"Bulky Household Collection"]],"\n        If you have need to dispose of some bulky household items we can arrange that for you.\n      "],"\n    "],"\n\n    ",["LI",{"class":"col-xs-12 col-sm-6 col-md-4 col-lg-4 lev2menuItem","style":"height: 131.328px;"},"\n      ",["DIV",{"class":"col-xs-12 lev2menuItemTxt"},"\n        ",["H3",{},["A",{"href":"/home-composting"},"Home Composting"]],"\n        Fancy trying home composting?  We can help you get started and provide you with some useful advice and tips on being successful\n      "],"\n    "],"\n\n    ",["LI",{"class":"col-xs-12 col-sm-6 col-md-4 col-lg-4 lev2menuItem","style":"height: 151.656px;"},"\n      ",["DIV",{"class":"col-xs-12 lev2menuItemTxt"},"\n        ",["H3",{},["A",{"href":"/sustainable-schools"},"Sustainable Schools Award Scheme"]],"\n        The Sustainable Schools Award Scheme is about how we treat the earth and how we treat each other, no matter how far apart we live.\n      "],"\n    "],"\n\n    ",["LI",{"class":"col-xs-12 col-sm-6 col-md-4 col-lg-4 lev2menuItem","style":"height: 151.656px;"},"\n      ",["DIV",{"class":"col-xs-12 lev2menuItemTxt"},"\n        ",["H3",{},["A",{"href":"/waste-strategy"},"Municipal Waste Management Strategy"]],"\n        Towards Zero Waste is the overarching waste strategy for Wales and identifies high level principles, policies and targets.\n      "],"\n    "],"\n\n    ",["LI",{"class":"col-xs-12 col-sm-6 col-md-4 col-lg-4 lev2menuItem","style":"height: 131.328px;"},"\n      ",["DIV",{"class":"col-xs-12 lev2menuItemTxt"},"\n        ",["H3",{},["A",{"href":"/real-nappies"},"Real Nappies"]],"\n        Find out more about using Real Nappies and the cashback scheme available\n      "],"\n    "],"\n\n    ",["LI",{"class":"col-xs-12 col-sm-6 col-md-4 col-lg-4 lev2menuItem","style":"height: 131.328px;"},"\n      ",["DIV",{"class":"col-xs-12 lev2menuItemTxt"},"\n        ",["H3",{},["A",{"href":"/waste-and-recycling/recycle-on-the-go"},"Recycle on the go"]],"\n        You can now recycle your rubbish at a number of Pembrokeshire beaches. Sea, Sand and Sort provides recycling on the go facilities.\n      "],"\n    "],"\n\n    ",["LI",{"class":"col-xs-12 col-sm-6 col-md-4 col-lg-4 lev2menuItem","style":"height: 109.328px;"},"\n      ",["DIV",{"class":"col-xs-12 lev2menuItemTxt"},"\n        ",["H3",{},["A",{"href":"/waste-collections/seagull-proof-bags"},"Seagull Proof Bags"]],"\n        You can now purchase reusable seagull proof bags to protect your bins\n      "],"\n    "],"\n\n    ",["LI",{"class":"col-xs-12 col-sm-6 col-md-4 col-lg-4 lev2menuItem","style":"height: 109.328px;"},"\n      ",["DIV",{"class":"col-xs-12 lev2menuItemTxt"},"\n        ",["H3",{},["A",{"href":"https://www.pembrokeshire.gov.uk/waste-collections/garden-waste-collections"},"Garden Waste Collections"]],"\n        Collections run fortnightly from 3 March to 5 December 2025.\n      "],"\n    "],"\n\n    ",["LI",{"class":"col-xs-12 col-sm-6 col-md-4 col-lg-4 lev2menuItem","style":"height: 153.328px;"},"\n      ",["DIV",{"class":"col-xs-12 lev2menuItemTxt"},"\n        ",["H3",{},["A",{"href":"https://myrecyclingwales.org.uk/"},"Where does your recycling go?"]],"\n        My Recycling Wales allows you to browse Welsh local authorities and see what happens to your waste across the UK, and even around the world.\n      "],"\n    "],"\n\n    ",["LI",{"class":"col-xs-12 col-sm-6 col-md-4 col-lg-4 lev2menuItem","style":"height: 153.328px;"},"\n      ",["DIV",{"class":"col-xs-12 lev2menuItemTxt"},"\n        ",["H3",{},["A",{"href":"/waste-and-recycling/householders-duty-of-care"},"Householders Duty of Care"]],"\n        A duty of care applies to household, commercial and industrial waste known as controlled waste.\n      "],"\n    "],"\n\n    ",["LI",{"class":"col-xs-12 col-sm-6 col-md-4 col-lg-4 lev2menuItem","style":"height: 197.328px;"},"\n      ",["DIV",{"class":"col-xs-12 lev2menuItemTxt"},"\n        ",["H3",{},["A",{"href":"/waste-collections/food-waste-collections"},"Food Waste Collections"]],"\n        We can compost all your food waste!  Find out more about our collection service and what you can and can't put in your bin\n      "],"\n    "],"\n\n    ",["LI",{"class":"col-xs-12 col-sm-6 col-md-4 col-lg-4 lev2menuItem","style":"height: 197.328px;"},"\n      ",["DIV",{"class":"col-xs-12 lev2menuItemTxt"},"\n        ",["H3",{},["A",{"href":"/absorbent-hygiene-products"},"Absorbent Hygiene Products"]],"\n        If someone in your home uses disposable nappies or other AHPs and the property is their main place of residence, you can register for the AHP collection service to get these materials collected separately from your other waste and recycling.\n      "],"\n    "],"\n\n    ",["LI",{"class":"col-xs-12 col-sm-6 col-md-4 col-lg-4 lev2menuItem","style":"height: 153.328px;"},"\n      ",["DIV",{"class":"col-xs-12 lev2menuItemTxt"},"\n        ",["H3",{},["A",{"href":"/kerbside-collection/larger-household-allowance-terms-and-conditions"},"Larger Household Allowance"]],"\n        It is anticipated that larger households will produce greater amounts of waste and therefore will be provided with additional capacity\n      "],"\n    "],"\n\n    ",["LI",{"class":"col-xs-12 col-sm-6 col-md-4 col-lg-4 lev2menuItem","style":"height: 153.328px;"},"\n      ",["DIV",{"class":"col-xs-12 lev2menuItemTxt"},"\n        ",["H3",{},["A",{"href":"https://www.pembrokeshire.gov.uk/waste-and-recycling/get-broken-items-repaired-repair-business-directory"},"Repair Business Directory"]],"\n        Don’t throw your broken items away, get them repaired!\n      "],"\n    "],"\n\n    ",["LI",{"class":"col-xs-12 col-sm-6 col-md-4 col-lg-4 lev2menuItem","style":"height: 175.328px;"},"\n      ",["DIV",{"class":"col-xs-12 lev2menuItemTxt"},"\n        ",["H3",{},["A",{"href":"/waste-collections/two-minute-beach-clean"},"Two Minute Beach Clean"]],"\n        The aim of the #2minutebeachclean scheme is to make it easy for people to keep our beaches clean.\n      "],"\n    "],"\n\n    ",["LI",{"class":"col-xs-12 col-sm-6 col-md-4 col-lg-4 lev2menuItem","style":"height: 175.328px;"},"\n      ",["DIV",{"class":"col-xs-12 lev2menuItemTxt"},"\n        ",["H3",{},["A",{"href":"https://www.pembrokeshire.gov.uk/waste-collections/community-litter-picking-hubs"},"Community Litter Picking Hubs"]],"\n        There are seven Litter picking hubs operating across the County. They allow general public, community groups and businesses to borrow litter picking equipment to help clean up their local area.\n      "],"\n    "],"\n\n    ",["LI",{"class":"col-xs-12 col-sm-6 col-md-4 col-lg-4 lev2menuItem","style":""},"\n      ",["DIV",{"class":"col-xs-12 lev2menuItemTxt"},"\n        ",["H3",{},["A",{"href":"https://www.pembrokeshire.gov.uk/waste-and-recycling/waste-and-recycling-collection-disruptions"},"Waste and recycling collection disruptions"]],"\n        Find out whether there are collection disruptions in your area.\n      "],"\n    "],"\n\n  "],"\n"],"\n\n",["BR"],"\n",["BR"],"\n",["DIV",{"class":"container-fluid clearfix"},"\n  ",["DIV",{"class":"row"},"\n    ",["DIV",{"class":"col-xs-12 col-sm-12 col-md-12 col-lg-10 col-lg-offset-1"},"\n      ",["DIV",{"class":"text-right"},["SMALL",{},["STRONG",{},"ID:"]," 17, revised 08/07/2025"]],"\n    "],"\n  "],"\n"],"\n"],"\n","\n"],"\n\