,["SOURCE",{"srcset":"/sites/default/files/styles/cta_header_narrow_400x472px/public/media/images/_1200734.jpg?itok=E4qf37KP 1x","media":"all and (min-width: 320px)","type":"image/jpeg","width":"400","height":"472"}],"\n        ","\n      \n",["IMG",{"__playwright_current_src__":"https://www.westminster.gov.uk/sites/default/files/styles/cta_header_narrow_400x472px/public/media/images/_1200734.jpg?itok=E4qf37KP","class":"image","src":"/sites/default/files/styles/cta_header_narrow_400x472px/public/media/images/_1200734.jpg?itok=E4qf37KP","alt":"A silver food waste bin, with a plastic liner and full of vegetable peelings, stale bread and teabags"}],"\n"],"\n\n\n    \n\n  "],"\n\n    \n\n      "],"\n    \n    ",["DIV",{"class":"flexible-header__content-wrapper col-lg-7"},"\n                        \n",["P",{"class":"paragraph text--large"},"\n      \n\n          Find out how to recycle your food waste.\n    \n\n  "],"\n                            \n\n",["H1",{"name":"","class":"heading heading--title"},"\n      \n\n          Food waste recycling\n    \n\n  "],"\n                              "],"\n  "],"\n"],"\n\n    \n\n                      ",["DIV",{"class":"container-fluid site-max"},"\n        \n  ",["DIV",{"class":"row region-breadcrumb region-breadcrumb--"},"\n    ",["DIV",{"class":"container"},"\n      ",["DIV",{"id":"block-wcc-localgov-breadcrumbs","class":"block"},"\n  \n    \n      \n\n  ",["NAV",{"role":"navigation"},"\n    ",["OL",{"class":"breadcrumb"},"\n          ",["LI",{"class":"breadcrumb__item"},"\n                  ",["A",{"class":"breadcrumb__link","href":"/"},"Home"],"\n              "],"\n        "],"\n  "],"\n\n  "],"\n\n    "],"\n  "],"\n\n      "],"\n        ",["DIV",{"class":"container-fluid"},"\n    ",["DIV",{"class":"row"},"\n                ",["DIV",{"class":"container container--empty"},"\n    ",["DIV",{"data-drupal-messages-fallback":"","class":"hidden"}],"\n\n  "],"\n\n      \n                                    ",["DIV",{"class":"content-top"},"\n              \n\n\n            "],"\n                  \n                \n                          ",["MAIN",{"id":"content","role":"main","class":"column main-content container-fluid"},"\n            ",["SECTION",{"class":"section","id":"main-content","tabindex":"-1"},"\n                ",["DIV",{},"\n    ",["DIV",{"id":"block-flexibletemplatesubmenu","class":"block"},"\n  \n    \n        ",["DIV",{"class":"container"},"\n  ",["UL",{"class":"sub-navigation"},"\n                                  ",["LI",{"class":"sub-navigation__link sub-navigation__link--active"},"\n          ",["A",{"class":"button button--underlined","href":"/recycling-and-rubbish/recycling-and-rubbish-collections/food-waste-recycling"},"Food waste recycling"],"\n        "],"\n                              ",["LI",{"class":"sub-navigation__link sub-navigation__link--"},"\n          ",["A",{"class":"button button--underlined","href":"/food-waste-recycling-expansion/using-food-waste-service"},"Using the food waste service"],"\n        "],"\n                              ",["LI",{"class":"sub-navigation__link sub-navigation__link--"},"\n          ",["A",{"class":"button button--underlined","href":"/food-waste-recycling-expansion/kerbside-collections"},"Kerbside collections"],"\n        "],"\n                              ",["LI",{"class":"sub-navigation__link sub-navigation__link--"},"\n          ",["A",{"class":"button button--underlined","href":"/food-waste-recycling-expansion/housing-estate-collections"},"Housing estate collections"],"\n        "],"\n                              ",["LI",{"class":"sub-navigation__link sub-navigation__link--"},"\n          ",["A",{"class":"button button--underlined","href":"/food-waste-recycling-expansion/mansion-block-collections"},"Mansion block collections"],"\n        "],"\n                              ",["LI",{"class":"sub-navigation__link sub-navigation__link--"},"\n          ",["A",{"class":"button button--underlined","href":"/food-waste-recycling-expansion/neighbourhood-food-waste-bins"},"Neighbourhood food waste bins "],"\n        "],"\n                              ",["LI",{"class":"sub-navigation__link sub-navigation__link--"},"\n          ",["A",{"class":"button button--underlined","href":"/recycling-and-rubbish/recycling-and-rubbish-collections/food-waste-recycling/on-demand-food-waste"},"On-demand food waste collections"],"\n        "],"\n                              ",["LI",{"class":"sub-navigation__link sub-navigation__link--"},"\n          ",["A",{"class":"button button--underlined","href":"/food-waste-regents-park"},"Regent’s Park Crown Estate Properties"],"\n        "],"\n            "],"\n"],"\n\n  "],"\n",["DIV",{"id":"block-wcc-localgov-mainpagecontent--2","class":"block"},"\n  \n    \n      \n\n\n\n\n\n\n\n  \n  \n  \n\n",["ARTICLE",{"class":"node node--flexible_template flexible-template node--view-mode-full node--type-flexible-template","data-component-id":"localgov_base:display-full"},"\n\n  ",["DIV",{"class":"lgd-container padding-horizontal"},"\n    \n    \n\n    \n    \n      ",["DIV",{"class":"flexible-template__content node__content"},"\n        \n\n          \n\n\n",["DIV",{"id":"paragraph-id-10685","class":"page-section"},"\n    ",["DIV",{"class":"container"},"\n    ",["DIV",{"class":"row layout layout--builder"},"\n      ",["DIV",{"class":"layout__region col-md"},"\n        ",["DIV",{"class":"container"},"\n  \n",["DIV",{"id":"paragraph-id-10686","class":"wysiwyg"},"\n                      \n\n            ",["DIV",{"class":"text-long"},["P",{},"We introduced a food waste recycling trial service for around 7,000 households during autumn 2019 until February 2022, collecting over 700 tonnes of food waste to be recycled in total. Since March 2022 we have been introducing a permanent residential food waste recycling service across Westminster."],"\n\n",["P",{},"Most residents now have access to a food waste recycling service. If your property still does not have access to the service, please contact us via:"],"\n\n",["UL",{},"\n\t",["LI",{},"email on ",["A",{"href":"mailto:foodwaste@westminster.gov.uk"},"foodwaste@westminster.gov.uk"]],"\n\t",["LI",{},"calling our contact centre on ",["A",{"href":"tel:02076412000"},"020 7641 2000"]],"\n"],"\n\n",["P",{},"If you live in a building with a property management or managing agent company, we will need their approval before introducing the service in your building."],"\n\n",["P",{},"Depending on your property (and the space to store and leave out a bin for collection) and where you live you will be able to recycle your food waste via:"],"\n\n",["UL",{},"\n\t",["LI",{},"A weekly ",["A",{"data-entity-substitution":"canonical","data-entity-type":"node","data-entity-uuid":"87e0a1cf-1816-4ab3-9a14-426d4db6411c","href":"/food-waste-recycling-expansion/kerbside-collections"},"kerbside food waste recycling service"]],"\n\t",["LI",{},"A communal food waste bin recycling service, mainly for ",["A",{"href":"https://www.westminster.gov.uk/food-waste-recycling-expansion/housing-estate-collections"},"our housing estates"]," or ",["A",{"href":"https://www.westminster.gov.uk/food-waste-recycling-expansion/mansion-block-collections"},"private blocks of flats"]],"\n\t",["LI",{},"An ",["A",{"data-entity-substitution":"canonical","data-entity-type":"node","data-entity-uuid":"f5d57b4a-44fc-4af8-bdae-508b934fe234","href":"/food-waste-recycling-expansion/neighbourhood-food-waste-bins"},"on-street food waste neighbourhood service"],", for properties with limited space for bins"],"\n\t",["LI",{},"A 2-hour ",["A",{"data-entity-substitution":"canonical","data-entity-type":"node","data-entity-uuid":"3159b6bf-875f-437a-b9d5-f28c8bf632bb","href":"/recycling-and-rubbish/recycling-and-rubbish-collections/food-waste-recycling/on-demand-food-waste"},"on-demand booking collection service"],", for properties in St James’s, West End and Marylebone wards only"],"\n"],"\n\n",["H3",{},"Businesses"],"\n\n",["P",{},"Find more information about our ",["A",{"href":"https://cleanstreets.westminster.gov.uk/food-waste-recycling-services"},"food waste recycling service for businesses and request a quote."]],"\n\n",["H3",{},"Why recycle your food waste"],"\n\n",["P",{},"Around 30% of the rubbish that we throw away is food waste. By using the new service, your food waste can be recycled, which will help reduce our impact on the environment and ",["A",{"data-entity-substitution":"canonical","data-entity-type":"node","data-entity-uuid":"63fc03c7-4157-49c1-8b9b-c60e2af07ef8","href":"/fairer-environment-hub/understand/climate-action-plan"},"helps to tackle climate change."]],"\n\n",["P",{},"Since introducing the food waste recycling service, Westminster’s ",["A",{"href":"https://www.gov.uk/government/statistics/local-authority-collected-waste-management-annual-results"},"household recycling rate has increased to 24.6% (2022/23)"]],"\n\n",["P",{},"Thank you for recycling your food waste."],"\n\n",["H3",{},"Get more liners"],"\n\n",["P",{},"Please see the ",["A",{"data-entity-substitution":"canonical","data-entity-type":"node","data-entity-uuid":"d4cc71e1-e6be-4a87-aa1c-c9e628b3c155","href":"/food-waste-recycling-expansion/using-food-waste-service"},"information on using the food waste service page."]],"\n\n",["H3",{},"Where the food waste goes"],"\n\n",["P",{},"Everything collected is sent for processing in an anaerobic digestion plant outside of London. This plant uses food waste to create biogas, a renewable energy source used to generate electricity to power the national grid, and heat homes. This plant will also transform the food waste into a bio-fertiliser, which will be used on farmland to grow more food."],"\n\n",["H3",{},"Reduce your food waste"],"\n\n",["P",{},"Westminster City Council is proud to be part of ",["A",{"href":"https://eatlikealondoner.com/"},"Eat Like a Londoner."]," It’s designed to help Londoners shop, cook and eat better: more sustainably, more cost-effectively, more deliciously. With recipes, hacks, tips and tricks – from experts and locals alike – this is the ultimate destination for anyone looking for new ways to cook, plan or save food."],"\n\n",["P",{},"Please visit ",["A",{"href":"https://eatlikealondoner.com/"},"Eat like a Londoner: Save money. Eat better. Help the Planet."]," to find out more."]],"\n      \n          "],"\n"],"\n\n      "],"\n    "],"\n  "],"\n\n"],"\n\n    \n\n      "],"\n  "],"\n\n  \n\n  \n"],"\n\n  "],"\n  \n\n\n",["DIV",{"id":"block-gov-metric-snippet","class":"govmetric"},"\n  ",["DIV",{"class":"gm_sidebar gm_sidebar_rh","style":"z-index:0"},"\n    ",["A",{"href":"https://websurveys2.govmetric.com/theme/gm/9990019","class":"gm_sidebar_anchor","role":"button","rel":"nofollow"},"\n      ",["IMG",{"__playwright_current_src__":"https://websurveys2.govmetric.com/imgs/triggers/rh.svg","src":"https://websurveys2.govmetric.com/imgs/triggers/rh.svg","alt":"Feedback button"}],"\n    "],"\n  "],"\n"],"\n\n  "],"\n\n            "],"\n          "],"\n        \n  \n        \n                              ",["DIV",{"class":"col-md-12"},"\n                ",["DIV",{},"\n    ",["DIV",{"class":"feedbackform-wrapper container"},"\n  \n\n\n",["DIV",{"id":"block-feedbackfooter","class":"feedback-form"},"\n  \n",["A",{"class":"link","href":"/form/page-feedback?path=/recycling-and-rubbish/recycling-and-rubbish-collections/food-waste-recycling&source_entity_type=node&source_entity_id=23805"},"\n      \n\n          Is there anything wrong with this page?\n    \n\n  "],"\n\n"],"\n"],"\n\n  "],"\n\n            "],"\n                        \n          "],"\n  "],"\n            \n",["FOOTER",{"class":"footer"},"\n  ",["DIV",{"class":"container"},"\n    ",["DIV",{"class":"footer__inner"},"\n      ",["DIV",{"class":"footer__menu"},"\n            ",["DIV",{"id":"block-footer"},"\n            \n  \n\n        \n\n\n\n    \n                          \n    \n",["UL",{"class":"inline-menu"},"\n            \n",["LI",{"class":"inline-menu__item"},"\n   