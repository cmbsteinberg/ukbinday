esses used to provide content functions on this site."]]],["BUTTON",{"class":"accept","id":"cookie-control-save"},"Save cookie preferences"]]],["BUTTON",{"class":"reject","id":"cookie-control-reject"},"Essential cookies only"],["BUTTON",{"class":"accept","id":"cookie-control-accept"},"Accept all cookies"]]]],["HEADER",{"id":"site-header"},"\n    ",["DIV",{"class":"inner max-width"},"\n      ",["DIV",{"id":"site-identity"},"\n        ",["A",{"href":"https://www.shropshire.gov.uk"},"\n            ",["IMG",{"__playwright_current_src__":"https://next.shropshire.gov.uk/media/yt5pdjur/logo.svg?width=280&v=1da4a235fd0a130","id":"logo","src":"/media/yt5pdjur/logo.svg?width=280&v=1da4a235fd0a130","alt":"Shropshire Council","width":"150"}],"\n        "],"\n      "],"\n\n\n        ",["FORM",{"id":"search","role":"search","method":"get","action":"https://www.shropshire.gov.uk/search","aria-label":"Search the site"},"\n  ",["LABEL",{"for":"search-query-search","class":"screen-reader-text"},"Search keywords:"],"\n  ",["INPUT",{"__playwright_value_":"","type":"search","name":"s","id":"search-query-search","placeholder":"Search for…","value":"","data-search-autocomplete":"false"}],"\n  ",["BUTTON",{},"Search"],"\n"],"\n\n    "],"\n  "],"\n\n    ",["ASIDE",{"id":"phase-banner","role":"note"},"\n      ",["DIV",{"class":"inner max-width"},"\n        ",["P",{},"\n          ",["MARK",{},"Beta"],"\n          ",["SPAN",{},"This is a new service — your ",["A",{"href":"https://www.surveymonkey.co.uk/r/NextShropshire"},"feedback"]," will help us to improve it."],"\n        "],"\n      "],"\n    "],"\n\n  ",["MAIN",{"id":"content"},"\n          ",["STYLE",{},"\n            #masthead {\n              --header-image: url('/media/n3cbqgds/recycling.png?rmode=max&width=1200&height=300&format=webp&quality=85&v=1d9bef08058c4f0');\n            }\n          "],"\n\n    ",["HEADER",{"id":"masthead","class":"max-width"},"\n        ",["DIV",{"class":"inner"},"\n          ",["H1",{"id":"page-title"},"\n            Your collection service\n          "],"\n        "],"\n\n      ",["NAV",{"class":"breadcrumb"},["OL",{"class":"menu"},["LI",{},["A",{"href":"/","title":"Home"},"Home"]],["LI",{},["A",{"href":"/recycling-and-rubbish/","title":"Recycling and rubbish"},"Recycling and rubbish"]],["LI",{},["A",{"href":"/recycling-and-rubbish/what-to-do-with/","title":"What to do with..."},"What to do with..."]],["LI",{},["SPAN",{"class":"current-page"},"Your collection service"]]]],"\n    "],"\n\n      ",["ASIDE",{"id":"nf-17197","class":"notification max-width information dismissable"},"\n        ",["H2",{},"Garden waste subscription service"],"\n        ",["P",{"class":"MsoNormal"},["SPAN",{"style":"font-size: 14.0pt;"},"The garden waste payment window has reopened. To subscribe, please go to our '",["A",{"rel":"noopener","href":"/recycling-and-rubbish/garden-waste-collections/how-to-subscribe/","target":"_blank"},"How to subscribe'"]," page. "],"Please note that the fee is £56 per bin and the subscription will run until 31 October 2025."],"\n      ",["BUTTON",{"class":"close"},"Dismiss"]],"\n\n    \n      ",["DIV",{"class":"block-grid","data-grid-columns":"12"},"\n          ",["DIV",{"id":"block-72df9166-38b3-4f6e-a268-a909f75d9461","class":"block fixed-width-row  first-in-row","data-col-span":"12","data-row-span":"1","data-align":"","data-justify":""},"\n              ",["DIV",{"class":"inner max-width"},"\n      ",["DIV",{"class":"block-grid","data-grid-columns":"12"},"\n          ",["DIV",{"id":"block-91034c54-0d4e-4100-a29c-0432455382b9","class":"block rich-text  first-in-row","data-col-span":"12","data-row-span":"1","data-align":"","data-justify":""},"\n              ",["P",{},"Please ensure that your bin can easily be moved by one hand. This is to ensure that collection crews don't have any issues emptying your bin. Overloaded bins can cause health and safety issues to the collection crew and won't be emptied."],"\n",["P",{},"It's the resident's responsibility to remove waste to ensure the bin can be collected on the next scheduled collection. Additional waste can be disposed of at your ",["A",{"href":"/recycling-and-rubbish/household-recycling-centres/","title":"Household recycling centres"},"nearest household recycling centre"],"."],"\n          "],"\n          ",["DIV",{"id":"block-58f5446f-223f-4105-837d-48fa27f1fa71","class":"block rich-text  first-in-row","data-col-span":"12","data-row-span":"1","data-align":"","data-justify":""},"\n              ",["H2",{},"Mixed packaging"],"\n",["P",{},"There’s no need to separate cans, plastics and glass. You can mix them all together in your boxes or recycling bin. Please keep material loose and please don't bag your recycling."],"\n",["P",{},["IMG",{"__playwright_current_src__":"https://next.shropshire.gov.uk/media/xuukaxye/mixed-packaging.png?rmode=max&width=500","src":"/media/xuukaxye/mixed-packaging.png?rmode=max&width=500","alt":"Examples of mixed packaging","width":"500","height":"82"}]],"\n",["H3",{},"We accept..."],"\n",["UL",{},"\n",["LI",{},"Aerosols"],"\n",["LI",{},"Drink cans"],"\n",["LI",{},"Foil"],"\n",["LI",{},"Plastic pots, tubs, trays and bottles"],"\n",["LI",{},"Food tins"],"\n",["LI",{},"Sweet tins"],"\n",["LI",{},"Bottle tops"],"\n",["LI",{},"Metal tops"],"\n",["LI",{},"Glass bottles and jars"],"\n"],"\n          "],"\n          ",["DIV",{"id":"block-294e258c-b194-462c-aad3-e07cd539c23a","class":"block rich-text  first-in-row","data-col-span":"12","data-row-span":"1","data-align":"","data-justify":""},"\n              ",["H2",{},"Blue bag"],"\n",["P",{},"The blue bag makes it easy to recycle. You can use it to collect all your cardboard and paper too, freeing up an extra box for your other recycling."],"\n",["P",{},["IMG",{"__playwright_current_src__":"https://next.shropshire.gov.uk/media/mi0cdply/blue-bag-recycling.png?rmode=max&width=500","src":"/media/mi0cdply/blue-bag-recycling.png?rmode=max&width=500","alt":"Blue bag recycling examples","width":"500","height":"78"}]],"\n",["H3",{},"We accept..."],"\n",["UL",{},"\n",["LI",{},"Magazines"],"\n",["LI",{},"Junk mail"],"\n",["LI",{},"Envelopes"],"\n",["LI",{},"Catalogues"],"\n",["LI",{},"Ready-meal boxes"],"\n",["LI",{},"Egg boxes"],"\n",["LI",{},"Newspapers"],"\n",["LI",{},"Cereal boxes"],"\n",["LI",{},"Cardboard packaging"],"\n"],"\n",["P",{},"If you have lots of cardboard, cut or tear into small pieces (the size of your blue bag) and secure together. Please then leave this by the side of your blue bag, secured so that it doesn’t become windblown."],"\n          "],"\n          ",["DIV",{"id":"block-5f661224-918b-4c85-ba70-32d38b44d2c6","class":"block rich-text  first-in-row","data-col-span":"12","data-row-span":"1","data-align":"","data-justify":""},"\n              ",["H2",{},"Batteries"],"\n",["P",{},"Place batteries in a clear plastic bag and put out next to your recycling boxes on recycling day. Normal household batteries can be recycled along with the rest of your household recycling. Batteries should be placed in a clear plastic bag and left where the collection crews can easily see them.",["BR"]],"\n          "],"\n          ",["DIV",{"id":"block-6baa338d-474f-47bd-a72b-7a9cfccf8744","class":"block rich-text  first-in-row","data-col-span":"12","data-row-span":"1","data-align":"","data-justify":""},"\n              ",["H2",{},"Rubbish bin"],"\n",["P",{},"For anything that can’t be recycled, you can still use your general waste bin. We send this waste to an energy recovery facility where it's used to generate electricity."],"\n",["P",{},"So before you bin it, ask yourself, is it general household waste or can it be recycled?"],"\n",["P",{},"Remember, we don’t collect waste from the side of your bin. Make sure everything fits inside and the lid is closed. The council reserves the right to not collect bins that are identified as not safe to unload. This could be due to risk of spillage, harm to collection crews, passers-by, and damage to vehicles."],"\n",["P",{},["STRONG",{},"Provision of Sacks"],": In cases where properties can't store bins, the council provides sacks for waste collection. These sacks are designed to be durable and keep wildlife out when properly secured."],"\n",["H3",{},"Household recycling centres (HRCs)"],"\n",["P",{},"If you have any items that are too big for the kerbside collection service, you can drop them off at your local HRC. We recycle over 30 different types of materials – everything from kettles and toasters to car batteries, paint and cooking oil! Don’t forget, if you’re in a van – you may need a permit."],"\n",["H3",{},"Bulky waste"],"\n",["P",{},"Another way to recycle large, bulky items is to donate them to a local re-use shop or scheme. Or if you’d like us to pick it up, you can pay to use our bulky waste collection service. Simply call: ",["A",{"href":"tel:+443456789007","title":"Call recycling and rubbish"},"0345 678 9007"]],"\n          "],"\n      "],"\n              "],"\n          "],"\n      "],"\n\n\n  "],"\n\n  ",["FOOTER",{"id":"site-footer"},"\n    ",["DIV",{"class":"inner max-width"},"\n        ",["SECTION",{"id":"footer-links"},"\n          ",["H2",{},"Legal"],"\n          ",["UL",{"class":"menu"},"\n              ",["LI",{"class":"privacy-policies"},["A",{"href":"https://www.shropshire.gov.uk/privacy/"},"Privacy policies"]],"\n              ",["LI",{"class":"cookie-policy"},["A",{"href":"https://www.shropshire.gov.uk/about-this-site/cookies/"},"Cookie policy"]],"\n              ",["LI",{"class":"terms-and-conditions"},["A",{"href":"https://www.shropshire.gov.uk/website-information/terms-and-conditions-for-users-of-this-website/"},"Terms and conditions"]],"\n              ",["LI",{"class":"accessibility-statement"},["A",{"href":"https://www.shropshire.gov.uk/website-information/help-using-our-website/accessibility-statement-for-shropshire-council/"},"Accessibility statement"]],"\n              ",["LI",{"class":"data-protection-and-f-o-is"},["A",{"href":"https://www.shropshire.gov.uk/access-to-information/"},"Data protection and FOIs"]],"\n          "],"\n        "],"\n\n        ",["SECTION",{"id":"footer-links-secondary"},"\n          ",["H2",{},"Using this site"],"\n          ",["UL",{"class":"menu"},"\n              ",["LI",{"class":"contact-us"},["A",{"href":"https://next.shropshire.gov.uk/customer-services/ways-to-contact-us/"},"Contact us"]],"\n              ",["LI",{"class":"feedback-and-complaints"},["A",{"href":"/feedback/"},"Feedback and complaints"]],"\n              ",["LI",{"class":"jobs-and-careers"},["A",{"href":"/jobs-and-careers/"},"Jobs and careers"]],"\n              ",["LI",{"class":"newsroom"},["A",{"href":"https://newsroom.shropshire.gov.uk/"},"Newsroom"]],"\n              ",["LI",{"class":"open-data"},["A",{"href":"/open-data/"},"Open data"]],"\n              ",["LI",{"class":"maps"},["A",{"href":"https://shropshire.maps.arcgis.com/apps/PublicGallery/index.html?appid=adf20c247d5149ea95f482335e002f6c"},"Maps"]],"\n          "],"\n        "],"\n\n        ",["SECTION",{"id":"social-media"},"\n          ",["H2",{},"Connect with us"],"\n          ",["UL",{"class":"menu social-icons","data-horizontal":""},"\n              ",["LI",{"class":"follow-us-on-twitter"},["A",{"href":"https://www.twitter.com/ShropCouncil","class":"social-icon","title":"Follow us on Twitter"},["SPAN",{"class":"screen-reader-text"},"Follow us on Twitter"]]],"\n              ",["LI",{"class":"follow-us-on-facebook"},["A",{"href":"https://www.facebook.com/shropshirecouncil","class":"social-icon","title":"Follow us on Facebook"},["SPAN",{"class":"screen-reader-text"},"Follow us on Facebook"]]],"\n              ",["LI",{"class":"follow-us-on-instagram"},["A",{"href":"https://www.instagram.com/shropshirecouncil","class":"social-icon","title":"Follow us on Instagram"},["SPAN",{"class":"screen-reader-text"},"Follow us on Instagram"]]],"\n              ",["LI",{"class":"follow-us-on-linked-in"},["A",{"href":"https://uk.linkedin.com/company/shropshire-council","target":"_blank","class":"social-icon","title":"Follow us on LinkedIn"},["SPAN",{"class":"screen-reader-text"},"Follow us on LinkedIn"]]],"\n          "],"\n        "],"\n\n\n      ",["SECTION",{"id":"copyright"},"\n        © Shropshire Council 2017–2025\n      "],"\n    "],"\n  "],"\n\n  ","\n  ","\n  \n    ","\n\n    ","\n\n\n"]],"viewport":{"width":800,"height":461},"timestamp":3150.663,"wallTime":1753094240020,"collectionTime":2.5,"resourceOverrides":[],"isMainFrame":true}}
