{"type":"before","callId":"call@50","startTime":17348.143,"class":"Frame","method":"evaluateExpression","params":{"expression":"() => {\n    const table = document.querySelector('[ref=\"e472\"]');\n    const rows = Array.from(table.querySelectorAll('tbody tr'));\n    const data = {};\n\n    rows.forEach(row => {\n        const date = row.querySelector('td:nth-child(1)').innerText;\n        const blackBin = row.querySelector('td:nth-child(2)').innerText;\n        const blueBin = row.querySelector('td:nth-child(3)').innerText;\n        const greenBin = row.querySelector('td:nth-child(4)').innerText;\n\n        if (blackBin.trim() !== '') {\n            data.blackBin = { next_pickup_day: date, frequency: 'Every two weeks' };\n        }\n        if (blueBin.trim() !== '') {\n            data.blueBin = { next_pickup_day: date, frequency: 'Every two weeks' };\n        }\n        if (greenBin.trim() !== '') {\n            data.greenBin = { next_pickup_day: date, frequency: 'Every two weeks' };\n        }\n    });\n    return data;\n}","isFunction":true,"arg":{"value":{"v":"undefined"},"handles":[]}},"pageId":"page@6d35269c7fc13f41d2ca33b75fb0c2f6","beforeSnapshot":"before@call@50"}
