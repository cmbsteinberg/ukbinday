ght: auto; }\ninput[type=\"search\"] { appearance: textfield; box-sizing: content-box; }\ninput[type=\"search\"]::-webkit-search-cancel-button, input[type=\"search\"]::-webkit-search-decoration { appearance: none; }\nfieldset { border: 1px solid rgb(192, 192, 192); margin: 0px 2px; padding: 0.35em 0.625em 0.75em; }\nlegend { border: 0px; padding: 0px; }\ntextarea { overflow: auto; }\noptgroup { font-weight: bold; }\ntable { border-collapse: collapse; border-spacing: 0px; }\ntd, th { padding: 0px; }\n* { box-sizing: border-box; }\n#prefix-overlay-outer p { margin: 0px; padding: 0px; }\n#prefix-overlay-outer { font-family: \"Open Sans\", \"Helvetica Neue\", Arial, sans-serif; padding: 0px 0px 15px; text-align: center; box-shadow: rgb(0, 0, 0) 0px 0px 10px; border-radius: 10px; -webkit-tap-highlight-color: rgba(255, 255, 255, 0) !important; outline: 0px !important; }\n#prefix-overlay-header { font: 24px \"Open Sans\", \"Helvetica Neue\", Arial, sans-serif; padding-bottom: 0px; padding-top: 15px; display: block; }\n#prefix-overlay-header img { vertical-align: middle; }\n#prefix-overlay-header button.prefix-overlay-close { padding: 0px; position: absolute; top: -12.5px; right: -12.5px; display: block; width: 30px; height: 30px; border: none; text-indent: -9999px; cursor: pointer; background: url(\"data:image/png;base64,\") 0px 0px no-repeat; }\n.prefix-overlay-content { color: rgb(52, 61, 71); text-align: center; display: block; font-weight: bold; font-size: 22px; margin: 0px; line-height: 26px; padding: 10px 15px; }\n#prefix-overlay-form-div form { margin: 0px auto; padding-top: 9px; }\n#prefix-overlay-form-div input { margin: 0px auto; display: block; }\n#prefix-error-outer { clear: both; font-size: 14px; line-height: 1.2em; color: rgb(255, 34, 34); padding-top: 10px; }\n.prefix-overlay-button-panel { padding-top: 10px; font-size: 12px; line-height: 20px; }\n#prefix-overlay-outer .prefix-overlay-button-panel button { background-color: transparent; border: none; line-he