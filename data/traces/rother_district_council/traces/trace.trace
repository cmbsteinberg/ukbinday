; outline: 0px; overflow-y: auto; padding: 0px; position: absolute; resize: none; top: 0px; width: 100%; word-break: break-word; }\n.webchat--css-zymfj-1ms7ti7.webchat__defaultAvatar { border-radius: 50%; height: 40px; width: 40px; }\n.webchat--css-zymfj-1u4tklr.webchat__basic-transcript:focus { outline: 0px; }\n.webchat--css-zymfj-1u4tklr.webchat__basic-transcript:focus .webchat__basic-transcript__activity-indicator.webchat__basic-transcript__activity-indicator--focus { border-color: rgb(118, 118, 118); border-style: none; border-width: 1px; box-sizing: border-box; height: calc(100% - 5px); left: 0px; margin: 0px 5px; pointer-events: none; position: absolute; top: 0px; width: calc(100% - 10px); }\n.webchat--css-zymfj-1u4tklr.webchat__basic-transcript:focus-visible .webchat__basic-transcript__focus-indicator, .webchat--css-zymfj-1u4tklr.webchat__basic-transcript .webchat__basic-transcript__terminator:focus-visible + .webchat__basic-transcript__focus-indicator { height: 100%; border-color: black; border-style: none; border-width: 2px; box-sizing: border-box; pointer-events: none; position: absolute; top: 0px; width: 100%; }\n.webchat--css-zymfj-1u4tklr.webchat__basic-transcript .webchat__basic-transcript__activity { padding-top: 5px; position: relative; }\n.webchat--css-zymfj-1u4tklr.webchat__basic-transcript .webchat__basic-transcript__activity:first-child { margin-top: 5px; }\n.webchat--css-zymfj-1u4tklr.webchat__basic-transcript .webchat__basic-transcript__activity:not(:first-child) { margin-top: -5px; }\n.webchat--css-zymfj-1u4tklr.webchat__basic-transcript .webchat__basic-transcript__activity-active-descendant { height: 100%; left: 0px; margin-top: -5px; padding-bottom: 5px; pointer-events: none; position: absolute; top: 0px; width: 100%; }\n.webchat--css-zymfj-1u4tklr.webchat__basic-transcript .webchat__basic-transcript__activity-body:not(:empty) { padding-bottom: 10px; }\n.webchat--css-zymfj-1u4tklr.webchat__basic-transcript .webchat__basic-transcript__termina