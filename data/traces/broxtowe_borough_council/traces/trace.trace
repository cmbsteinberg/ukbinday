label":"Roads, Parking & Travel"},"\n                                    ",["A",{"href":"/for-you/roads-parking-travel/"},"Roads, Parking & Travel"],"\n                                "],"\n                                ",["LI",{"class":"left-nav siblings","title":"Schools & Learning","aria-label":"Schools & Learning"},"\n                                    ",["A",{"href":"/for-you/schools-learning/"},"Schools & Learning"],"\n                                "],"\n                                ",["LI",{"class":"left-nav siblings","title":"Town Centres in Broxtowe ","aria-label":"Town Centres in Broxtowe "},"\n                                    ",["A",{"href":"https://www.broxtowe.gov.uk/for-business/town-centres/"},"Town Centres in Broxtowe"],"\n                                "],"\n                                ",["LI",{"class":"left-nav siblings","title":"LLeisure Ltd","aria-label":"LLeisure Ltd"},"\n                                    ",["A",{"href":"/for-you/lleisure-ltd/"},"LLeisure Ltd"],"\n                                "],"\n\n                    "],"\n                "],"\n        "],"\n    "],"\n"],"\n\n    ",["A",{"id":"skipNavigation"}],"\n\n                ",["DIV",{"id":"topTasks"},"\n                    ",["DIV",{"class":"bottom-links-title"},"Popular services"],"\n                    ",["UL",{"title":"Popular services","aria-label":"Popular services"},"\n                                ",["LI",{"class":"list-unstyled"},"\n                                    ",["A",{"href":"/about-the-council/redirects/when-is-my-bin-collection/"},"When Is My Bin Collection?"],"\n                                "],"\n                                ",["LI",{"class":"list-unstyled"},"\n                                    ",["A",{"href":"/about-the-council/redirects/pay-for-garden-waste-subscription/"},"Pay For Garden Waste Subscription"],"\n                                "],"\n                                ",["LI",{"class":"list-unstyled"},"\n                                    ",["A",{"href":"/about-the-council/redirects/report-a-missed-bin/"},"Report A Missed Bin"],"\n                                "],"\n                                ",["LI",{"class":"list-unstyled"},"\n                                    ",["A",{"href":"/about-the-council/redirects/request-an-additional-bin/"},"Request An Additional Bin"],"\n                                "],"\n                                ",["LI",{"class":"list-unstyled"},"\n                                    ",["A",{"href":"/about-the-council/redirects/bulky-waste-form/"},"Bulky Waste Form"],"\n                                "],"\n                    "],"\n                "],"\n\n            ",["DIV",{"id":"rightContentWrapper","class":"right-content-holder col-xs-12 col-sm-12 col-md-9"},"\n                    ",["DIV",{"class":"page-title"},"\n                        ",["H1",{},"Waste and Recycling"],"\n                    "],"\n                    ",["DIV",{"class":"page-description"},"\n                        ",["STRONG",{},"Welcome to Broxtowe's Waste and Recycling page.  We aim to help you understand more about waste and recycling within the borough.  You can also find a list of our different services available to the residents of Broxtowe."],"\n                    "],"\n\n                ",["DIV",{"class":"content-paragraph "},"\n                    ",["DIV",{"class":"x11i5rnm xat24cr x1mh8g0r x1vvkbs xtlvy1s x126k92a"},"\n",["DIV",{},["SPAN",{"style":"color: #035b4b; font-size: 18px; font-weight: bold;"},"Recycling in Broxtowe"]],"\n"],"\n",["P",{},"Recycling is collected from your kerbside and processed by the ",["A",{"rel":"noopener","href":"https://www.veolia.co.uk/nottinghamshire/facilities/materials-recovery-facility","target":"_blank","title":"Veolia Nottinghamshire Material Recovery Facility website"},"Materials Recovery Facility in Mansfield (Opens in New Window)."],"                                                                              ",["IMG",{"__playwright_current_src__":"https://www.broxtowe.gov.uk/media/8487/copy-of-veolia_mansfield_selected_enhanced_low_res-137.jpg?width=317&height=211&mode=max","style":"width: 317px; height: 211px; float: right;","src":"/media/8487/copy-of-veolia_mansfield_selected_enhanced_low_res-137.jpg?width=317&height=211&mode=max","alt":"jcb forklift at recycling centre","title":"Copy of Veolia_Mansfield_Selected_Enhanced_Low_Res-137.jpg","data-id":"14608"}]],"\n",["P",{},"Materials are processed by product type, rather than codes.         "],"\n",["P",{},"It is important to  put the correct items in the recycling bin.  A good guide to what goes in your recycle bin can be found on your recycling bin sticker.  Anything that is not listed on the sticker should be considered waste.  This will help reduce contamination.  Please see our recycling page for more information on what you can ",["A",{"href":"/for-you/waste-and-recycling/recycling-bin/","title":"Broxtowe Borough Councils Recycling web page"},"recycle"]," (Opens in a New Window).       "],"\n",["P",{},"The national target of recycling is 50% and we are working hard together with Veolia to achieve this by reducing contamination in recycling.  Did you know that 11% (based on random sample in 2019) of the items placed in recycling bins in 2019 don't belong there? Contamination means the contents of the recycling bin must all go to waste. The biggest contaminates we see are pizza boxes with grease or food traces, nappies, Tetra packs, glass, shredded paper and textiles. Please ",["STRONG",{},"don't "],"put these items in recycling bins as they cannot currently be recycled."],"\n",["H2",{},"Not sure what goes in what bin?"],"\n",["P",{},"If you're not sure what goes in what bin, you can use our ",["A",{"rel":"noopener","href":"/for-you/waste-and-recycling/waste-a-z/","target":"_blank","title":"A-Z of Waste and Recycling"},"A-Z of Waste and Recycling search (Opens in a New Window)"]," to check."],"\n",["H2",{},"Not sure when your next collection is?"],"\n",["P",{},"Use our ",["A",{"rel":"noopener","href":"https://selfservice.broxtowe.gov.uk/renderform.aspx?t=217&k=9D2EF214E144EE796430597FB475C3892C43C528","target":"_blank","title":"When Is My Collection online form"},"When Is My Collection Form (Opens in a New Window)"]," to see when your next bin collection is. "],"\n",["P",{},["SPAN",{"class":"offscreen"},"You can also text 60075 to check which collection is due that week.  Start the message with 'BROX NEXT' including your postcode and house number - i.e. 'BROX NEXT NG9 1AB 32', you will be sent a message back with details of your next scheduled collection."]],"\n",["P",{},"'Each message sent is charged at the user's standard network rate although some inclusive network plans exclude messages to short codes and therefore prices may vary.'"],"\n",["H2",{},"How do I report a missed bin collection?"],"\n",["P",{},"The easiest way to report a missed bin is online using our ",["A",{"href":"https://selfservice.broxtowe.gov.uk/renderform.aspx?t=214&k=E6368F859A9802907F255AB887E3B3ED6A503DAC","title":"Report a missed bin online form"},"report a missed bin online form ",["SPAN",{"class":"offscreen"},"(Opens in a New Window)."]]],"\n                "],"\n\n                \n\n\n                    ",["HR"],"\n                    ",["DIV",{"class":"content-contact-holder col-xs-12"},"\n                        ",["DIV",{"class":"desktop-row"},"\n                            ",["DIV",{"class":"row"},"\n                                ",["DIV",{"class":"col-md-3"},"\n                                    ",["DIV",{"class":"contact-title"},"Contact"],"\n                                "],"\n                                ",["DIV",{"class":"col-md-8"},"\n\n\n                                            ",["DIV",{"class":"col-sm-6 contact-information"},"\n                                                ",["DIV",{"class":"contactName"},"Recycling"],"\n                                                    ",["DIV"