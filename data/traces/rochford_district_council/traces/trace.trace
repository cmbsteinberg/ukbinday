bmit govuk-button"}]],"\n"],"\n\n\n"],"\n"],"\n\n    "],"\n  "],"\n\n      "],"\n\n\n\n\n    \n  \n\n"],"\n\n      "],"\n    "],"\n  \n"],"\n"],"\n\n  ",["DIV",{"id":"global-bar","class":"global-bar dont-print ","data-module":"global-bar","data-global-bar-permanent":"true","data-nosnippet":""},"\n    ",["DIV",{"class":"global-bar-message govuk-width-container"},"\n    "],"\n  "],"\n\n\n  \n\n  ",["DIV",{"role":"banner"},"\n    \n    ",["DIV",{"class":"govuk-width-container"},"\n          \n    \n      ",["DIV",{"class":"region region-pre_content"},"\n    ",["DIV",{"id":"block-rochford-breadcrumbs","class":"block block-system block-system-breadcrumb-block"},"\n  ",["NAV",{"aria-labelledby":"system-breadcrumb","class":"govuk-breadcrumbs"},["DIV",{"id":"system-breadcrumb","class":"visually-hidden"},"Breadcrumb"],["DIV",{"class":"govuk-breadcrumbs "},"\n  ",["OL",{"class":"govuk-breadcrumbs__list"},"\n          ",["LI",{"class":"govuk-breadcrumbs__list-item"},"\n      ",["A",{"class":"govuk-breadcrumbs__link","href":"/"},"Home"],"\n    "],"\n              ",["LI",{"class":"govuk-breadcrumbs__list-item"},"\n      ",["A",{"class":"govuk-breadcrumbs__link","href":"/environment"},"Environment"],"\n    "],"\n              ",["LI",{"class":"govuk-breadcrumbs__list-item"},"\n      ",["A",{"class":"govuk-breadcrumbs__link","href":"/recycling"},"Recycling"],"\n    "],"\n              ",["LI",{"class":"govuk-breadcrumbs__list-item","aria-current":"page"},"Bins and Collections"],"\n        "],"\n"],"\n"],"\n"],"\n",["DIV",{"id":"block-rochford-sitewidealert","class":"cp-site-alert block block-sitewide-alert-block"},"\n  ",["DIV",{"data-sitewide-alert":""}]],"\n",["DIV",{"id":"block-rochford-page-title","class":"block block-core block-page-title-block"},"\n  \n  ",["H1",{"class":"govuk-heading-xl","id":"bins-and-collections"},"\n            ",["SPAN",{},"Bins and Collections"],"\n      "],"\n\n"],"\n\n  "],"\n\n    "],"\n  "],"\n\n",["DIV",{"class":"govuk-width-container"},"\n      ",["MAIN",{"class":"govuk-main-wrapper","id":"main-content"},"\n        ",["DIV",{"class":"govuk-grid-row"},"\n                                      ",["DIV",{"class":"page-region-content govuk-grid-column-full"},"\n          ",["DIV",{"class":"region region-content"},"\n    ",["DIV",{"data-drupal-messages-fallback":"","class":"hidden"}],"\n",["DIV",{"id":"block-rochford-content","class":"block block-system block-system-main-block"},"\n  ",["ARTICLE",{"about":"/bins-and-collections"},"\n\n  \n    \n\n  \n  ",["DIV",{},"\n      ",["DIV",{"class":"layout layout--onecol"},"\n    ",["DIV",{"class":"layout__region layout__region--content"},"\n      ",["DIV",{"class":"block block-layout-builder block-extra-field-block--node--basic-page--content-moderation-control"},"\n  "],"\n",["DIV",{"class":"views-element-container block block-views block-views-block--content-published-information-block-1"},"\n  ",["DIV",{},["DIV",{"class":"content-authored-information-block view-id-content-published-information view-display-id-block-1 js-view-dom-id-b6ec5d9dc62ba707446a9d547739975aeb4c39a3cd2ec093f1a130f224637440"},"\n  \n  \n  \n\n  \n  \n  \n\n  ",["DIV",{},["SPAN",{"class":"views-field views-field-created"},["SPAN",{"class":"views-label views-label-created"},"Published"],["SPAN",{"class":"field-content"},["TIME",{"datetime":"2022-01-07T17:43:40+00:00"},"07 January 2022"],"\n"]],["DIV",{"class":"views-field views-field-revision-timestamp"},["SPAN",{"class":"views-label views-label-revision-timestamp"},"Last updated"],["SPAN",{"class":"field-content"},["TIME",{"datetime":"2025-06-13T23:00:21+01:00"},"13 June 2025"],"\n"]]],"\n    \n\n  \n  \n\n  \n  \n"],"\n"],"\n"],"\n\n    "],"\n  "],"\n\n  ",["DIV",{"class":"layout layout--twocol-section layout--twocol-section--67-33 govuk-grid-row"},"\n\n          ",["DIV",{"class":"layout__region layout__region--first"},"\n        ",["DIV",{"class":"block block-layout-builder block-field-block--node--basic-page--body"},"\n  \n            ",["DIV",{"class":"field field--name-body field--type-text-with-summary field--label-hidden"},"\n",["H2",{"id":"waste-collection-update-ongoing-disruption-due-to-roadworks"},"Waste Collection Update: Ongoing disruption due to roadworks"],"\n\n\n\n",["P",{},"Due to ongoing road works near Aldermans Hill and Main Road, Hockley, our waste contractor Rochford Norse will be making their waste collections on a Wednesday earlier to avoid traffic congestion on these roads for a few weeks/months."],"\n\n\n\n",["P",{},"Please leave your bins out on the boundary of your property as normal by 7am, to ensure your waste is collected."],"\n\n\n\n",["P",{},"We apologise for any inconvenience."],"\n\n\n\n",["H2",{"id":"bins-and-collections-0"},"Bins and collections"],"\n\n\n\n",["P",{},"All households in the Rochford District are provided with three bins, including flats and parkland homes.",["BR"],["BR"],"The compostables bin collected weekly",["BR"],"The recyclables bin collected fortnightly",["BR"],"The non-recyclables collected fortnightly",["BR"],["BR"],"Bins need to be placed at the boundary of your property by 7am on your collection day."],"\n\n\n\n",["P",{},"If you live in a private road, private street or an unadopted road you may be required to present your bins next to the adopted highway, or at a position agreed with the waste officer at the discretion of the Council."],"\n\n\n\n",["P",{},"Following collection please place your bins back onto your property."],"\n\n\n\n",["P",{},"If you live in a flat with a communal bin area there is no need to move the bins, they will be collected and returned to the allocated bin areas.",["BR"],["BR"],["STRONG",{},"To find out your collection day and which bin is collected in which week, please check the bin collection day tool. "]],"\n\n\n\n",["P",{},["STRONG",{},["STRONG",{},"We also have an ",["A",{"href":"/online-bin-collections-calendar"},"online bin collection calendar"],", ",["STRONG",{},["STRONG",{},"the ",["A",{"href":"https://www.rochford.gov.uk/printable-bin-collections"},"printable calendar"]," is available in Related Content."]]],["BR"],["BR"],"If you are physically unable to place your bin at the boundary, please see the ‘Special collections’ section"]],"\n\n\n\n",["P",{},"Please avoid putting out additional waste for collection. If every household puts out more waste than usual, the collection vehicles will fill up quicker. This could result in some households not having their waste collected, as well as placing additional strain on collection crews. The advice is to store your additional recycling within your home."],"\n\n\n\n",["H2",{"id":"contaminated-bins"},"Contaminated bins"],"\n\n\n\n",["P",{},"Please see the ‘What goes where?’ page of the website to find out which items to place in each of your bins or use the A - Z of materials in Related Content section."],"\n\n\n\n",["P",{},"All items should be placed ",["STRONG",{},"loose "],"into your ",["STRONG",{},"recyclables bin"],"."],"\n\n\n\n",["P",{},"If your bin contains incorrect items, it will not be collected and the crew will make a note of the contamination on the waste management system."],"\n\n\n\n",["P",{},"In addition, a photograph of your bin contents may be taken for our records*."],"\n\n\n\n",["P",{},["STRONG",{},"Common incorrect items"]],"\n\n\n\n",["P",{},"Please ",["STRONG",{},"DO NOT"]," place any of the following items in the ",["STRONG",{},"RECYCLABLES"]," bin:"],"\n\n\n\n",["UL",{},["LI",{},"Food"],["LI",{},"Food stained packaging"],["LI",{},"Clothing and textiles"],["LI",{},"Nappies"],["LI",{},"Plastic carrier bags"],["LI",{},"Black sacks"],["LI",{},"Plastic wrapping"]],"\n\n\n\n",["P",{},"Please ",["STRONG",{},"DO NOT"]," place any of the following items in the ",["STRONG",{},"COMPOSTABLES"]," bin:"],"\n\n\n\n",["UL",{},["LI",{},"Soil and mud"],["LI",{},"Food packaging"],["LI",{},"Animal waste"]],"\n\n\n\n",["P",{},"Please ",["STRONG",{},"DO NOT"]," place any of the following items in the ",["STRONG",{},"NON RECYCLABLES"]," bin:"],"\n\n\n\n",["UL",{},["LI",{},"Building materials / rubble"],["LI",{},"Tiles"],["LI",{},"Plasterboard"]],"\n\n\n\n",["P",{},"These lists are not exhaustive. If you are unsure about a particular item please check the 'What goes where?' page or the A-Z of materials tool in the Related Content section."],"\n\n\n\n",["P",{},"*Any photographs taken will be done so for purposes connected to the Council’s waste collection service, including but not limited to compliance with Council policy and the Environmental Protection Act 1990.  This initiative is to be implemented for the benefit of the public, to ensure that bin collections are carried out fairly and efficiently, and to resolve any dispute. Any photograph taken will comply with the relevant privacy and data protection laws."],"\n\n\n\n",["H2",{"id":"side-waste"},"Side waste"],"\n\n\n\n",["P",{},"Additional waste left next to or on top of your bins will not be collected."],"\n\n\n\n",["P",{},"The only exceptions on your recyclables collection day:"],"\n\n\n\n",["UL",{},["LI",{},"Recyclable materials presented in a blue box (from the previous recycling scheme) - if the blue box is missed we will not be able to return to empty it until your next scheduled collection day."],["LI",{},"Textiles in blue sacks (please see the kerbside textiles section on the ",["A",{"href":"/what-goes-where","data-type":"[EN] basic_page","data-id":"324"},"'what goes where' page"],")"]],"\n\n\n\n",["P",{},"During the Christmas and New Year period, residents will be advised if and when additional waste is collected. This will appear on the relevant collection calendar."],"\n\n\n\n",["H2",{"id":"missed-bins"},"Missed bins"],"\n\n\n\n",["P",{},"If your bin was missed, but was not contaminated and there was no side waste, then it may have been missed due to one of the following reasons:"],"\n\n\n\n",["UL",{},["LI",{},"The bin was not presented at the boundary of your property"],["LI",{},"The bin was not presented by 7am on your collection day"],["LI",{},"The incorrect bin was presented"],["LI",{},"The crew were unable to collect the bin due to an obstruction (e.g. access blocked by a vehicle)"],["LI",{},"The bin was too heavy"]],"\n\n\n\n",["P",{},"If the collection crew arrive at the property to find that the bin is not presented correctly, they will make a note of the problem they have identified on their electronic device and on some occasions may take a photograph for our records*."],"\n\n\n\n",["P",{},"If you believe that your bin was genuinely missed, please report it within two working days following your scheduled collection day using the on line form in Related Content."],"\n\n\n\n",["P",{},["BR"],"If a missed collection is not reported within the two working days the bin will not be emptied until the next scheduled collection day."],"\n\n\n\n",["P",{},"*Any photographs taken will be done so for purposes connected to the Council’s waste collection service, including but not limited to compliance with Council policy and the Environmental Protection Act 1990.  This initiative is to be implemented for the benefit of the public, to ensure that bin collections are carried out fairly and efficiently, and to resolve any dispute. Any photograph taken will comply with the relevant privacy and data protection laws"],"\n\n\n\n",["P",{},"If you are unable to report a missed bin online please e-mail ",["A",{"href":"mailto:customerservices@rochford.gov.uk"},"customerservices@rochford.gov.uk"]," and you will be contacted, alternatively, you can call 01702 318191."],"\n\n\n\n",["H2",{"id":"special-collections"},"Special collections"],"\n\n\n\n",["P",{},["STRONG",{},"Assisted collections"]],"\n\n\n\n",["P",{},"If you are physically unable to move your bins, and have no able bodied person to help you, you can apply for an assisted collection. This means that the collection crew will collect your bins from a specified area on your property and return the to the same place after emptying them."],"\n\n\n\n",["P",{},"Please complete the form in the Related Content section to arrange this."],"\n\n\n\n",["P",{},["STRONG",{},"Exemptions"]],"\n\n\n\n",["P",{},"If you are unable to separate out your waste due to any medical conditions, you can apply for an exemption from the scheme. This means you will be provided with one large non recyclables bin to place all of your waste into, and this will be collected fortnightly on your normal non recyclables collection day."],"\n\n\n\n",["P",{},"Please complete the form in the Related Content section to arrange this."],"\n\n\n\n",["H2",{"id":"charges-for-bins-in-new-properties"},"Charges for bins in new properties"],"\n\n\n\n",["P",{},"New properties in the District are provided with a set of three bins, which are paid for by the developer or the householder."],"\n\n\n\n",["P",{},"If you have moved into a new property and wheeled bins have not been provided, please contact the developer to find out if they have paid for the bins for your property. If the developer has not paid the householder will need to order and pay for a set of bins."],"\n\n\n\n",["P",{},"The bins remain the property of Rochford District Council and cannot be taken with the resident if they move."],"\n\n\n\n",["H2",{"id":"bin-deliveries-and-repairs"},"Bin Deliveries and Repairs"],"\n\n\n\n",["P",{},"Please report your missing or broken bin using the on line form in Related Content."],"\n\n\n\n",["P",{},"If you are unable to report a Bin Repair or Delivery online please e-mail ",["A",{"href":"mailto:customerservices@rochford.gov.uk"},"customerservices@rochford.gov.uk"]," and you will be contacted, alternatively, you can call 01702 318191."],"\n\n\n\n",["H2",{"id":"other-waste-related-collection-queries-or-complaints"},"Other Waste Related Collection Queries or Complaints"],"\n\n\n\n",["P",{},"For other waste collection queries or complaints please e-mail ",["A",{"href":"mailto:customerservices@rochford.gov.uk"},"customerservices@rochford.gov.uk"]," and yo