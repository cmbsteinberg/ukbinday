"class":"content-inner"},"\n\n          ","\n\n         ",["SECTION",{"id":"main-content"},"\n\n          \n            ",["HEADER",{"id":"main-content-header","class":"clearfix"},"\n\n                                ",["H1",{"id":"page-title"},"\n                Food waste recycling - weekly collection                "],"\n              \n  \n            "],"\n\n          ","\n                        ",["DIV",{"id":"content","class":"region"},"\n            ",["SECTION",{"id":"block-views-eforms-on-a-node-block","class":"block block-views bk-bht odd first block-count-4 block-region-content block-eforms-on-a-node-block"},"  \n      ",["H2",{"class":"block-title"},"Forms"],"\n  \n  ",["DIV",{"class":"view view-eforms-on-a-node view-id-eforms_on_a_node view-display-id-block view-dom-id-30330c2d28089637a98c828b8b8182ea"},"\n        \n  \n  \n      ",["DIV",{"class":"view-content"},"\n        ",["DIV",{"class":"views-row views-row-1 views-row-odd views-row-first"},"\n      \n  ",["DIV",{"class":"views-field views-field-field-link-to-form"},"        ",["DIV",{"class":"field-content"},["A",{"href":"https://iportal.itouchvision.com/icustomer/?cuid=D3A2EAB39CE0CD93644005BE063F50E0A8C0DCE9&lang=en","title":"Report a missed collection","target":"_blank","data-extlink":"","rel":"noopener noreferrer"},"Report a missed collection",["SPAN",{"class":"ext"},["SPAN",{"class":"element-invisible"},"(link is external)"]]]],"  "],"  "],"\n  ",["DIV",{"class":"views-row views-row-2 views-row-even views-row-last"},"\n      \n  ",["DIV",{"class":"views-field views-field-field-link-to-form"},"        ",["DIV",{"class":"field-content"},["A",{"href":"https://iportal.itouchvision.com/icustomer/?cuid=32F359515BCC71C43EE05636F508B08FA8C060A9&lang=en","title":"Request a replacement container","target":"_blank","data-extlink":"","rel":"noopener noreferrer"},"Request a replacement container",["SPAN",{"class":"ext"},["SPAN",{"class":"element-invisible"},"(link is external)"]]]],"  "],"  "],"\n    "],"\n  \n  \n  \n  \n  \n  \n"],"\n  "],["DIV",{"id":"block-system-main","class":"block block-system no-title even last block-count-5 block-region-content block-main"},"  \n  \n  ",["DIV",{"about":"https://www.epsom-ewell.gov.uk/residents/recycling-and-waste/simply-weekly-recycling/food-waste-recycling-weekly-collection","typeof":"foaf:Document","role":"article","class":"ds-1col node node-page article odd node-full view-mode-full clearfix"},"\n\n  \n  ",["DIV",{"class":"field field-name-body field-type-text-with-summary field-label-hidden view-mode-full"},["DIV",{"class":"field-items"},["DIV",{"class":"field-item even","property":"content:encoded"},["H2",{},"Weekly food waste recycling"],"\n\n",["P",{},"Leave your bins out in a clearly visible place at the edge of your property by 6.30am on ",["A",{"href":"http://maps.epsom-ewell.gov.uk/myeebc.aspx"},"collection day"],". we work as normal on bank holiday Mondays and Good Friday. ",["A",{"href":"https://www.epsom-ewell.gov.uk/residents/recycling-and-waste/simply-weekly-recycling/what-happens-if-collection-missed"},"What if a collection is missed?"]," "],"\n\n",["DIV",{"class":"row","style":"border-bottom:solid green; display:flex"},"\n\t",["DIV",{"class":"col","style":"flex:1; max-width:10%; padding:1em"},"\n\t\t",["P",{},["IMG",{"__playwright_current_src__":"https://www.epsom-ewell.gov.uk/sites/default/files/pictures/Recycling/SWR%20food%20bin23.png","alt":"Picture of food waste recycling bin","src":"/sites/default/files/pictures/Recycling/SWR%20food%20bin23.png","style":"float:left; height:auto; width:100%"}]],"\n\t"],"\n\n\t",["DIV",{"class":"col","style":"flex:1; padding:1em"},"\n\t\t",["P",{},"For all food waste, cooked or uncooked, such as meat, fish, vegetables, bones, plate scrapings. ",["STRONG",{},"NO BULK LIQUIDS PLEASE "],"such as soup or milk. ",["STRONG",{},"NO PACKAGING"],"."],"\n\n\t\t",["P",{},"You can line your food caddy with plastic bags if you like. ",["A",{"href":"https://www.epsom-ewell.gov.uk/why-it-ok-put-plastic-bags-food-waste-not-green-recycling-bin"},"Why is it OK to use plastic bags to line your food waste bin, but not to recycle plastic bags in your green mixed recycling bin?"]],"\n\n\t\t",["P",{},["STRONG",{},"DON'T "],"put your food in your ",["A",{"href":"https://www.epsom-ewell.gov.uk/residents/recycling-and-waste/simply-weekly-recycling/mixed-recycling-bin-weekly-collection"},"big, green mixed recycling bin"],". It can't be separated from the other stuff, and ruins the rest of the recycling. ",["A",{"href":"https://www.epsom-ewell.gov.uk/residents/recycling-and-waste/simply-weekly-recycling"},"Right thing, right bin"],"."],"\n\t"],"\n"],"\n\n",["H2",{},"Helping you to recycle your food waste"],"\n\n",["P",{},["IMG",{"__playwright_current_src__":"https://www.epsom-ewell.gov.uk/sites/default/files/pictures/Recycling/SWR%20food%20kitchen%20caddy5.png","alt":"Picture of kitchen caddy for food waste recycling","src":"/sites/default/files/pictures/Recycling/SWR%20food%20kitchen%20caddy5.png","style":"height:50px; width:45px"}]," We supply silver kitchen caddies free of charge; please use our form at the top of this page to request one. Or you can use your own if you prefer a different design."],"\n\n",["P",{},"You can line your kitchen caddy with plastic bags or plastic liners (please note we do not supply liners, but these are widely available in supermarkets and other shops). ",["A",{"href":"https://www.epsom-ewell.gov.uk/why-it-ok-put-plastic-bags-food-waste-not-green-recycling-bin"},"Why is it OK to use plastic bags to line your kitchen caddy, but not to recycle them in your green mixed recycling bin?"]],"\n\n",["H2",{},"Quick guide to recycling"],"\n\n",["P",{},["A",{"href":"https://www.surreyep.org.uk/what-to-do-with-an-item/","target":"_blank","rel":"noopener noreferrer"},["IMG",{"__playwright_current_src__":"https://dabuttonfactory.com/button.png?t=Where+can+I+recycle+it%3F&f=Zenhei&ts=26&tc=fff&hp=45&vp=20&c=4&bgt=gradient&bgc=42a435&ebgc=274e13","alt":"Where can I recycle it?","src":"https://dabuttonfactory.com/button.png?t=Where+can+I+recycle+it%3F&f=Zenhei&ts=26&tc=fff&hp=45&vp=20&c=4&bgt=gradient&bgc=42a435&ebgc=274e13","style":"height:66px; width:345px"}]]],"\n\n",["P",{},["A",{"href":"http://www.surreyep.org.uk/reduce-reuse-recycle/more-hints-and-tips/","data-extlink":"","target":"_blank","rel":"noopener noreferrer"},"What if the Council can't recycle it?",["SPAN",{"class":"ext"},["SPAN",{"class":"element-invisible"},"(link is external)"]]]],"\n\n",["H2",{},"Please don't recycle:"],"\n\n",["UL",{},"\n\t",["LI",{},"Bulk liquids like large amounts of milk or soup. This is because it's difficult and messy for our staff to handle"],"\n\t",["LI",{},"Packaging. You can line your bin or caddy with a plastic bag or liner. But do not recycle other packaging in this bin. ",["A",{"href":"https://www.epsom-ewell.gov.uk/residents/recycling-and-waste/simply-weekly-recycling/mixed-recycling-bin-weekly-collection"},"Recycle cardboard, and some plastics"],"."],"\n"],"\n\n",["H2",{},"More"],"\n\n",["UL",{},"\n\t",["LI",{},["A",{"href":"https://www.surreyep.org.uk/reduce-reuse-recycle/food/simple-tips-to-reduce-food-waste/","data-extlink":"","target":"_blank","rel":"noopener noreferrer"},"Simple tips to reduce food waste",["SPAN",{"class":"ext"},["SPAN",{"class":"element-invisible"},"(link is external)"]]]],"\n\t",["LI",{},["A",{"href":"https://www.epsom-ewell.gov.uk/residents/recycling-and-waste/recycling-out-and-about"},"Recycling out and about"]],"\n\t",["LI",{},["A",{"href":"https://www.epsom-ewell.gov.uk/residents/recycling-and-waste/simply-weekly-recycling/can-i-have-additional-bins"},"Can I have an extra bin?"]],"\n\t",["LI",{},["A",{"href":"https://www.epsom-ewell.gov.uk/residents/recycling-and-waste/simply-weekly-recycling/help-disabled-or-elderly"},"Help for the disabled or elderly"]],"\n\t",["LI",{},["A",{"href":"https://www.epsom-ewell.gov.uk/what-happens-your-recycling"},"What happens to my recycling?"]],"\n\t",["LI",{},["A",{"href":"https://www.epsom-ewell.gov.uk/learn-about-recycling-and-waste"},"Learn more about recycling and waste"]],"\n"],"\n\n",["P",{},["IMG",{"__playwright_current_src__":"https://www.epsom-ewell.gov.uk/sites/default/files/pictures/Recycling/Simply%20Weekly%20Recycling%20logo.jpg","alt":"Simply weekly recycling logo","src":"/sites/default/files/pictures/Recycling/Simply%20Weekly%20Recycling%20logo.jpg","style":"height:110px; width:150px"}],";"],"\n\n",["P",{},["IMG",{"__playwright_current_src__":"https://www.epsom-ewell.gov.uk/sites/default/files/pictures/Recycling/Recycle%20for%20Surrey%20green.jpg","alt":"Recycle for Surrey logo","src":"/sites/default/files/pictures/Recycling/Recycle%20for%20Surrey%20green.jpg","style":"height:22px; width:150px"}]],"\n"]]]],"\n\n\n  "],"            "],"\n\n          ","\n          \n\n          "],"\n\n          ","\n",["DIV",{"class":"region region-content-aside"},["DIV",{"class":"region-inner clearfix"},["SECTION",{"id":"block-cck-blocks-field-documents","class":"block block-cck-blocks bk-bht no-bhd odd first last block-count-6 block-region-content-aside block-field-documents"},["DIV",{"class":"block-inner clearfix"},"  \n      ",["H2",{"class":"block-title"},"Documents"],"\n  \n  ",["DIV",{"class":"block-content content"},["DIV",{"class":"field field-name-field-documents field-type-file field-label-hidden view-mode-cck_blocks"},["DIV",{"class":"field-items"},["DIV",{"class":"field-item even"},["TABLE",{"class":"sticky-header","style":"position: fixed; top: 0px; left: 180px; visibility: hidden;"},["THEAD",{"style":""},["TR",{},["TH",{},"Attachment"],["TH",{},"Size"]," "]]],["TABLE",{"class":"sticky-enabled tableheader-processed sticky-table"},"\n ",["THEAD",{},["TR",{},["TH",{},"Attachment"],["TH",{},"Size"]," "]],"\n",["TBODY",{},"\n ",["TR",{"class":"odd"},["TD",{},["SPAN",{"class":"file"},["IMG",{"__playwright_current_src__":"https://www.epsom-ewell.gov.uk/modules/file/icons/application-pdf.png","cl