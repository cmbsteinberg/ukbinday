lass":"main-title"},"Check collection dates"],"\n"],"\n",["STYLE",{},"\n    a.btn.btn-primary {\n        text-decoration: none !important;\n    }\n\n    .drop-shadow {\n        border: navy solid 4px;\n        border-top-right-radius: 4px;\n        border-top-left-radius: 4px;\n        box-shadow: 1px 2px 2px rgb(25 68 118 / 5%), 2px 4px 4px rgb(25 68 118 / 5%), 4px 8px 8px rgb(25 68 118 / 5%) !important;\n        padding-bottom: 15px;\n        padding-top: 1px;\n    }\n\n\n    .form-area h2 {\n        background: #f4f4f4;\n        height: auto;\n        margin: 0;\n        padding-top: 7px;\n        padding-bottom: 7px;\n        padding-left: 10px;\n    }\n\n    .message-body h2 {\n        padding-left: 15px;\n        padding-right: 15px;\n    }\n\n    .message-body {\n        padding-left: 15px;\n        padding-right: 15px;\n    }\n\n    .form-container {\n        padding-top: 15px;\n    }\n    \n    i.fa.fa-play {\n    padding-left: 10px;\n}\n\n"],"\n",["DIV",{"class":"form-container"},"\n    ",["DIV",{"class":"form-area drop-shadow"},"\n\n\n        \n            ",["H2",{},"Find - Collection Day and Calendar Download"],"\n        ",["DIV",{"class":"message-body"},"\n            ",["H3",{},"What you need to know"],"\n             ",["P",{},["SPAN",{},"To find out your waste and recycling collection day and "],["SPAN",{},["STRONG",{},"download your 2024/25 waste calendar "],"use this facility. "]],"\n",["P",{},["SPAN",{},"If you would like to receive weekly collection day reminders you can subscribe to this if you register."]],"\n            ",["BR"],"\n\n            ",["H3",{},"What we need"],"\n                ",["P",{},"Your postcode and address. If you would like to register to receive weekly collection date reminders we will require your email address. "],"\n",["P",{},"Use the ",["STRONG",{},"Start button"]," to lookup up your calendar and ",["STRONG",{},"download"],"."],"\n            ",["BR"],"\n            ",["BR"],"\n            ",["DIV",{"class":"onlineformbuttons"},"\n                ",["A",{"href":"https://my.middevon.gov.uk/en/AchieveForms/?form_uri=sandbox-publish://AF-Process-2289dd06-9a12-4202-ba09-857fe756f6bd/AF-Stage-eb382015-001c-415d-beda-84f796dbb167/definition.json&redirectlink=%2Fen&cancelRedirectLink=%2Fen&consentMessage=yes","title":"Collection Day and Calendar Download","class":"btn btn-primary"},"Start ",["I",{"class":"fa fa-play","aria-hidden":"true"}]],"\n            "],"\n\n            ",["H3",{},"Other ways to Apply"],"\n        ",["P",{},"Online is the best way to apply as you can update your details or view the status of the active service."],"\n",["P",{},"Alternatively you can contact our customer services team on 01884 255255."],"\n        "],"\n    "],"\n"],"\n",["H2",{},"Presenting your waste and recycling containers for collection"],"\n",["P",{},"Please remember to put your waste and recycling containers out at the kerbside where they can be seen easily, ",["STRONG",{},"either after 6.00pm the night before, or before 6.00am"]," ",["STRONG",{},"on your collection day"],". Please take care not to obstruct pavements or roads, and take containers back in as soon as possible after collections. Bin lids should be closed and only waste in the bin will be collected. Extra waste on top or alongside will not usually be taken. If you occasionally have extra refuse, this can be saved until your next collection."],"\n",["H2",{},"Missed collection updates"],"\n",["P",{}," Occasionally, we may be unable to complete a round on the scheduled day. Updates are available on our website, please check the",["A",{"data-udi":"umb://document/ddd80e23ba2b4423a97c2f89694ac078","href":"/residents/recycling-rubbish/report-a-missed-collection/daily-waste-collection-updates/"}," daily waste collection updates"]," webpage before ",["A",{"data-udi":"umb://document/e06b36b49d8d4a43be74b31d6e602e57","href":"/residents/recycling-rubbish/report-a-missed-collection/"},"reporting a missed collection"],"."],"\n\n\t\n\t\t"],"