","tabindex":"0","method":"add","operand":"1"},"Section 1"]," "]]],["SECTION",{"class":"all-sections col-xs-12 AF-col-xs-fluid col-sm-12"},["SECTION",{"class":"fields render"},["DIV",{"class":"field fs-hidden","data-field-name":"channel","data-field-type":"text","style":"padding-top: 0px;"},["DIV",{"class":"fieldContent"},["LABEL",{"id":"label_channel","for":"channel","class":"col-xs-11 col-sm-11  fieldName alignAbove\t\t","style":"display: none;"},["SPAN",{"class":"_fieldName","style":"display: none;"},"channel"],"\t\t\t\t"],"\t",["DIV",{"class":"af-block col-xs-1 col-sm-1 ","style":"display: none;"}],["INPUT",{"__playwright_value_":"","type":"text","data-type":"text","name":"channel","id":"channel","data-name":"channel","aria-labelledby":"label_channel channel prefix_channel helpText_channel","readonly":"true","class":"col-xs-11 col-sm-11     fs-hidden-field alignAbove fieldInput text read_only_field ","data-hidden":"true","data-default-value":"Self","data-output-format":"normal","data-mandatory-message":"This field is required","data-min-message":"Please input at least _min_value_ characters","data-max-message":"Please input no more than _max_value_ characters","data-validation-mask-message":"Please input text of the format: _validation_mask_","autocomplete":"off","style":"display: none;"}],["DIV",{"class":"screen-reader-error","aria-live":"polite","aria-atomic":"true","style":"display: none;"}]]],["DIV",{"class":"field fs-hidden","data-field-name":"formName","data-field-type":"text","style":"padding-top: 0px;"},["DIV",{"class":"fieldContent"},["LABEL",{"id":"label_formName","for":"formName","class":"col-xs-11 col-sm-11  fieldName alignAbove\t\t","style":"display: none;"},["SPAN",{"class":"_fieldName","style":"display: none;"},"formName"],"\t\t\t\t"],"\t",["DIV",{"class":"af-block col-xs-1 col-sm-1 ","style":"display: none;"}],["INPUT",{"__playwright_value_":"","type":"text","data-type":"text","name":"formName","id":"formName","data-name":"formName","aria-labelledby":"label_formName formName prefix_formName helpText_formName","readonly":"true","class":"col-xs-11 col-sm-11     fs-hidden-field alignAbove fieldInput text read_only_field ","data-hidden":"true","data-default-value":"{parent_form_name}","data-output-format":"normal","data-mandatory-message":"This field is required","data-min-message":"Please input at least _min_value_ characters","data-max-message":"Please input no more than _max_value_ characters","data-validation-mask-message":"Please input text of the format: _validation_mask_","autocomplete":"off","style":"display: none;"}],["DIV",{"class":"screen-reader-error","aria-live":"polite","aria-atomic":"true","style":"display: none;"}]]],["DIV",{"class":"field fs-hidden","data-field-name":"processName","data-field-type":"text","style":"padding-top: 0px;"},["DIV",{"class":"fieldContent"},["LABEL",{"id":"label_processName","for":"processName","class":"col-xs-11 col-sm-11  fieldName alignAbove\t\t","style":"display: none;"},["SPAN",{"class":"_fieldName","style":"display: none;"},"processName"],"\t\t\t\t"],"\t",["DIV",{"class":"af-block col-xs-1 col-sm-1 ","style":"display: none;"}],["INPUT",{"__playwright_value_":"","type":"text","data-type":"text","name":"processName","id":"processName","data-name":"processName","aria-labelledby":"label_processName processName prefix_processName helpText_processName","readonly":"true","class":"col-xs-11 col-sm-11     fs-hidden-field alignAbove fieldInput text read_only_field ","data-hidden":"true","data-default-value":"{process_name}","data-output-format":"normal","data-mandatory-message":"This field is required","data-min-message":"Please input at least _min_value_ characters","data-max-message":"Please input no more than _max_value_ characters","data-validation-mask-message":"Please input text of the format: _validation_mask_","autocomplete":"off","style":"display: none;"}],["DIV",{"class":"screen-reader-error","aria-live":"polite","aria-atomic":"true","style":"display: none;"}]]],["DIV",{"class":"field fs-hidden","data-field-name":"processID","data-field-type":"text","style":"padding-top: 0px;"},["DIV",{"class":"fieldContent"},["LABEL",{"id":"label_processID","for":"processID","class":"col-xs-11 col-sm-11  fieldName alignAbove\t\t","style":"display: none;"},["SPAN",{"class":"_fieldName","style":"display: none;"},"processID"],"\t\t\t\t"],"\t",["DIV",{"class":"af-block col-xs-1 col-sm-1 ","style":"display: none;"}],["INPUT",{"__playwright_value_":"","type":"text","data-type":"text","name":"processID","id":"processID","data-name":"processID","aria-labelledby":"label_processID processID prefix_processID helpText_processID","readonly":"true","class":"col-xs-11 col-sm-11     fs-hidden-field alignAbove fieldInput text read_only_field ","data-hidden":"true","data-default-value":"{process_id}","data-output-format":"normal","data-mandatory-message":"This field is required","data-min-message":"Please input at least _min_value_ characters","data-max-message":"Please input no more than _max_value_ characters","data-validation-mask-message":"Please input text of the format: _validation_mask_","autocomplete":"off","style":"display: none;"}],["DIV",{"class":"screen-reader-error","aria-live":"polite","aria-atomic":"true","style":"display: none;"}]]],["DIV",{"class":"field fs-hidden","data-field-name":"caseReference","data-field-type":"text","style":"padding-top: 0px;"},["DIV",{"class":"fieldContent"},["LABEL",{"id":"label_caseReference","for":"caseReference","class":"col-xs-11 col-sm-11  fieldName alignAbove\t\t","style":"display: none;"},["SPAN",{"class":"_fieldName","style":"display: none;"},"caseReference"],"\t\t\t\t"],"\t",["DIV",{"class":"af-block col-xs-1 col-sm-1 ","style":"display: none;"}],["INPUT",{"__playwright_value_":"","type":"text","data-type":"text","name":"caseReference","id":"caseReference","data-name":"caseReference","aria-labelledby":"label_caseReference caseReference prefix_caseReference helpText_caseReference","readonly":"true","class":"col-xs-11 col-sm-11     fs-hidden-field alignAbove fieldInput text read_only_field ","data-hidden":"true","data-default-value":"{reference}","data-output-format":"normal","data-mandatory-message":"This field is required","data-min-message":"Please input at least _min_value_ characters","data-max-message":"Please input no more than _max_value_ characters","data-validation-mask-message":"Please input text of the format: _validation_mask_","autocomplete":"off","style":"display: none;"}],["DIV",{"class":"screen-reader-error","aria-live":"polite","aria-atomic":"true","style":"display: none;"}]]],["DIV",{"class":"field fs-hidden","data-field-name":"binUPRN","data-field-type":"text","style":"padding-top: 0px;"},["DIV",{"class":"fieldContent"},["LABEL",{"id":"label_binUPRN","for":"binUPRN","class":"col-xs-11 col-sm-4   fieldName alignLeft\t\t","style":"display: none;"},["SPAN",{"class":"_fieldName","style":"display: none;"},"binUPRN"],"\t\t\t\t"],"\t",["DIV",{"class":"af-block col-xs-1 col-sm-1 hidden-sm hidden-md hidden-lg","style":"display: none;"}],["INPUT",{"__playwright_value_":"","type":"text","data-type":"text","name":"binUPRN","id":"binUPRN","data-name":"binUPRN","aria-labelledby":"label_binUPRN binUPRN prefix_binUPRN helpText_binUPRN","readonly":"true","class":"col-xs-11 col-sm-7     fs-hidden-field UPRN alignLeft fieldInput text read_only_field ","data-hidden":"true","data-default-value":"{UPRN}","data-output-format":"normal","data-mandatory-message":"This field is required","data-min-message":"Please input at least _min_value_ characters","data-max-message":"Please input no more than _max_value_ characters","data-validation-mask-message":"Please input text of the format: _validation_mask_","autocomplete":"off","style":"display: none;"}],["DIV",{"class":"screen-reader-error","aria-live":"polite","aria-atomic":"true","style":"display: none;"}]]],["DIV",{"class":"field","data-field-name":"html11","data-field-type":"html"},["DIV",{"class":"fieldContent"},"\t",["SPAN",{"data-name":"html11","data-type":"html","class":"col-xs-11 col-sm-11 fieldInput content html non-input ","data-content":"<style>\n#bin-schedule-content {\n    font-size: 12pt;\n}\n\n#bin-schedule-content h3 {\n    padding-bottom: 20px;\n}\n\n.bin-schedule-content-service-card, .bin-schedule-content-bin-card {\n    padding-bottom: 20px;\n}\n\n.bin-schedule-content-bin-card {\n    display: flex;\n    flex-wrap: nowrap;\n}\n\n.bin-schedule-content-bin-card img {\n    height: 100px;\n}\n\n.bin-schedule-content-info p {\n    width: 100%;\n    padding-left: 20px;\n}\n\n@media only screen and (min-width: 768px) {\n    .bin-schedule-content-info {\n        padding-top: 15px;\n    }\n    \n}\n</style>\n<div id=\"bin-schedule-content\"></div>  \n<script>\n//Saves the ran integration in a list\nvar cacheIntRun = (integration) => {\n    intRunCache.push(integration)\n}\n\n//Takes the log of integrations that have run and adds them to the db\nvar logIntRun = () => {\n    var payload = {\n        \"caseReference\": {\n            \"name\": \"caseReference\",\n            \"value\": getTokenValue('caseReference')\n        },\n        \"integrationName\": {\n            \"name\": \"integrationName\",\n            \"value\": intRunCache.join(',')\n        },\n        \"processName\": {\n            \"name\": \"processName\",\n            \"value\": getTokenValue('processName')\n        },\n        \"formName\": {\n            \"name\": \"formName\",\n            \"value\": getTokenValue('formName')\n        }\n    }\n \n    runLookup('611e0a754e66e', payload)\n\n    intRunCache = []\n}\n\n//If a token exists on the form, it retrieve it's value, otherwise, it return ''\nvar getTokenValue = (name) => {\n    var value = ''\n    try {\n        value = $(`input[name=\"${name}\"]`)[0].value\n    } catch (error) {\n        value = ''\n    }\n    return value\n}\n\n//Takes the lookup ID and data, runs the integration and returns the data\nvar runLookup = (lookupId, data = {}) => {\n    return new Promise((resolve, reject) => {\n        var vurl = '/apibroker/runLookup?id=' + lookupId + '&repeat_against=&noRetry=false&getOnlyTokens=undefined&log_id=&app_name=AchieveForms&_=' + randoms + '&sid=' + sessions;\n        var vdata = {\n            \"formValues\": {\n                \"Section 1\": data\n            },\n            \"usePHPIntegrations\": true,\n            \"formName\": getTokenValue('formName'),\n            \"processId\": getTokenValue('processID'),\n            \"tokens\": {\n                \"port\": \"\"\n            },\n            \"env_tokens\": {},\n            \"processName\": getTokenValue('processName'),\n            \"created\": \"\",\n            \"reference\": \"AJAX\",\n            \"formUri\": \"\"\n        };\n        $.ajax({\n            url: vurl,\n            dataType: 'json',\n            method: 'POST',\n            data: JSON.stringify(vdata),\n            contentType: 'text/json',\n            processData: false,\n            error: function(e) {\n                var result = {\n                    hasRan: true,\n                    success: false,\n                    data: e\n                }\n                console.log(e)\n                resolve(result)\n            },\n            success: function(doc) {\n                var result = {\n                    hasRan: true,\n                    success: false,\n                    data: doc\n                }\n                try {\n                    result.data = doc.integration.transformed.rows_data\n                    result.success = true\n                    resolve(result)\n                } catch (error) {\n                    resolve(result)\n                }\n            }\n        })\n    })\n}\n\nvar randomString = (e) => {\n    var t = \"xxxxxxxx-xxxx-4xxx-yxxx-xxxxxxxxxxxx\".replace(/[xy]/g, function(e) {\n        var t, n;\n        return t = 16 * Math.random() | 0,\n            n = \"x\" === e ? t : 3 & t | 8,\n            n.toString(16)\n    });\n    return e ? t.replace(/\\-/g, \"\").substring(0, e) : t\n}\n\nvar retrieveSessionId = new Promise((resolve, reject) => {\n    var url = '/authapi/isauthenticated?uri=' + location.href + '&hostname=' + location.hostname + '&withCredentials=true'\n    $.ajax({\n        url: url,\n        dataType: 'json',\n        method: 'GET',\n        contentType: 'text/json',\n        processData: false,\n        error: function(e) {\n            console.log(e);\n            alert('there was an error while fetching');\n            reject(e)\n        },\n        success: function(doc) {\n            resolve(doc['auth-session'])\n        }\n    });\n})\n\nvar randoms = randomString(13);\nvar sessions = ''\nvar intRunCache = []\n\nretrieveSessionId.then((value) => {\n    sessions = value\n})\n\n//Display the error message if data isn't returned properly\nvar displayError = () => {\n    logIntRun()\n    \n\t$('#bin-schedule-content').empty().append('<p>Bin schedule is not available at the moment. Please try again later.</p>')\n}\n\nvar displayResults = (results, resultKeys, round, propertyDataResponse, attributes) => {\n    var content = ''\n    \n    var options = { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' }\n\n    content += '<div class=\"bin-schedule-content-service-card\"><h3>Your collection schedule</h3>'\n    \n    for (var a in resultKeys) {\n        var i = resultKeys[a][0]\n        \n        var service = results[i]\n        \n        if (service.hasOwnProperty('nextCollectionDate')) {\n            \n            var nextCollectionDate = service.nextCollectionDate.toLocaleDateString(undefined, options)\n            \n            var icon = ''\n    \t\t\n            if (i.trim() == 'Domestic') {\n                icon = 'https://qwestservices-cwac-webobjects.s3.eu-west-2.amazonaws.com/self-landing-page/assets/Bin%20Collection%20Schedule%20Icons/Customer%20Portal_Domestic%20Bin.svg'\n            } else if (i.trim() == 'Recycling') {\n                icon = 'https://qwestservices-cwac-webobjects.s3.eu-west-2.amazonaws.com/self-landing-page/assets/Bin%20Collection%20Schedule%20Icons/Customer%20Portal_Recycling%20Bin.png'\n            } else if (i.trim() == 'Garden') {\n                icon = 'https://qwestservices-cwac-webobjects.s3.eu-west-2.amazonaws.com/self-landing-page/assets/Bin%20Collection%20Schedule%20Icons/Customer%20Portal_Green%20Bin.svg'\n            } else if (i.trim() == 'Food') {\n                icon = 'https://qwestservices-cwac-webobjects.s3.eu-west-2.amazonaws.com/self-landing-page/assets/Bin%20Collection%20Schedule%20Icons/Customer%20Portal_Food%20Caddy.svg'\n            }\n            \n            if (service.nextCollectionDate >= new Date(2025, 2, 10) || i.trim() != 'Garden') {\n                content += '<div class=\"bin-schedule-content-bin-card\">'\n                content += '<img src=\"' + icon + '\" alt=\"' + i + ' icon\">'\n                content += '<div class=\"bin-schedule-content-info\"><p>' + i + '</p><p>Next collection: ' + nextCollectionDate + '</p></div>'\n                content += '</div>'                \n            }\n            \n\n        }\n    }\n        \n    content += '</div>'\n    \n    content += '<p>Please ensure your containers are put out before 6am on the day of collection.</p>'\n    \n    var attributesRegex = new RegExp(attributes.join( \"|\" ), \"i\");\n    \n    if (round.letter != '' && round.day != '') {\n        if(attributesRegex.test('WEEKLY RECYCLING') && attributes.length > 0) {\n            content += '<p><span style=\"font-size: 14pt;\"><a target=\"_parent\" href=\"https://www.cheshirewestandchester.gov.uk/asset-library/waste-calendars/weekly-recycling-' + round.day + '-' + round.letter + '.PDF\">View your calendar</a></span></p>'\n        } else {\n            content += '<p><span style=\"font-size: 14pt;\"><a target=\"_parent\" href=\"https://www.cheshirewestandchester.gov.uk/asset-library/waste-calendars/' + round.day + '-' + round.letter + '.PDF\">View your calendar</a></span></p>'\n        }\n        \n        if (propertyDataResponse[0].gardenPermitSubscribed === 'True') {\n            if (attributesRegex.test('Narrows service') && attributes.length > 0) {\n                content += '<p><span style=\"font-size: 14pt;\"><a target=\"_parent\" href=\"https://www.cheshirewestandchester.gov.uk/asset-library/waste-calendars/garden-waste-weekly-recycling-' + round.dayGarden + '.PDF\">View your garden waste calendar</a></span></p>'\n            } else {\n                content += '<p><span style=\"font-size: 14pt;\"><a target=\"_parent\" href=\"https://www.cheshirewestandchester.gov.uk/asset-library/waste-calendars/garden-waste-' + round.dayGarden + '-' + round.letterGarden + '.PDF\">View your garden waste calendar</a></span></p>'\n            }\n        }\n    }\n\n    \n    \n    $('input[name=\"loading\"]')[0].value = 'False'\n    $('input[name=\"loading\"]').trigger('input')\n        \n    $('#bin-schedule-content').empty().append(content)\n}\n\n//goes through the data returned from each integration and finds the relevant data\nvar sortResults = (featuresScheduleGetResponse, jobsGetResponse, premisesAttributeGetResponse, propertyDataResponse) => {\n    //converts the date into yyyy-mm-dd format\n    var formatDate = (date) => {\n        var d = new Date(date),\n            month = '' + (d.getMonth() + 1),\n            day = '' + d.getDate(),\n            year = d.getFullYear();\n    \n        if (month.length < 2) \n            month = '0' + month;\n        if (day.length < 2) \n            day = '0' + day;\n    \n        return [year, month, day].join('-');\n    }\n    \n    //gets the most common value in an array\n    var mode = (arr) => {\n        return arr.sort((a,b) =>\n              arr.filter(v => v===a).length\n            - arr.filter(v => v===b).length\n        ).pop();\n    }\n    \n    \n    var results = {}\n    let eastTwin08Round = false\n    \n    //add each waste container service into the results object\n    for (var item in featuresScheduleGetResponse) {\n        if (featuresScheduleGetResponse[item].type === 'WASTE CONTAINER') {\n            \n            var currentService = featuresScheduleGetResponse[item]\n            \n            if (currentService.Round === 'EastTwin08') {\n                eastTwin08Round = true\n            }\n            \n            //Add service if not exists\n            if(!results.hasOwnProperty(currentService.service)){\n                results[currentService.service] = {\n                    services: []\n                }\n            }\n\n            //Add round type if not exists or add the round to existing round type\n            if (!results[currentService.service].services.some(e => e.name === currentService.serviceType)) {\n                results[currentService.service].services.push({\n                    name: currentService.serviceType,\n                    rounds: [currentService.Round]\n                })\n            } else if (results[currentService.service].services.some(e => e.name === currentService.serviceType)) {\n                for (var i in results[currentService.service].services) {\n                    if (results[currentService.service].services[i].name === currentService.serviceType) {\n                        results[currentService.service].services[i].rounds.push(currentService.Round)\n                        break\n                    }\n                }\n            }\n\n        }\n    }\n    \n    //holds the weekdays of each collection\n    var collectionDays = {}\n    collectionDays['garden'] = []\n    collectionDays['standard'] = []\n    \n    var today = new Date()\n    today.setHours(0,0,0,0)\n    \n    \n    //add each jobs into the appropriate section in the result object\n    for (var i in results) {\n        \n        for (a in results[i].services) {\n            var type = results[i].services[a].name\n            \n            for (b in results[i].services[a].rounds) {\n                var round = results[i].services[a].rounds[b]\n                \n                for (c in jobsGetResponse) {\n                    //checks if the current job matches the current service type\n\t\t\t\t\tif ((jobsGetResponse[c].round.includes(round) && !eastTwin08Round) || (jobsGetResponse[c].taskName ===type  && eastTwin08Round)) {\n                        var currentJobDate = new Date(formatDate(jobsGetResponse[c].collectionDateTime))\n                        \n\t\t\t\t\t\t//christmas special\n                        if (currentJobDate.getFullYear() === 2024 && currentJobDate.getMonth() === 11) {\n                            if (currentJobDate.getDate() === 25) {\n                                currentJobDate.setDate(21);\n                            } else if (currentJobDate.getDate() === 26) {\n                                currentJobDate.setDate(28);\n                            }\n                        }\n                        if (currentJobDate.getFullYear() === 2025 && currentJobDate.getMonth() === 0) {\n                            if (currentJobDate.getDate() === 1) {\n                                currentJobDate.setDate(4);\n                            }\n                        }\n                        \n                        //sets the next collection date\n                        if (currentJobDate >= today) {\n                            if (!results[i].hasOwnProperty('nextCollectionDate')) {\n                                results[i].nextCollectionDate = currentJobDate\n                                results[i].nextCollectionDateId = jobsGetResponse[c].ID\n                            } else if (results[i].nextCollectionDate > currentJobDate) {\n                                results[i].nextCollectionDate = currentJobDate\n                                results[i].nextCollectionDateId = jobsGetResponse[c].ID\n                            }\n                            \n                            if(i != 'Garden') {\n                                collectionDays['standard'].push(currentJobDate.getDay())\n                            } else {\n                                collectionDays['garden'].push(currentJobDate.getDay())\n                            }    \n    \n                        }\n                        \n                    }\n                }\n                \n            }\n        }\n    }\n    \n    \n    var resultKeys = []\n    \n    for (var i in results) {\n        resultKeys.push([i, results[i].nextCollectionDate])\n    }\n    \n    //sort keys in the results object\n    resultKeys.sort(function(a,b) {\n        return a[1]-b[1]\n    })\n\n    //go through the attributes\n\tlet roundLetter = ''\n\tlet roundLetterGarden = ''\n\tlet roundLetterGardenFound = false\n\tlet attributes = []\n\n\tfor (let i in premisesAttributeGetResponse) {\n\t\tif (premisesAttributeGetResponse[i].Name.includes('WEEK')) {\n\t\t\troundLetter = premisesAttributeGetResponse[i].Name.replace('WEEK ', '')\n\t\t} else if (premisesAttributeGetResponse[i].Name.includes('GARDEN')) {\n\t\t\troundLetterGarden = premisesAttributeGetResponse[i].Name.replace('GARDEN ', '')\n\t\t\troundLetterGardenFound = true\n\t\t}\n\t\t\n\t\tattributes.push(premisesAttributeGetResponse[i].Name)\n\t}\n\t\n\tif (!roundLetterGardenFound) {\n\t    roundLetterGarden = roundLetter\n\t}\n    \n    var weekdayList = [\"Sunday\",\"Monday\",\"Tuesday\",\"Wednesday\",\"Thursday\",\"Friday\",\"Saturday\"]\n\n    var roundObj = {\n        day: weekdayList[mode(collectionDays['standard'])],\n        dayGarden: weekdayList[mode(collectionDays['garden'])],\n        letter: roundLetter,\n        letterGarden: roundLetterGarden\n    }\n    \n\t//now get the actual collection date because the collectionDateTime is sometimes inaccurate... honestly\n    async function processResults(results) {\n        return new Promise(async (resolve) => {\n            for (let service in results) {\n                if (results[service].hasOwnProperty('nextCollectionDate')) {\n                    results[service] = await getExpectedDate(results[service]);\n                }\n            }\n    \n            resolve(results);\n        });\n    }\n    \n    \n    async function getExpectedDate(service) {\n        const bin_payload = {\n            \"JobID\": {\n                \"name\": \"JobID\",\n                \"value\": service.nextCollectionDateId\n            },\n            \"AuthenticateResponse\": {\n                \"name\": \"AuthenticateResponse\",\n                \"value\": AuthenticateResponse\n            }\n        };\n    \n        try {\n            const response = await runLookup('658194703e7f8', bin_payload);\n            cacheIntRun('Bartec - binsubform - Jobs_Detail_Get');\n    \n            if (response.success) {\n                service.nextCollectionDate = new Date(formatDate(response.data[0].ExpectedStart));\n            } else {\n                service.nextCollectionDate = service.nextCollectionDate;\n            }\n    \n            return service;\n        } catch (error) {\n            console.error(\"Error in getExpectedDate:\", error);\n            return service;\n        }\n    }\n    \n    logIntRun()\n        \n    displayResults(results, resultKeys, roundObj, propertyDataResponse, attributes)\n    \n    \n    /*processResults(results).then(updatedResults => {\n        //save the integrations log in the db \n        logIntRun()\n        \n        displayResults(results, resultKeys, roundObj, propertyDataResponse)\n    })*/\n}\n\n\n//checks if data has returned from all integration before working on them\nvar checkData = (featuresScheduleGetResponse, jobsGetResponse, premisesAttributeGetResponse, propertyDataResponse) => {\n\tif (featuresScheduleGetResponse.hasRan && jobsGetResponse.hasRan && premisesAttributeGetResponse.hasRan && propertyDataResponse.hasRan) {\n\t    if (featuresScheduleGetResponse.success && jobsGetResponse.success && premisesAttributeGetResponse.success && propertyDataResponse.success) {\n\t        sortResults(featuresScheduleGetResponse.data, jobsGetResponse.data, premisesAttributeGetResponse.data, propertyDataResponse.data)\n\t    } else {\n\t        displayError()\n\t    }\n\t}\n}\n\n//runs all the relevant integration to retreive the data\nvar getBins = () => {\n    payload = {\n        \"UPRN\": {\n            \"name\": \"UPRN\",\n            \"value\": UPRN\n        },\n        \"AuthenticateResponse\": {\n            \"name\": \"AuthenticateResponse\",\n            \"value\": AuthenticateResponse\n        }\n    }\n\t\n\tvar template = {\n\t    hasRan: false,\n\t    success: false,\n\t    data: ''\n\t}\n\t\n    var response1 = Object.create(template)\n    var response2 = Object.create(template)\n    var response3 = Object.create(template)\n    var response4 = Object.create(template)\n    \n    //run each integration and check if all the data is returned\n    runLookup('6101d1a29ba09', payload).then((response) => {\n        cacheIntRun('Bartec - binsubform - Features_Schedules_Get')\n        response1 = response\n        checkData(response1, response2, response3, response4)\n    })\n    runLookup('6101d23110243', payload).then((response) => {\n        cacheIntRun('Bartec - binsubform - Jobs_Get')\n        response2 = response\n        checkData(response1, response2, response3, response4)\n    })\n    runLookup('6101d1ec57644', payload).then((response) => {\n        cacheIntRun('Bartec - binsubform - Premises_Attributes_Get')\n        response3 = response\n        checkData(response1, response2, response3, response4)\n    })\n    runLookup('657850070861d', payload).then((response) => {\n        response4 = response\n        checkData(response1, response2, response3, response4)\n    })\n}\n\n//checks and gets the authentication token\nvar getAuthenticateResponse = () => {\n    if (AuthenticateResponse == '') {\n\t\trunLookup('609b918c7dd6d').then((response) => {\n\t\t\tcacheIntRun('Bartec - get authenticate token')\n\t\t\t\n            if (response.success) {\n                AuthenticateResponse = response.data[0].AuthenticateResponse\n\t\t\t    getBins()\n            } else {\n                displayError()\n            }\n\t\t})\n    } else {\n        getBins()\n    }\n}\n\n//runs when the binUPRN token changes\n$('input[name=\"binUPRN\"]').change(() => {\n    if ($('input[name=\"binUPRN\"]')[0].value !== '' && $('input[name=\"binUPRN\"]')[0].value !== UPRN) {\n        UPRN = $('input[name=\"binUPRN\"]')[0].value\n        \n        //adds a message to show the customer to wait\n        $('#bin-schedule-content').empty()\n        $('input[name=\"loading\"]')[0].value = 'True'\n        $('input[name=\"loading\"]').trigger('input')\n        \n        $('input[name=\"round\"]')[0].value = ''\n        $('input[name=\"round\"]').trigger('input')\n        \n        getAuthenticateResponse()\n    } else if ($('input[name=\"binUPRN\"]')[0].value === '') {\n        //removes the information\n        $('#bin-schedule-content').empty()\n        $('input[name=\"loading\"]')[0].value = 'False'\n        $('input[name=\"loading\"]').trigger('input')\n        \n        $('input[name=\"round\"]')[0].value = ''\n        $('input[name=\"round\"]').trigger('input')\n    }\n})\n\nvar payload = {}\nvar AuthenticateResponse = ''\nvar lookupStatus = true\n\nvar UPRN = ''\n</script>"},["STYLE",{},"\n#bin-schedule-content {\n    font-size: 12pt;\n}\n\n#bin-schedule-content h3 {\n    padding-bottom: 20px;\n}\n\n.bin-schedule-content-service-card, .bin-schedule-content-bin-card {\n    padding-bottom: 20px;\n}\n\n.bin-schedule-content-bin-card {\n    display: flex;\n    flex-wrap: nowrap;\n}\n\n.bin-schedule-content-bin-card img {\n    height: 100px;\n}\n\n.bin-schedule-content-info p {\n    width: 100%;\n    padding-left: 20px;\n}\n\n@media only screen and (min-width: 768px) {\n    .bin-schedule-content-info {\n        padding-top: 15px;\n    }\n    \n}\n"],"\n",["DIV",{"id":"bin-schedule-content"}],"  \n"],["DIV",{"class":"screen-reader-error","aria-live":"polite","aria-atomic":"true"}]]],["DIV",{"class":"field fs-hidden","data-field-name":"loading","data-field-type":"text","style":"padding-top: 0px;"},["DIV",{"class":"fieldContent"},["LABEL",{"id":"label_loading","for":"loading","class":"col-xs-11 col-sm-11  fieldName alignAbove\t\t","style":"display: none;"},["SPAN",{"class":"_fieldName","style":"display: none;"},"loading"],"\t\t\t\t"],"\t",["DIV",{"class":"af-block col-xs-1 col-sm-1 ","style":"display: none;"}],["INPUT",{"__playwright_value_":"","type":"text","data-type":"text","name":"loading","id":"loading","data-name":"loading","aria-labelledby":"label_loading loading prefix_loading helpText_loading","readonly":"true","class":"col-xs-11 col-sm-11     fs-hidden-field alignAbove fieldInput text read_only_field ","data-hidden":"true","data-output-format":"normal","data-mandatory-message":"This field is required","data-min-message":"Please input at least _min_value_ characters","data-max-message":"Please input no more than _max_value_ characters","data-validation-mask-message":"Please input text of the format: _validation_mask_","autocomplete":"off","style":"display: none;"}],["DIV",{"class":"screen-reader-error","aria-live":"polite","aria-atomic":"true","style":"display: none;"}]]],["DIV",{"class":"field","data-field-name":"statictext1","data-field-type":"staticText","style":"display: none;"},["DIV",{"class":"fieldContent"},"\t",["SPAN",{"data-name":"statictext1","data-type":"staticText","class":"col-xs-11 col-sm-11 conditional fieldInput content staticText non-input ","data-display-condition":"{loading} is 'True'"}],["DIV",{"class":"screen-reader-error","aria-live":"polite","aria-atomic":"true"}]]],["DIV",{"class":"field fs-hidden","data-field-name":"round","data-field-type":"text","style":"padding-top: 0px;"},["DIV",{"class":"fieldContent"},["LABEL",{"id":"label_round","for":"round","class":"col-xs-11 col-sm-11  fieldName alignAbove\t