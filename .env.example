# Hetzner API token (required for deployment.py)
HCLOUD_TOKEN=

# Redis connection (set automatically in docker-compose, override if needed)
REDIS_URL=redis://redis:6379

# Public-facing URL (used for sitemap, CORS, etc.)
BASE_URL=https://ukbinday.co.uk
FRONTEND_URL=https://ukbinday.co.uk

# CORS allowed origins (comma-separated, defaults to FRONTEND_URL value)
CORS_ORIGINS=https://ukbinday.co.uk

# Environment (set to "production" to enable static file caching)
ENV=production

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# Scraper configuration
SCRAPER_TIMEOUT=30
CACHE_TTL=50400
RATE_LIMIT_DAILY=100
