lass=\"col-md-12\">\n                        \n                        \n                                    \n\n\n                        \r\n\n\r\n\r\n\r\n<p>\r\nMulberry<br/>\r\nUdny Station<br />\r\nAB41 6QQ</p>\r\n\r\n<table>\r\n    <tbody>\r\n        <tr>\r\n            <th scope=\"col\">Next collection</th>\r\n            <th scope=\"col\">What we will collect</th>\r\n            <th scope=\"col\">Collection frequency</th>\r\n        </tr>\r\n            <tr>\r\n                <td scope=\"col\" valign=\"top\">30/12/2025 Tuesday</td>\r\n                <td scope=\"col\" valign=\"top\">Blue lid bin recycling and food waste</td>\r\n                <td scope=\"col\" valign=\"top\">3 weekly</td>\r\n            </tr>\r\n            <tr>\r\n                <td scope=\"col\" valign=\"top\">06/01/2026 Tuesday</td>\r\n                <td scope=\"col\" valign=\"top\">Orange lid bin recycling and food waste</td>\r\n                <td scope=\"col\" valign=\"top\">3 weekly</td>\r\n            </tr>\r\n            <tr>\r\n                <td scope=\"col\" valign=\"top\">13/01/2026 Tuesday</td>\r\n                <td scope=\"col\" valign=\"top\">Refuse and food waste</td>\r\n                <td scope=\"col\" valign=\"top\">3 weekly</td>\r\n            </tr>\r\n    </tbody>\r\n</table>\r\n\r\n    <p class=\"callout\">\r\n        If the collection details are missing or you think they are incorrect, please email <a href=\\\"mailto:waste@aberdeenshire.gov.uk\\\">waste@aberdeenshire.gov.uk</a>\r\n    </p>\r\n\r\n<p>\r\n    <a href=\"https://online.aberdeenshire.gov.uk/waste/atoz\" target=\"_blank\" class=\"btn btn-primary\">Check what to put in each bin</a>\r\n</p>\r\n\r\n<p>\r\n    If your bin wasn't emptied on the collection day, please check for <a href=\"https://www.aberdeenshire.gov.uk/waste/disruptions-to-bin-collections/\">disruptions to bin collections</a> before reporting it as missed.\r\n</p>\r\n\r\n\r\n                                    <div id=\"ErrorMessageDiv\" 