// Minimal WebSocket client implementation (dependency-free)
class WebSocketClient {
  constructor(url) {
    this.url = new URL(url);
    this.callbacks = {};
    this.socket = null;
    this.buffer = Buffer.alloc(0);
  }

  on(event, callback) {
    this.callbacks[event] = callback;
  }

  connect() {
    return new Promise((resolve, reject) => {
      const http = require('http');
      const crypto = require('crypto');

      const key = crypto.randomBytes(16).toString('base64');

      const options = {
        hostname: this.url.hostname,
        port: this.url.port || 80,
        path: this.url.pathname + this.url.search,
        headers: {
          'Upgrade': 'websocket',
          'Connection': 'Upgrade',
          'Sec-WebSocket-Key': key,
          'Sec-WebSocket-Version': '13'
        }
      };

      const req = http.request(options);

      req.on('upgrade', (res, socket) => {
        this.socket = socket;

        socket.on('data', (data) => {
          this.buffer = Buffer.concat([this.buffer, data]);
          this.processFrames();
        });

        socket.on('error', (err) => {
          if (this.callbacks.error) this.callbacks.error(err);
        });

        if (this.callbacks.open) this.callbacks.open();
        resolve();
      });

      req.on('error', reject);
      req.end();
    });
  }

  processFrames() {
    while (this.buffer.length >= 2) {
      const firstByte = this.buffer[0];
      const secondByte = this.buffer[1];

      const fin = (firstByte & 0x80) !== 0;
      const opcode = firstByte & 0x0F;
      const masked = (secondByte & 0x80) !== 0;
      let payloadLen = secondByte & 0x7F;

      let offset = 2;

      if (payloadLen === 126) {
        if (this.buffer.length < 4) return;
        payloadLen = this.buffer.readUInt16BE(2);
        offset = 4;
      } else if (payloadLen === 127) {
        if (this.buffer.length < 10) return;
        payloadLen = Number(this.buffer.readBigUInt64BE(2));
        offset = 10;
      }

      if (this.buffer.length < offset + payloadLen) return;

      let payload = this.buffer.slice(offset, offset + payloadLen);
      this.buffer = this.buffer.slice(offset + payloadLen);

      if (opcode === 0x1 && this.callbacks.message) {
        this.callbacks.message(payload.toString('utf8'));
      }
    }
  }

  send(data) {
    const payload = Buffer.from(data, 'utf8');
    const payloadLen = payload.length;

    let frame;
    let offset = 2;

    if (payloadLen < 126) {
      frame = Buffer.alloc(payloadLen + 6);
      frame[1] = payloadLen | 0x80;
    } else if (payloadLen < 65536) {
      frame = Buffer.alloc(payloadLen + 8);
      frame[1] = 126 | 0x80;
      frame.writeUInt16BE(payloadLen, 2);
      offset = 4;
    } else {
      frame = Buffer.alloc(payloadLen + 14);
      frame[1] = 127 | 0x80;
      frame.writeBigUInt64BE(BigInt(payloadLen), 2);
      offset = 10;
    }

    frame[0] = 0x81; // FIN + text frame

    const mask = Buffer.alloc(4);
    require('crypto').randomFillSync(mask);
    mask.copy(frame, offset);
    offset += 4;

    for (let i = 0; i < payloadLen; i++) {
      frame[offset + i] = payload[i] ^ mask[i % 4];
    }

    this.socket.write(frame);
  }

  close() {
    if (this.socket) {
      this.socket.end();
      this.socket = null;
    }
  }
}

// SessionManager for persistent connections with network tracking
class SessionManager {
  constructor(wsUrl, sessionId) {
    this.wsUrl = wsUrl;
    this.sessionId = sessionId;
    this.ws = new WebSocketClient(wsUrl);
    this.messageId = 1;
    this.networkLog = [];
    this.pendingRequests = new Map(); // requestId -> request data
    this.pendingResponses = new Map(); // requestId -> response data
    this.callbacks = new Map(); // messageId -> {resolve, reject}
    this.connected = false;
  }

  async connect() {
    return new Promise(async (resolve, reject) => {
      this.ws.on('error', (err) => {
        reject(err);
      });

      this.ws.on('message', (data) => {
        this.handleMessage(data);
      });

      try {
        await this.ws.connect();
        this.connected = true;

        // Enable Network domain
        await this.sendCommand('Network.enable', {});

        resolve();
      } catch (err) {
        reject(err);
      }
    });
  }

  handleMessage(data) {
    try {
      const message = JSON.parse(data);

      // Handle command responses
      if (message.id && this.callbacks.has(message.id)) {
        const { resolve, reject } = this.callbacks.get(message.id);
        this.callbacks.delete(message.id);

        if (message.error) {
          reject(new Error(message.error.message || JSON.stringify(message.error)));
        } else {
          resolve(message.result);
        }
        return;
      }

      // Handle network events
      if (message.method) {
        this.handleNetworkEvent(message.method, message.params);
      }
    } catch (err) {
      console.error('Failed to parse message:', err.message);
    }
  }

  handleNetworkEvent(method, params) {
    try {
      if (method === 'Network.requestWillBeSent') {
        const requestData = {
          requestId: params.requestId,
          url: params.request.url,
          method: params.request.method,
          requestHeaders: params.request.headers,
          requestBody: params.request.postData || null,
          resourceType: params.type,
          initiator: params.initiator,
          timestamp: params.timestamp
        };
        this.pendingRequests.set(params.requestId, requestData);
      } else if (method === 'Network.responseReceived') {
        const responseData = {
          requestId: params.requestId,
          responseStatus: params.response.status,
          responseHeaders: params.response.headers,
          mimeType: params.response.mimeType,
          timestamp: params.timestamp
        };
        this.pendingResponses.set(params.requestId, responseData);
      } else if (method === 'Network.loadingFinished') {
        // Request completed - combine request and response data
        const requestId = params.requestId;
        const requestData = this.pendingRequests.get(requestId);
        const responseData = this.pendingResponses.get(requestId);

        if (requestData && responseData) {
          // Store for later body retrieval
          this.networkLog.push({
            ...requestData,
            ...responseData,
            loadTimestamp: params.timestamp,
            encodedDataLength: params.encodedDataLength
          });
        }

        // Clean up
        this.pendingRequests.delete(requestId);
        this.pendingResponses.delete(requestId);
      } else if (method === 'Network.loadingFailed') {
        // Request failed
        const requestId = params.requestId;
        const requestData = this.pendingRequests.get(requestId);

        if (requestData) {
          this.networkLog.push({
            ...requestData,
            failed: true,
            errorText: params.errorText,
            canceled: params.canceled
          });
        }

        this.pendingRequests.delete(requestId);
        this.pendingResponses.delete(requestId);
      }
    } catch (err) {
      console.error('Error handling network event:', err.message);
    }
  }

  async sendCommand(method, params) {
    return new Promise((resolve, reject) => {
      const id = this.messageId++;
      this.callbacks.set(id, { resolve, reject });

      const message = { id, method, params };
      this.ws.send(JSON.stringify(message));

      // Timeout after 30 seconds
      setTimeout(() => {
        if (this.callbacks.has(id)) {
          this.callbacks.delete(id);
          reject(new Error('Command timeout'));
        }
      }, 30000);
    });
  }

  async executeCommand(command, args) {
    // Execute existing chrome-ws commands within session context
    switch (command) {
      case 'navigate':
        const [url] = args;
        return await this.sendCommand('Page.navigate', { url });

      case 'click':
        const [clickSelector] = args;
        const clickJs = `
          (function() {
            const el = document.querySelector(${JSON.stringify(clickSelector)});
            if (!el) throw new Error('Element not found: ${clickSelector}');
            el.click();
            return true;
          })()
        `;
        return await this.sendCommand('Runtime.evaluate', { expression: clickJs });

      case 'fill':
        const [fillSelector, value] = args;
        const fillJs = `
          (function() {
            const el = document.querySelector(${JSON.stringify(fillSelector)});
            if (!el) throw new Error('Element not found: ${fillSelector}');
            el.value = ${JSON.stringify(value)};
            el.dispatchEvent(new Event('input', { bubbles: true }));
            el.dispatchEvent(new Event('change', { bubbles: true }));
            return true;
          })()
        `;
        return await this.sendCommand('Runtime.evaluate', { expression: fillJs });

      case 'extract':
        const [extractSelector] = args;
        const extractJs = `
          (function() {
            const el = document.querySelector(${JSON.stringify(extractSelector)});
            if (!el) throw new Error('Element not found: ${extractSelector}');
            return el.textContent.trim();
          })()
        `;
        const result = await this.sendCommand('Runtime.evaluate', { expression: extractJs, returnByValue: true });
        return result.result.value;

      case 'wait-for':
        const [waitSelector] = args;
        const waitJs = `
          (function() {
            return new Promise((resolve) => {
              const check = () => {
                if (document.querySelector(${JSON.stringify(waitSelector)})) {
                  resolve(true);
                } else {
                  setTimeout(check, 100);
                }
              };
              check();
            });
          })()
        `;
        return await this.sendCommand('Runtime.evaluate', { expression: waitJs, awaitPromise: true });

      default:
        throw new Error(`Unsupported command in session: ${command}`);
    }
  }

  async exportNetworkLog(outputFile) {
    const fs = require('fs');

    // Retrieve response bodies for all captured requests
    const completeLog = [];
    for (const entry of this.networkLog) {
      if (entry.requestId && !entry.failed) {
        try {
          const bodyResult = await this.sendCommand('Network.getResponseBody', {
            requestId: entry.requestId
          });
          entry.responseBody = bodyResult.body;
          entry.responseBodyBase64 = bodyResult.base64Encoded;
        } catch (err) {
          // Some requests may not have bodies (e.g., 204, images, etc.)
          entry.responseBody = null;
          entry.responseBodyError = err.message;
        }
      }
      completeLog.push(entry);
    }

    // Write to file
    fs.writeFileSync(outputFile, JSON.stringify(completeLog, null, 2));
    return completeLog;
  }

  async close() {
    try {
      await this.sendCommand('Network.disable', {});
    } catch (err) {
      // Ignore errors during cleanup
    }
    this.ws.close();
    this.connected = false;
  }
}

