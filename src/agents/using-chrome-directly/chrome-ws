          const check = () => {
            if (document.body.textContent.includes(${JSON.stringify(text)})) {
              resolve(true);
            } else {
              setTimeout(check, 100);
            }
          };
          check();
        });
      `;
      await sendCdpCommand(wsUrl, 'Runtime.evaluate', {
        expression: js,
        awaitPromise: true
      });
      console.log(`Text found: ${text}`);
    } catch (e) {
      console.error('Wait failed:', e.message);
      process.exit(1);
    }
  })();
  return;
}

