// Command: session-start - start persistent monitoring session
if (command === 'session-start') {
  if (!wsUrlOrIndex) {
    console.error('Usage: chrome-ws session-start <tab-index-or-ws-url>');
    process.exit(1);
  }
  (async () => {
    try {
      const wsUrl = await resolveWsUrl(wsUrlOrIndex);

      // Generate unique session ID
      const crypto = require('crypto');
      const sessionId = crypto.randomUUID();

      // Create session manager
      const session = new SessionManager(wsUrl, sessionId);
      await session.connect();

      // Store in global sessions map
      sessions.set(sessionId, session);

      // Print session ID to stdout (will be read by Python)
      console.log(sessionId);

      // Keep process alive - don't exit
      // Session will be closed by session-stop command
    } catch (e) {
      console.error('Failed to start session:', e.message);
      process.exit(1);
    }
  })();
  return;
}

// Command: session-cmd - execute command within session
if (command === 'session-cmd') {
  const [sessionId, subCommand, ...subArgs] = [wsUrlOrIndex, ...args];

  if (!sessionId || !subCommand) {
    console.error('Usage: chrome-ws session-cmd <session-id> <command> [...args]');
    console.error('Example: chrome-ws session-cmd abc123 navigate https://example.com');
    process.exit(1);
  }

  (async () => {
    try {
      const session = sessions.get(sessionId);
      if (!session) {
        console.error(`Session not found: ${sessionId}`);
        process.exit(1);
      }

      // Execute command within session
      const result = await session.executeCommand(subCommand, subArgs);

      // Print result if any
      if (result !== undefined && result !== null) {
        if (typeof result === 'object') {
          console.log(JSON.stringify(result, null, 2));
        } else {
          console.log(result);
        }
      }

      // Exit after command completes
      process.exit(0);
    } catch (e) {
      console.error('Command failed:', e.message);
      process.exit(1);
    }
  })();
  return;
}

// Command: session-stop - stop session and export network log
if (command === 'session-stop') {
  const [sessionId, outputFile] = [wsUrlOrIndex, ...args];

  if (!sessionId || !outputFile) {
    console.error('Usage: chrome-ws session-stop <session-id> <output-file.json>');
    process.exit(1);
  }

  (async () => {
    try {
      const session = sessions.get(sessionId);
      if (!session) {
        console.error(`Session not found: ${sessionId}`);
        process.exit(1);
      }

      // Export network log to file
      const networkLog = await session.exportNetworkLog(outputFile);
      console.log(`Network log exported to ${outputFile} (${networkLog.length} entries)`);

      // Clean up session
      await session.close();
      sessions.delete(sessionId);

      process.exit(0);
    } catch (e) {
      console.error('Failed to stop session:', e.message);
      process.exit(1);
    }
  })();
  return;
}

if (command !== 'raw' || !wsUrlOrIndex || args.length === 0) {
  console.error('Usage: chrome-ws raw <tab-index-or-ws-url> <json-rpc-payload>');
  process.exit(1);
}

const payload = args.join(' ');
let message;
try {
  message = JSON.parse(payload);
} catch (e) {
  console.error('Invalid JSON payload:', e.message);
  process.exit(1);
}

// For raw command, wsUrlOrIndex must be a full WebSocket URL (not an index)
// since this is the low-level escape hatch
if (!wsUrlOrIndex.startsWith('ws://')) {
  console.error('raw command requires full WebSocket URL, not tab index');
  console.error('Use: chrome-ws tabs  # to get WebSocket URLs');
  process.exit(1);
}

(async () => {
  const ws = new WebSocketClient(wsUrlOrIndex);

  const timeout = setTimeout(() => {
    console.error('Timeout after 30s');
    ws.close();
    process.exit(1);
  }, 30000);

  ws.on('message', (data) => {
    const response = JSON.parse(data);
    if (response.id === message.id) {
      clearTimeout(timeout);
      console.log(JSON.stringify(response, null, 2));
      ws.close();
      process.exit(0);
    }
  });

  ws.on('error', (error) => {
    clearTimeout(timeout);
    console.error('WebSocket error:', error.message);
    process.exit(1);
  });

  try {
    await ws.connect();
    ws.send(JSON.stringify(message));
  } catch (err) {
    clearTimeout(timeout);
    console.error('Connection failed:', err.message);
    process.exit(1);
  }
})();
