    console.error('Usage: chrome-ws new <url>');
    process.exit(1);
  }
  const url = wsUrlOrIndex;
  (async () => {
    try {
      const tab = await chromeHttp(`/json/new?${encodeURIComponent(url)}`, 'PUT');
      console.log(tab.webSocketDebuggerUrl);
